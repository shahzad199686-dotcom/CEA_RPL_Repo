@model IEnumerable<CEA_RPL.Domain.Entities.Applicant>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Application Management";
}

<div class="dashboard-content">
    <div class="admin-container-limit">
        <!-- TIER 1: EXECUTIVE HEADER -->
        <div class="welcome-hero-alt">
            <div>
                <h1>Application <span style="color: var(--a-primary);">Directory</span></h1>
                <p>Manage, audit, and certify environment auditor candidates globally.</p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex gap-2 me-3">
                    <button class="btn-export" title="Export to PDF"><i data-lucide="file-text"></i></button>
                    <button class="btn-export" title="Export to CSV"><i data-lucide="download"></i></button>
                </div>
                <a asp-action="Dashboard" class="btn-cta-primary">
                    <i data-lucide="clock" style="width: 20px; height: 20px;"></i>
                    Review Pending
                </a>
            </div>
        </div>

        <!-- TIER 2: MODERN FILTER TOOLBAR -->
        <div class="modern-toolbar-card">
            <div class="toolbar-group" style="flex: 2;">
                <div class="position-relative w-100">
                    <i data-lucide="search" style="position: absolute; left: 16px; top: 14px; color: var(--a-muted); width: 20px;"></i>
                    <input type="text" id="appSearch" class="toolbar-input" style="padding-left: 48px;" placeholder="Search candidate name, ID, or email...">
                </div>
            </div>
            
            <div class="toolbar-group">
                <span class="toolbar-label">Status</span>
                <select id="statusFilter" class="toolbar-input">
                    <option value="">All Statuses</option>
                    <option value="Submitted">Submitted</option>
                    <option value="UnderReview">Under Review</option>
                    <option value="Approved">Approved</option>
                    <option value="Rejected">Rejected</option>
                </select>
            </div>

            <div class="toolbar-group">
                <span class="toolbar-label">Category</span>
                <select class="toolbar-input">
                    <option>All Categories</option>
                    <option>Category 1</option>
                    <option>Category 2</option>
                </select>
            </div>

            <div class="toolbar-group" style="flex: 0 0 auto;">
                <button class="btn-export" style="height: 48px; border-radius: 12px; padding: 0 16px;">
                    <i data-lucide="sliders-horizontal" style="width: 20px; height: 20px;"></i>
                </button>
            </div>
        </div>

        <!-- TIER 3: APPLICATION CARD STACK -->
        <div id="cardContainer">
            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                    <i data-lucide="folder-open" style="width: 48px; height: 48px; color: var(--a-line);"></i>
                    <h5 class="mt-3 fw-bold text-muted">No applications found</h5>
                </div>
            }

            @foreach (var app in Model)
            {
                var statusPillClass = app.Status switch
                {
                    "Approved" => "pill-green",
                    "Rejected" => "pill-red",
                    "Submitted" => "pill-amber",
                    "UnderReview" => "pill-blue",
                    "Feedback Pending" => "pill-blue",
                    _ => "pill-amber"
                };

                var cats = string.IsNullOrEmpty(app.Categories) ? new string[0] : app.Categories.Split(',');
                var displayCats = cats.Take(2).ToList();
                var remaining = cats.Length - 2;

                <div class="app-row-card-wrapper">
                    <div class="app-row-card">
                        <!-- Avatar & Identity -->
                        <div class="row-card-avatar">
                            @(app.FullName.Length > 0 ? app.FullName[0].ToString() : "A")
                        </div>
                        
                        <div class="row-card-info">
                            <span class="row-card-title">@app.FullName</span>
                            <span class="row-card-subtitle">ID: RPL-@app.Id.ToString("D4")</span>
                        </div>

                        <!-- Contact Information -->
                        <div class="row-card-contact">
                            <div class="fw-bold" style="color: var(--a-ink); font-size: 0.85rem;">@app.Email</div>
                            <div class="text-muted small fw-bold">@app.Mobile</div>
                        </div>

                        <!-- Classification Tags -->
                        <div class="row-card-tags">
                            @foreach (var cat in displayCats)
                            {
                                <span class="cat-chip text-truncate" style="max-width: 100px;">@cat.Trim()</span>
                            }
                            @if (remaining > 0)
                            {
                                <span class="cat-chip" style="background: transparent; border-color: var(--a-line);">+@remaining more</span>
                            }
                            @if (cats.Length == 0)
                            {
                                <span class="text-muted small">No categories</span>
                            }
                        </div>

                        <!-- Metadata -->
                        <div class="row-card-meta">
                            <div class="toolbar-label" style="font-size: 0.6rem; margin-bottom: 4px; color: var(--a-muted);">Submitted Date</div>
                            <div class="fw-bold" style="font-size: 0.9rem; color: var(--a-ink);">@app.CreatedAt.ToString("dd MMM yyyy")</div>
                        </div>

                        <!-- Decision Status -->
                        <div class="row-card-status">
                            <span class="status-pill @statusPillClass">@app.Status</span>
                        </div>

                        <!-- Narrative Action -->
                        <div class="ms-3">
                            <a asp-action="Details" asp-route-id="@app.Id" class="btn-review-pill">
                                Review Application <i data-lucide="arrow-right" style="width: 16px; height: 16px;"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // CLIENT-SIDE SEARCH & FILTER
        const searchInput = document.getElementById('appSearch');
        const statusFilter = document.getElementById('statusFilter');
        const cards = document.querySelectorAll('.app-row-card-wrapper');

        function performFiltering() {
            const query = searchInput.value.toLowerCase();
            const statusValue = statusFilter.value.toLowerCase();

            cards.forEach(wrapper => {
                const card = wrapper.querySelector('.app-row-card');
                const name = card.querySelector('.row-card-title').innerText.toLowerCase();
                const email = card.querySelector('.row-card-contact > div:first-child').innerText.toLowerCase();
                const status = card.querySelector('.status-pill').innerText.toLowerCase();

                const matchesSearch = name.includes(query) || email.includes(query);
                const matchesStatus = statusValue === "" || status.includes(statusValue);

                wrapper.style.display = (matchesSearch && matchesStatus) ? 'block' : 'none';
            });
        }

        searchInput.addEventListener('input', performFiltering);
        statusFilter.addEventListener('change', performFiltering);

        // INITIALIZE ICONS
        lucide.createIcons();
    </script>
}

<style>
    .app-row-card-wrapper { transition: all 0.3s ease; }
    .btn-export i { width: 18px; height: 18px; }
</style>
