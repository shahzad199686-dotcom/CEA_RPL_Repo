@model CEA_RPL.Models.AdminReportViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Executive Analytics";
}

<!-- ANALYTICS KPI STRIP -->
<div class="stats-grid">
    <div class="modern-card p-4 d-flex align-items-center gap-3">
        <div class="stat-icon-box bg-blue-subtle text-primary" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="bar-chart-3" style="width: 20px;"></i></div>
        <div>
            <div style="font-size: 0.7rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Total Cases</div>
            <div style="font-size: 1.35rem; font-weight: 800; color: var(--a-ink);">@Model.Total</div>
        </div>
    </div>
    <div class="modern-card p-4 d-flex align-items-center gap-3">
        <div class="stat-icon-box bg-emerald-subtle text-success" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="check-check" style="width: 20px;"></i></div>
        <div>
            <div style="font-size: 0.7rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Approved</div>
            <div style="font-size: 1.35rem; font-weight: 800; color: var(--a-ink);">@Model.Approved</div>
        </div>
    </div>
    <div class="modern-card p-4 d-flex align-items-center gap-3">
        <div class="stat-icon-box bg-amber-subtle text-warning" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="clock" style="width: 20px;"></i></div>
        <div>
            <div style="font-size: 0.7rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Pending</div>
            <div style="font-size: 1.35rem; font-weight: 800; color: var(--a-ink);">@Model.Pending</div>
        </div>
    </div>
    <div class="modern-card p-4 d-flex align-items-center gap-3">
        <div class="stat-icon-box bg-red-subtle text-danger" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;"><i data-lucide="shield-x" style="width: 20px;"></i></div>
        <div>
            <div style="font-size: 0.7rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Rejected</div>
            <div style="font-size: 1.35rem; font-weight: 800; color: var(--a-ink);">@Model.Rejected</div>
        </div>
    </div>
</div>

<!-- CORE ANALYTICS -->
<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="modern-card p-4 h-100">
            <h5 class="fw-bold mb-4">Portal Velocity Trends</h5>
            <div style="height: 340px;">
                <canvas id="mainTrendChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="modern-card p-4 h-100 text-center">
            <h5 class="fw-bold text-start mb-4">Certification Mix</h5>
            <div class="d-flex flex-column align-items-center justify-content-center h-100" style="min-height: 280px;">
                <div style="height: 180px; width: 180px; margin-bottom: 24px;">
                    <canvas id="donutChart"></canvas>
                </div>
                <div class="w-100 text-start small">
                    <div class="d-flex justify-content-between py-1 border-bottom border-light"><span class="text-muted fw-bold">Success Rate</span><span class="fw-bold">@((Model.Total > 0 ? (Model.Approved * 100 / Model.Total) : 0))%</span></div>
                    <div class="d-flex justify-content-between py-1"><span class="text-muted fw-bold">Active Review</span><span class="fw-bold">@Model.Pending</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- REDESIGNED ADMINISTRATIVE ACTIVITY AUDIT -->
<div class="audit-container">
    <div class="audit-header">
        <i data-lucide="history"></i>
        <h5 class="mb-0 fw-800 text-dark">Administrative Activity Audit</h5>
    </div>
    <div class="table-responsive">
        <table class="audit-table">
            <thead>
                <tr>
                    <th class="audit-cell x-small fw-800 text-muted uppercase">Event Type</th>
                    <th class="audit-cell x-small fw-800 text-muted uppercase">Entity / Reference</th>
                    <th class="audit-cell x-small fw-800 text-muted uppercase">Authorized Actor</th>
                    <th class="audit-cell x-small fw-800 text-muted uppercase text-end">Event Time</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var act in Model.RecentActivities)
                {
                    <tr class="audit-row">
                        <td class="audit-cell">
                            <div class="d-flex align-items-center gap-2">
                                <div class="bg-primary-light text-primary rounded p-1" style="line-height: 0;">
                                    <i data-lucide="clipboard-list" style="width: 14px;"></i>
                                </div>
                                <span class="fw-bold text-dark" style="font-size: 0.9rem;">@act.Action</span>
                            </div>
                        </td>
                        <td class="audit-cell">
                            <span class="audit-reference">@act.Entity</span>
                        </td>
                        <td class="audit-cell">
                            <span class="actor-badge">@act.Actor</span>
                        </td>
                        <td class="audit-cell text-end">
                            <div class="fw-bold text-dark" style="font-size: 0.85rem;">@act.Timestamp.ToString("HH:mm")</div>
                            <div class="x-small text-muted fw-bold">@act.Timestamp.ToString("dd MMM yyyy")</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             Chart.defaults.font.family = "'Inter', sans-serif";
             Chart.defaults.color = "#94a3b8";

            // 1. Line
            const lineCtx = document.getElementById('mainTrendChart').getContext('2d');
            new Chart(lineCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                    datasets: [{
                        label: 'Cases',
                        data: [65, 59, 80, 81, 56, 55, 40, 72, 88, 105, 95, 120],
                        borderColor: '#0ea5a5',
                        backgroundColor: 'rgba(14, 165, 165, 0.05)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { grid: { color: '#f1f5f9' }, min: 0 },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Donut
            const donutCtx = document.getElementById('donutChart').getContext('2d');
            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Approved', 'Pending', 'Rejected'],
                    datasets: [{
                        data: [@Model.Approved, @Model.Pending, @Model.Rejected],
                        backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                        borderWidth: 0,
                        hoverOffset: 12
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '82%',
                    plugins: { legend: { display: false } }
                }
            });
            lucide.createIcons();
        });
    </script>
}
