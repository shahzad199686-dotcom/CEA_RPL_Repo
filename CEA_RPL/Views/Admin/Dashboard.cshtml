@model IEnumerable<CEA_RPL.Domain.Entities.Applicant>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Executive Overview";
}

<!-- KPI WIDGETS -->
<div class="stats-grid">
    <div class="modern-card p-4 d-flex align-items-center gap-4">
        <div class="stat-icon-box bg-blue-subtle text-primary" style="width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i data-lucide="users"></i>
        </div>
        <div>
            <div style="font-size: 0.75rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Total Volume</div>
            <div style="font-size: 1.5rem; font-weight: 800; color: var(--a-ink);">@ViewBag.Total</div>
            <div class="small text-success fw-bold"><i data-lucide="trending-up" style="width: 12px; height: 12px;"></i> +8.4%</div>
        </div>
    </div>
    
    <div class="modern-card p-4 d-flex align-items-center gap-4">
        <div class="stat-icon-box bg-amber-subtle text-warning" style="width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i data-lucide="clock"></i>
        </div>
        <div>
            <div style="font-size: 0.75rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Awaiting Review</div>
            <div style="font-size: 1.5rem; font-weight: 800; color: var(--a-ink);">@ViewBag.Pending</div>
            <div class="small text-warning fw-bold">Active Requests</div>
        </div>
    </div>

    <div class="modern-card p-4 d-flex align-items-center gap-4">
        <div class="stat-icon-box bg-emerald-subtle text-success" style="width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i data-lucide="verified"></i>
        </div>
        <div>
            <div style="font-size: 0.75rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">Certified</div>
            <div style="font-size: 1.5rem; font-weight: 800; color: var(--a-ink);">@ViewBag.Approved</div>
            <div class="small text-success fw-bold">Quality Quota</div>
        </div>
    </div>

    <div class="modern-card p-4 d-flex align-items-center gap-4">
        <div class="stat-icon-box bg-teal-subtle text-primary" style="width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
            <i data-lucide="mail"></i>
        </div>
        <div>
            <div style="font-size: 0.75rem; font-weight: 800; color: var(--a-muted); text-transform: uppercase;">New Today</div>
            <div style="font-size: 1.5rem; font-weight: 800; color: var(--a-ink);">@ViewBag.SubmittedToday</div>
            <div class="small text-primary fw-bold">Live Stream</div>
        </div>
    </div>
</div>

<!-- ANALYTICS PREVIEW -->
<div class="row g-4 mb-5">
    <div class="col-xl-8">
        <div class="modern-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Daily Submission Trends</h5>
                <div class="badge bg-light text-muted border px-3 py-2">Last 7 Days</div>
            </div>
            <div style="height: 300px;">
                <canvas id="submissionsChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="modern-card p-4 text-center">
            <h5 class="fw-bold text-start mb-4">Certification Distribution</h5>
            <div class="d-flex flex-column align-items-center justify-content-center h-100" style="min-height: 280px;">
                <div style="height: 180px; width: 180px; margin-bottom: 24px;">
                    <canvas id="statusDonutChart"></canvas>
                </div>
                <div class="w-100 text-start small">
                    <div class="d-flex justify-content-between py-1"><span class="text-muted fw-bold">Approved</span><span class="fw-bold">@ViewBag.Approved</span></div>
                    <div class="d-flex justify-content-between py-1"><span class="text-muted fw-bold">Pending</span><span class="fw-bold">@ViewBag.Pending</span></div>
                    <div class="d-flex justify-content-between py-1"><span class="text-muted fw-bold">Rejected</span><span class="fw-bold">@ViewBag.Rejected</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- REDESIGNED SMART APPLICATION FEED -->
<div class="feed-container">
    <div class="feed-header">
        <h4 class="mb-0 fw-800 text-dark">Direct Application Feed</h4>
        <a asp-action="Applications" class="btn btn-secondary px-4 fw-800 rounded-pill shadow-sm" style="font-size: 0.8rem; background: #334155; border: none;">
            View Full Directory
        </a>
    </div>
    
    <div class="feed-table-card">
        <table class="feed-table">
            <thead>
                <tr>
                    <th>Ref ID</th>
                    <th>Candidate Detail</th>
                    <th>Contact Info</th>
                    <th>Submission</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model.Take(5))
                {
                    var stClass = app.Status switch {
                        "Approved" => "st-approved",
                        "Rejected" => "st-rejected",
                        "Submitted" => "st-submitted",
                        "UnderReview" => "st-review",
                        "Draft" => "st-review",
                        _ => "st-submitted"
                    };

                    var displayDate = app.SubmittedAt ?? app.CreatedAt;
                    var dateLabel = app.Status == "Draft" ? "Portal Entry" : "Portal Direct";

                    <tr class="feed-row">
                        <!-- Ref ID -->
                        <td class="feed-cell">
                            <span class="candidate-id">#@app.Id.ToString("D4")</span>
                        </td>
                        
                        <!-- Candidate Detail -->
                        <td class="feed-cell">
                            <div class="candidate-pill">
                                <div class="candidate-avatar">
                                    @(app.FullName.Length > 0 ? app.FullName[0].ToString() : "A")
                                </div>
                                <div>
                                    <div class="candidate-name">@app.FullName</div>
                                    <div class="x-small text-muted fw-bold">Candidate Profile</div>
                                </div>
                            </div>
                        </td>

                        <!-- Contact Info -->
                        <td class="feed-cell">
                            <div class="contact-stack">
                                <div class="contact-item">
                                    <i data-lucide="mail"></i> @app.Email
                                </div>
                                <div class="contact-item">
                                    <i data-lucide="phone"></i> @app.Mobile
                                </div>
                            </div>
                        </td>

                        <!-- Submission Date -->
                        <td class="feed-cell">
                            <div class="fw-bold text-dark" style="font-size: 0.85rem;">@displayDate.ToString("dd MMM yyyy")</div>
                            <div class="x-small text-muted fw-bold">@dateLabel</div>
                        </td>

                        <!-- Status Badge -->
                        <td class="feed-cell">
                            <span class="status-badge @stClass" style="font-size: 0.65rem; padding: 6px 14px;">
                                @(app.Status?.ToUpper() ?? "SUBMITTED")
                            </span>
                        </td>

                        <!-- Action -->
                        <td class="feed-cell text-end">
                            <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-outline-primary btn-sm rounded-pill fw-800 px-4" style="border-width: 2px;">
                                Review
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="bg-light d-inline-flex p-4 rounded-circle mb-3">
                    <i data-lucide="inbox" style="width: 44px; height: 44px; color: var(--a-muted);"></i>
                </div>
                <h5 class="fw-bold">No Records Found</h5>
                <p class="text-muted small">Active submissions will be displayed here.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             Chart.defaults.font.family = "'Inter', sans-serif";
             Chart.defaults.color = "#94a3b8";

            // 1. Frequency
            const trendCtx = document.getElementById('submissionsChart').getContext('2d');
            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Requests',
                        data: [12, 19, 15, 25, 22, 30, @(ViewBag.SubmittedToday ?? 18)],
                        borderColor: '#0ea5a5',
                        backgroundColor: 'rgba(14, 165, 165, 0.05)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f1f5f9' }, border: { display: false } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Mix
            const donutCtx = document.getElementById('statusDonutChart').getContext('2d');
            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Approved', 'Pending', 'Rejected'],
                    datasets: [{
                        data: [@(ViewBag.Approved ?? 0), @(ViewBag.Pending ?? 0), @(ViewBag.Rejected ?? 0)],
                        backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '82%',
                    plugins: { legend: { display: false } }
                }
            });
            lucide.createIcons();
        });
    </script>
}
