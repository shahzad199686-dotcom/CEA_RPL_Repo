@model IEnumerable<CEA_RPL.Models.AdminDocumentViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Document Repository";
}

<div class="dashboard-content">
    <div class="admin-container-limit">
        <!-- TIER 1: EXECUTIVE HEADER -->
        <div class="welcome-hero-alt">
            <div>
                <h1>Document <span style="color: var(--a-primary);">Repository</span></h1>
                <p>Centralized access to all candidate uploaded files, reports, and enclosures.</p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex gap-2 me-3">
                    <button class="btn-export" title="Filter Repository"><i data-lucide="filter"></i></button>
                    <button class="btn-export" title="Download All Files"><i data-lucide="download-cloud"></i></button>
                </div>
                <button class="btn-cta-primary">
                    <i data-lucide="archive" style="width: 20px; height: 20px;"></i>
                    Export ZIP
                </button>
            </div>
        </div>

        <!-- TIER 2: MODERN FILTER TOOLBAR -->
        <div class="modern-toolbar-card">
            <div class="toolbar-group" style="flex: 2;">
                <div class="position-relative w-100">
                    <i data-lucide="search" style="position: absolute; left: 16px; top: 14px; color: var(--a-muted); width: 20px;"></i>
                    <input type="text" id="docSearch" class="toolbar-input" style="padding-left: 48px;" placeholder="Search by candidate name or ID...">
                </div>
            </div>
            
            <div class="toolbar-group">
                <span class="toolbar-label">Doc Type</span>
                <select id="typeFilter" class="toolbar-input">
                    <option value="">All Types</option>
                    <option value="GOV ID">Gov ID</option>
                    <option value="REPORT">Reports</option>
                    <option value="ENCLOSURE">Enclosures</option>
                </select>
            </div>

            <div class="toolbar-group">
                <span class="toolbar-label">Uploaded</span>
                <select class="toolbar-input">
                    <option>Any Time</option>
                    <option>Last 7 Days</option>
                    <option>This Month</option>
                </select>
            </div>

            <div class="toolbar-group" style="flex: 0 0 auto;">
                <button class="btn-export" style="height: 48px; border-radius: 12px; padding: 0 16px;">
                    <i data-lucide="sort-desc" style="width: 20px; height: 20px;"></i>
                </button>
            </div>
        </div>

        <!-- TIER 3: DOCUMENT CARD STACK -->
        <div id="docContainer">
            @if (!Model.Any())
            {
                <div class="text-center py-5 bg-white rounded-4 shadow-sm">
                    <i data-lucide="file-x" style="width: 48px; height: 48px; color: var(--a-line);"></i>
                    <h5 class="mt-3 fw-bold text-muted">No documents found</h5>
                </div>
            }

            @foreach (var doc in Model)
            {
                var typeClass = doc.Type switch
                {
                    "GOV ID" => "pill-teal",
                    "REPORT" => "pill-blue",
                    "ENCLOSURE" => "pill-amber",
                    _ => "pill-amber"
                };

                var iconName = doc.Type == "GOV ID" ? "user-square-2" : (doc.Type == "REPORT" ? "file-text" : "paperclip");
                var iconColor = doc.Type == "GOV ID" ? "#0ea5a5" : (doc.Type == "REPORT" ? "#3b82f6" : "#f59e0b");
                var iconBg = doc.Type == "GOV ID" ? "#e6f6f6" : (doc.Type == "REPORT" ? "#eff6ff" : "#fffbeb");

                <div class="doc-row-card-wrapper">
                    <div class="app-row-card">
                        <!-- File Icon -->
                        <div class="row-card-avatar" style="background: @iconBg; color: @iconColor;">
                            <i data-lucide="@iconName" style="width: 24px; height: 24px;"></i>
                        </div>
                        
                        <div class="row-card-info">
                            <span class="row-card-title">@doc.ApplicantName</span>
                            <span class="row-card-subtitle">Candidate Ref: @doc.ApplicantRef</span>
                        </div>

                        <!-- Document Type Badge -->
                        <div class="row-card-contact" style="width: 200px; border-right: none;">
                            <span class="status-pill @typeClass" style="font-size: 0.65rem;">@doc.Type</span>
                        </div>

                        <!-- Upload Date -->
                        <div class="row-card-meta" style="flex: 1; text-align: left; padding-left: 24px; border-left: 1px solid var(--a-line);">
                            <div class="toolbar-label" style="font-size: 0.6rem; margin-bottom: 4px; color: var(--a-muted);">Uploaded On</div>
                            <div class="fw-bold" style="font-size: 0.9rem; color: var(--a-ink);">@doc.Date.ToString("dd MMM yyyy")</div>
                        </div>

                        <!-- Narrative Actions -->
                        <div class="d-flex gap-2 ms-3">
                            <a href="@doc.Path" target="_blank" class="btn-review-pill" style="background: white; color: var(--a-primary); border: 1.5px solid var(--a-primary);">
                                <i data-lucide="eye" style="width: 16px; height: 16px;"></i> Preview
                            </a>
                            <a href="@doc.Path" download class="btn-review-pill">
                                <i data-lucide="download" style="width: 16px; height: 16px;"></i> Download
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // CLIENT-SIDE SEARCH & FILTER
        const searchInput = document.getElementById('docSearch');
        const typeFilter = document.getElementById('typeFilter');
        const cards = document.querySelectorAll('.doc-row-card-wrapper');

        function performFiltering() {
            const query = searchInput.value.toLowerCase();
            const typeValue = typeFilter.value.toLowerCase();

            cards.forEach(wrapper => {
                const card = wrapper.querySelector('.app-row-card');
                const name = card.querySelector('.row-card-title').innerText.toLowerCase();
                const type = card.querySelector('.status-pill').innerText.toLowerCase();

                const matchesSearch = name.includes(query);
                const matchesType = typeValue === "" || type.includes(typeValue);

                wrapper.style.display = (matchesSearch && matchesType) ? 'block' : 'none';
            });
        }

        searchInput.addEventListener('input', performFiltering);
        typeFilter.addEventListener('change', performFiltering);

        // INITIALIZE ICONS
        lucide.createIcons();
    </script>
}

<style>
    .pill-teal { background: #e6f6f6; color: #0ea5a5; }
    .doc-row-card-wrapper { transition: all 0.3s ease; }
</style>
