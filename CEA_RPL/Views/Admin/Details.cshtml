@model CEA_RPL.Domain.Entities.Applicant
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"Review Case #{Model.Id}";

    // HELPER FUNCTIONS FOR ADDRESS PARSING
    (string street, string city, string pincode) ParseAddress(string fullAddr) {
        if (string.IsNullOrEmpty(fullAddr)) return ("", "", "");
        
        // Match logic from formatStructuredAddress in Index.cshtml
        // Format: "Street, City - XYZ, Pincode - 123456"
        var pincodeMatch = System.Text.RegularExpressions.Regex.Match(fullAddr, @", Pincode - ([0-9]{6})$");
        var cityMatch = System.Text.RegularExpressions.Regex.Match(fullAddr, @", City - ([^,]+), Pincode - [0-9]{6}$");
        
        string street = fullAddr;
        string city = cityMatch.Success ? cityMatch.Groups[1].Value.Trim() : "";
        string pincode = pincodeMatch.Success ? pincodeMatch.Groups[1].Value.Trim() : "";
        
        if (cityMatch.Success) {
            street = fullAddr.Split(", City - ")[0];
        } else if (pincodeMatch.Success) {
            street = fullAddr.Split(", Pincode - ")[0];
        }
        
        return (street.Trim(), city, pincode);
    }
}

<div class="row g-4">
    <!-- LEFT PANE: CANDIDATE DATA (70%) -->
    <div class="col-xl-8">
        
        <!-- BACK ACTIONS -->
        <div class="mb-4 d-flex align-items-center gap-3">
            <a asp-action="Applications" class="btn btn-secondary btn-sm rounded-pill px-3 fw-bold">
                <i data-lucide="chevron-left" class="me-1" style="width: 14px;"></i> All Applications
            </a>
            <span class="status-badge @(Model.Status == "Approved" ? "st-approved" : (Model.Status == "Submitted" ? "st-submitted" : "st-review"))">
                @(Model.Status ?? "Under Review")
            </span>
        </div>

        <!-- STEP 1: APPLICANT DETAILS -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="user"></i> Step 1: Applicant Details
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-3">
                        <div class="bg-light rounded-4 border p-2 shadow-sm sticky-top" style="top: 100px;">
                            <img src="@(Model.PhotoPath ?? "https://via.placeholder.com/200x260?text=No+Photo")" alt="Candidate Photo" class="img-fluid rounded-3" style="width: 100%; aspect-ratio: 3/4; object-fit: cover;">
                            <div class="text-center mt-3 x-small fw-800 text-muted uppercase">Candidate Photograph</div>
                        </div>
                    </div>
                    <div class="col-md-9">
                        <div class="info-grid mb-5">
                            <div><label class="info-label">Title</label><div class="info-value">@Model.Title</div></div>
                            <div style="grid-column: span 2;"><label class="info-label">Candidate Name</label><div class="info-value fs-lg">@Model.FullName</div></div>
                            
                            <div><label class="info-label">Relation</label><div class="info-value">@Model.ParentRelation</div></div>
                            <div style="grid-column: span 2;"><label class="info-label">Parent / Guardian Name</label><div class="info-value">@Model.ParentName</div></div>
                            
                            <div><label class="info-label">Date of Birth</label><div class="info-value">@Model.DateOfBirth.ToString("dd MMM yyyy")</div></div>
                            <div><label class="info-label">Gender</label><div class="info-value">@Model.Gender</div></div>
                            <div><label class="info-label">Citizenship</label><div class="info-value">@Model.Citizenship</div></div>
                            
                            <div style="grid-column: span 2;"><label class="info-label">Email Address</label><div class="info-value text-primary">@Model.Email</div></div>
                            <div><label class="info-label">Mobile Number</label><div class="info-value">@Model.Mobile</div></div>
                            <div><label class="info-label">Alt Mobile</label><div class="info-value">@(Model.AlternateMobile ?? "-")</div></div>
                        </div>

                        <div class="border-top pt-4 mb-5">
                            <h6 class="fw-800 text-dark uppercase small mb-4">Address Details</h6>
                            @{
                                var perm = ParseAddress(Model.PermanentAddress);
                                var corr = ParseAddress(Model.CorrespondenceAddress ?? "");
                            }
                            <div class="info-grid mb-4">
                                <div style="grid-column: 1 / -1;"><label class="info-label">Permanent Address</label><div class="info-value">@perm.street</div></div>
                                <div><label class="info-label">City</label><div class="info-value">@(string.IsNullOrEmpty(perm.city) ? "Not Specified" : perm.city)</div></div>
                                <div><label class="info-label">Pincode</label><div class="info-value">@(string.IsNullOrEmpty(perm.pincode) ? "-" : perm.pincode)</div></div>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.CorrespondenceAddress)) {
                                <div class="info-grid mt-4">
                                    <div style="grid-column: 1 / -1;"><label class="info-label">Correspondence Address</label><div class="info-value">@corr.street</div></div>
                                    <div><label class="info-label">City</label><div class="info-value">@(string.IsNullOrEmpty(corr.city) ? "Not Specified" : corr.city)</div></div>
                                    <div><label class="info-label">Pincode</label><div class="info-value">@(string.IsNullOrEmpty(corr.pincode) ? "-" : corr.pincode)</div></div>
                                </div>
                            } else {
                                <div class="p-3 bg-light rounded-3 small fw-bold text-muted border border-dashed">Correspondence Address is same as Permanent</div>
                            }
                        </div>

                        <div class="border-top pt-4">
                            <label class="info-label">ID Verification (@Model.GovIdType)</label>
                            <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-4 border border-dashed">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary-light text-primary p-2 rounded-3"><i data-lucide="shield-check"></i></div>
                                    <span class="fw-800 text-dark fs-5">@Model.GovIdNumber</span>
                                </div>
                                <div class="d-flex gap-2">
                                    @if (!string.IsNullOrEmpty(Model.GovIdPath)) {
                                        <a href="@Model.GovIdPath" target="_blank" class="btn btn-secondary btn-sm px-4 rounded-pill fw-bold">View Document</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 2: CATEGORY OF CERTIFICATION APPLIED FOR -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="layers"></i> Step 2: Category of Certification Applied For
            </div>
            <div class="card-body p-4">
                <div class="d-flex flex-wrap gap-2">
                    @if (string.IsNullOrEmpty(Model.Categories)) {
                        <div class="no-data-msg">No categories selected</div>
                    } else {
                        @foreach (var cat in Model.Categories.Split(',', StringSplitOptions.RemoveEmptyEntries)) {
                            <div class="badge bg-primary-light text-primary border border-primary-subtle px-4 py-2 rounded-pill fw-800">@cat.Trim()</div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- STEP 3: EDUCATIONAL QUALIFICATIONS -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="graduation-cap"></i> Step 3: Educational Qualifications
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Degree</th>
                            <th>Course / Discipline</th>
                            <th>Institution / University</th>
                            <th>Year</th>
                            <th class="text-end">Proof</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Educations.Any()) {
                            <tr><td colspan="5" class="no-data-msg">No recorded educational qualifications</td></tr>
                        } else {
                            @foreach (var ed in Model.Educations) {
                                <tr>
                                    <td class="fw-bold text-dark">@ed.Degree</td>
                                    <td class="small fw-bold">@ed.Discipline</td>
                                    <td class="small fw-bold wrap-text">@ed.Institution</td>
                                    <td>@ed.Year</td>
                                    <td class="text-end">
                                        @if (!string.IsNullOrEmpty(ed.CertificatePath)) {
                                            <a href="@ed.CertificatePath" target="_blank" class="text-primary"><i data-lucide="external-link" style="width: 18px;"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 4: PROFESSIONAL EXPERIENCE -->
        <div class="modern-card mb-4">
            <div class="review-step-header justify-content-between">
                <div class="d-flex align-items-center gap-2"><i data-lucide="briefcase"></i> Step 4: Professional Experience</div>
                <div class="badge bg-emerald-subtle text-success px-3 py-2 rounded-pill fw-800">Total Experience: @(Model.ProfessionalExperiences.Any() ? Model.ProfessionalExperiences.Last().Applicant.CurrentStep == 15 ? "Verified" : "Under Calculation" : "N/A")</div>
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Organization</th>
                            <th>Designation / Proof</th>
                            <th>Duration</th>
                            <th>Role Description</th>
                            <th class="text-end">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ProfessionalExperiences.Any()) {
                            <tr><td colspan="5" class="no-data-msg">No professional experience records submitted</td></tr>
                        } else {
                            @foreach (var exp in Model.ProfessionalExperiences) {
                                <tr>
                                    <td class="fw-bold text-dark wrap-text">@exp.Organization</td>
                                    <td class="small fw-bold">
                                        @exp.Designation
                                        @if(!string.IsNullOrEmpty(exp.ProofPath)) {
                                            <div class="mt-1"><a href="@exp.ProofPath" target="_blank" class="text-primary x-small fw-800 uppercase">View Certificate</a></div>
                                        }
                                    </td>
                                    <td class="small fw-bold text-muted">@exp.Duration</td>
                                    <td class="small wrap-text text-muted">@exp.NatureOfWork</td>
                                    <td class="text-end text-success"><i data-lucide="check-circle" style="width: 16px;"></i></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 5: PROJECT EXPERIENCE -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="folder-kanban"></i> Step 5: Project Experience
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Project Name</th>
                            <th>Client / Location</th>
                            <th>Category</th>
                            <th>Role</th>
                            <th>Year</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ProjectExperiences.Any()) {
                            <tr><td colspan="5" class="no-data-msg">No project experience items submitted</td></tr>
                        } else {
                            @foreach (var p in Model.ProjectExperiences) {
                                <tr>
                                    <td class="fw-bold text-dark wrap-text">@p.Name</td>
                                    <td class="small fw-bold">@p.Client <br><span class="text-muted x-small">@p.Location</span></td>
                                    <td><span class="badge bg-light text-dark fw-800 border">@p.Category</span></td>
                                    <td class="small">@p.Role</td>
                                    <td class="fw-bold text-primary">@p.Year</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 6: UPLOAD REPORTS -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="clipboard-list"></i> Step 6: Upload Reports
            </div>
            <div class="file-item-list">
                @if (!Model.UploadReports.Any()) {
                    <div class="no-data-msg">No reports uploaded</div>
                } else {
                    @foreach (var rep in Model.UploadReports) {
                        <div class="file-item-row">
                            <div class="file-info">
                                <div class="file-icon"><i data-lucide="file-text"></i></div>
                                <div>
                                    <div class="file-name">@rep.FileName</div>
                                    <div class="file-meta">Technical Audit / Submission Report</div>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="@rep.FilePath" target="_blank" class="btn btn-secondary btn-sm px-4 rounded-pill fw-bold">View</a>
                                <a href="@rep.FilePath" download class="btn btn-outline-secondary btn-sm px-4 rounded-pill fw-bold">Download</a>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- STEP 7: DETAILS OF CERTIFICATION / TRAINING -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="award"></i> Step 7: Details of Certification / Training
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Certification / Course</th>
                            <th>Institution / Authority</th>
                            <th>Duration</th>
                            <th>Year</th>
                            <th class="text-end">Proof</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.CertificationTrainings.Any()) {
                            <tr><td colspan="5" class="no-data-msg">No certifications or training records</td></tr>
                        } else {
                            @foreach (var t in Model.CertificationTrainings) {
                                <tr>
                                    <td class="fw-bold text-dark wrap-text">@t.Name</td>
                                    <td class="small fw-bold">@t.ObtainedFrom</td>
                                    <td>@t.Duration</td>
                                    <td>@t.Year</td>
                                    <td class="text-end">
                                        @if (!string.IsNullOrEmpty(t.ProofPath)) {
                                            <a href="@t.ProofPath" target="_blank" class="text-primary"><i data-lucide="external-link" style="width: 18px;"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 8: MEMBERSHIP IN PROFESSIONAL BODIES -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="users-2"></i> Step 8: Membership in Professional Bodies
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Body Name</th>
                            <th>Organization / Source</th>
                            <th>Status / Duration</th>
                            <th>Year</th>
                            <th class="text-end">Proof</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Memberships.Any()) {
                            <tr><td colspan="5" class="no-data-msg">No professional memberships listed</td></tr>
                        } else {
                            @foreach (var m in Model.Memberships) {
                                <tr>
                                    <td class="fw-bold text-dark">@m.Name</td>
                                    <td class="small fw-bold">@m.ObtainedFrom</td>
                                    <td>@m.Duration</td>
                                    <td>@m.Year</td>
                                    <td class="text-end">
                                        @if (!string.IsNullOrEmpty(m.ProofPath)) {
                                            <a href="@m.ProofPath" target="_blank" class="text-primary"><i data-lucide="external-link" style="width: 18px;"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 9: PAPER PUBLISHED / PRESENTED -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="book-open"></i> Step 9: Paper Published / Presented
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Paper Title</th>
                            <th>Publisher / Journal</th>
                            <th>Role</th>
                            <th>Year</th>
                            <th class="text-end">Proof</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PaperPublisheds.Any()) {
                            <tr><td colspan="5" class="no-data-msg">No papers or publications submitted</td></tr>
                        } else {
                            @foreach (var p in Model.PaperPublisheds) {
                                <tr>
                                    <td class="fw-bold text-dark wrap-text">@p.Name</td>
                                    <td class="small fw-bold">@p.Place</td>
                                    <td><span class="badge bg-light text-muted fw-800">@p.Role</span></td>
                                    <td>@p.Year</td>
                                    <td class="text-end">
                                        @if (!string.IsNullOrEmpty(p.ProofPath)) {
                                            <a href="@p.ProofPath" target="_blank" class="text-primary"><i data-lucide="external-link" style="width: 18px;"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 10: AWARDS / RECOGNITION -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="star"></i> Step 10: Awards / Recognition
            </div>
            <div class="table-responsive">
                <table class="modern-table review-table">
                    <thead>
                        <tr>
                            <th>Award Name</th>
                            <th>Organization / Authority</th>
                            <th>Year</th>
                            <th class="text-end">Proof</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Awards.Any()) {
                            <tr><td colspan="4" class="no-data-msg">No awards or recognitions recorded</td></tr>
                        } else {
                            @foreach (var a in Model.Awards) {
                                <tr>
                                    <td class="fw-bold text-dark">@a.Name</td>
                                    <td class="small fw-bold">@a.ReceivedFrom</td>
                                    <td>@a.Year</td>
                                    <td class="text-end">
                                        @if (!string.IsNullOrEmpty(a.ProofPath)) {
                                            <a href="@a.ProofPath" target="_blank" class="text-primary"><i data-lucide="external-link" style="width: 18px;"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- STEP 11: SOFTWARE / TOOLS / APPLICATION SKILLS -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="cpu"></i> Step 11: Software / Tools / Application Skills
            </div>
            <div class="card-body p-4">
                <div class="d-flex flex-wrap gap-3">
                    @if (!Model.SoftwareSkills.Any()) {
                        <div class="no-data-msg w-100">No software skills listed</div>
                    } else {
                        @foreach (var s in Model.SoftwareSkills) {
                            <div class="p-3 bg-light rounded-4 border d-flex align-items-center gap-3" style="min-width: 200px;">
                                <div class="bg-white p-2 rounded-3 border"><i data-lucide="terminal" style="width:16px;"></i></div>
                                <div>
                                    <div class="fw-800 text-dark small">@s.SoftwareName</div>
                                    <div class="x-small text-muted uppercase fw-800">@s.ProficiencyLevel</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- STEP 12: OTHER RELEVANT ENCLOSURES -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="plus-square"></i> Step 12: Other Relevant Enclosures
            </div>
            <div class="card-body p-4">
                @if (!Model.OtherEnclosures.Any() && string.IsNullOrEmpty(Model.EnclosureDescription)) {
                    <div class="no-data-msg">No additional enclosures submitted</div>
                } else {
                    <div class="row g-4 align-items-center">
                        <div class="col-md-7">
                            <label class="info-label">Candidate Description</label>
                            <div class="p-3 bg-light rounded-3 small fw-bold text-muted border border-dashed">
                                @(string.IsNullOrEmpty(Model.EnclosureDescription) ? "No description provided." : Model.EnclosureDescription)
                            </div>
                        </div>
                        <div class="col-md-5">
                            @foreach (var enc in Model.OtherEnclosures) {
                                <div class="p-3 bg-white border rounded-4 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <i data-lucide="file" class="text-muted" style="width:18px;"></i>
                                        <span class="small fw-bold text-dark">@enc.FileName</span>
                                    </div>
                                    <a href="@enc.FilePath" target="_blank" class="btn btn-secondary btn-sm px-3 rounded-pill fw-bold">View</a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- STEP 13: PAYMENT DETAILS -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="indian-rupee"></i> Step 13: Payment Details
            </div>
            <div class="card-body p-4">
                <div class="row align-items-center g-4">
                    <div class="col-md-7">
                        @if (!Model.PaymentDetails.Any()) {
                            <div class="no-data-msg">No payment information available</div>
                        } else {
                            @foreach (var pay in Model.PaymentDetails) {
                                <div class="payment-utr-card">
                                    <div class="small fw-800 text-primary uppercase mb-1">Transaction Ref (UTR)</div>
                                    <div class="fs-4 fw-800 text-dark">@pay.UtrNumber</div>
                                    <div class="mt-3 d-flex justify-content-between align-items-center">
                                        <div class="text-dark small fw-bold">Amount: ₹ @pay.Amount.ToString("N0") &bull; @pay.PaymentDate.ToString("dd MMM yyyy")</div>
                                        @if (!string.IsNullOrEmpty(pay.ReceiptPath)) {
                                            <a href="@pay.ReceiptPath" target="_blank" class="btn btn-primary btn-sm px-4 rounded-pill fw-bold">View Receipt</a>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="col-md-5">
                        <div class="p-4 rounded-4 text-center @(Model.PaymentStatus == "Verified" ? "bg-emerald-subtle text-success" : "bg-warning-light text-warning")" 
                             style="border: 1px dashed @(Model.PaymentStatus == "Verified" ? "var(--st-success)" : "var(--st-warning)");">
                            <div class="small fw-800 text-muted uppercase mb-2">Finance Certification Status</div>
                            <div class="fs-4 fw-800">@(Model.PaymentStatus ?? "Pending Review")</div>
                            <div class="mt-2 x-small fw-800 uppercase text-muted">Authorized via Finance Portal</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 14: DECLARATION BY APPLICANT -->
        <div class="modern-card mb-4">
            <div class="review-step-header">
                <i data-lucide="check-square"></i> Step 14: Declaration by Applicant
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="p-4 bg-light rounded-4 border border-dashed" style="line-height: 1.8;">
                            <p class="mb-0 text-dark fw-bold italic small">
                                "I hereby declare that the information provided in this application is true and correct to the best of my knowledge and belief. I understand that in the event of any information being found false or incorrect, my candidature/certification is liable to be cancelled / terminated without any notice."
                            </p>
                        </div>
                        <div class="mt-4 row g-3">
                            <div class="col-6"><label class="info-label">Place of Declaration</label><div class="info-value">@(Model.Declaration?.Place ?? "-")</div></div>
                            <div class="col-6"><label class="info-label">Signed Date</label><div class="info-value">@(Model.Declaration?.Date.ToString("dd MMM yyyy") ?? "-")</div></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        @if (!string.IsNullOrEmpty(Model.Declaration?.SignaturePath)) {
                            <div class="text-center p-3 border rounded-4 bg-white shadow-sm">
                                <img src="@Model.Declaration.SignaturePath" alt="Signature" class="img-fluid" style="max-height: 80px; object-fit: contain;">
                                <div class="mt-3 border-top pt-2 fw-800 text-dark small">@Model.Declaration.Name</div>
                                <div class="x-small text-muted uppercase">Authorized Signature</div>
                            </div>
                        } else {
                            <div class="no-data-msg border rounded-4">No signature uploaded</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- STEP 15: REVIEW / SUBMISSION METADATA -->
        <div class="modern-card mb-5">
            <div class="review-step-header">
                <i data-lucide="history"></i> Step 15: Audit & Submission Metadata
            </div>
            <div class="card-body p-4">
                <div class="info-grid">
                    <div><label class="info-label">Submission IP</label><div class="info-value">@(Model.Status == "Submitted" || Model.Status == "UnderReview" ? "Logged and Verified" : "Awaiting Submission")</div></div>
                    <div><label class="info-label">System Timestamp</label><div class="info-value">@(Model.SubmittedAt?.ToString("dd MMM yyyy HH:mm:ss") ?? "Pending")</div></div>
                    <div><label class="info-label">Integrity Status</label><div class="info-value text-success"><i data-lucide="check" class="me-1"></i> Final Checklist Verified</div></div>
                </div>
            </div>
        </div>

    </div>

    <!-- RIGHT PANE: DECISION (30%) -->
    <div class="col-xl-4">
        <div class="sticky-top" style="top: 100px;">
            <div class="modern-card shadow-lg" style="border-width: 2px;">
                <div class="p-3 px-4 border-bottom bg-white fw-800 text-dark d-flex align-items-center gap-2">
                    <i data-lucide="verified" class="text-primary" style="width: 20px;"></i> Admin Decision Panel
                </div>
                <div class="card-body p-4">
                    <form id="reviewForm">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-4">
                            <label class="info-label mb-2">Application Disposition</label>
                            <select name="status" class="form-select fw-bold" style="border-radius: 12px; height: 50px; border: 2px solid var(--a-line);">
                                <option value="UnderReview" selected="@(Model.Status == "UnderReview")">Mark Under Review</option>
                                <option value="Approved" selected="@(Model.Status == "Approved")" disabled="@(Model.PaymentStatus != "Verified")">
                                    Approve Candidate @(Model.PaymentStatus != "Verified" ? "(Locked)" : "")
                                </option>
                                <option value="Rejected" selected="@(Model.Status == "Rejected")">Reject Application</option>
                                <option value="Feedback Pending" selected="@(Model.Status == "Feedback Pending")">Request Feedback</option>
                            </select>
                            @if(Model.PaymentStatus != "Verified") {
                                <div class="mt-3 p-3 rounded-4 bg-warning-light small fw-bold" style="border: 1px solid #fee2b3;">
                                    <i data-lucide="lock" class="me-1" style="width: 14px; vertical-align: middle;"></i> Higher-level approval is locked until Finance verifies payment in Step 13.
                                </div>
                            }
                        </div>

                        <div class="mb-4">
                            <label class="info-label mb-2">Administrative Remarks</label>
                            <textarea name="feedback" class="form-control" rows="8" placeholder="Enter findings or notes..." style="border-radius: 12px; border: 2px solid var(--a-line); font-size: 0.9rem; padding: 16px;">@Model.AdminFeedback</textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm">
                            Submit Final Adjudication
                        </button>
                    </form>
                    <div id="statusResult" class="mt-4 p-3 rounded-4 text-center fw-bold small" style="display: none;"></div>
                </div>
            </div>

            <!-- AUDIT METADATA -->
            <div class="modern-card mt-4 p-4 text-center">
                <div class="small fw-800 text-muted uppercase mb-3">System Identity Scan</div>
                <div class="bg-light p-3 rounded-4">
                    <div class="small fw-bold text-dark">Application Reference</div>
                    <div class="text-primary fw-800">REF-CEA-@Model.Id.ToString("D5")</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const reviewForm = document.getElementById('reviewForm');
        const statusResult = document.getElementById('statusResult');

        reviewForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            statusResult.style.display = 'block';
            statusResult.innerHTML = '<span class="text-muted">Communicating with server...</span>';
            const formData = new FormData(reviewForm);
            
            try {
                const response = await fetch('/api/admin/update-status', { method: 'POST', body: formData });
                const result = await response.json();
                
                if (response.ok) {
                    statusResult.innerHTML = result.message;
                    statusResult.className = "mt-4 p-3 rounded-4 text-center fw-bold small bg-emerald-subtle text-success";
                    setTimeout(() => window.location.href = '/Admin/Applications', 1500);
                } else {
                    statusResult.innerHTML = result.message;
                    statusResult.className = "mt-4 p-3 rounded-4 text-center fw-bold small bg-error-subtle text-danger";
                }
            } catch (err) {
                statusResult.innerHTML = 'Communication error.';
                statusResult.className = "mt-4 p-3 rounded-4 text-center fw-bold small bg-error-subtle text-danger";
            }
        });
        lucide.createIcons();
    </script>
}

<style>
    .bg-light { background: #f8fafc !important; }
    .bg-emerald-subtle { background: #ecfdf5 !important; }
    .bg-primary-light { background: var(--a-primary-light) !important; }
    .x-small { font-size: 0.7rem; }
</style>

