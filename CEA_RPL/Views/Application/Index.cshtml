@{ 
    Layout = null; 
    bool isSubmitted = ViewBag.ApplicationStatus != null && ViewBag.ApplicationStatus != "Draft";
    
    var displayName = ViewBag.UserName as string ?? "User";
    var initials = "";
    if (!string.IsNullOrEmpty(displayName))
    {
        var words = displayName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (words.Length >= 2) {
            initials = (words[0][0].ToString() + words[1][0].ToString()).ToUpper();
        } else if (words[0].Length >= 2) {
            initials = words[0].Substring(0, 2).ToUpper();
        } else {
            initials = words[0][0].ToString().ToUpper();
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CEA RPL Application – Modern Portal</title>
    <link rel="stylesheet" href="~/css/index.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="~/lib/face-api.js/face-api.min.js"></script>
    <script src="~/lib/tesseract.js/tesseract.min.js"></script>
    <script src="~/lib/pdfjs/pdf.min.js"></script>
</head>
<body>

<div id="toast-container"></div>

<!-- Sticky Header & Stepper Wrapper -->
<div class="header-wrapper">
    <header class="header-bar">
        <div class="header-left">
                <h3>Application form for CEA</h3>
        </div>
        <div class="header-right">
            @if (!isSubmitted)
            {
                <div class="draft-status" id="draftStatus">
                    <div class="status-dot"></div>
                    <span>Draft saved</span>
                </div>
            }
            <div class="profile" id="profileMenu">
                <div class="profile-trigger" id="profileTrigger">
                    <div class="profile-name">@(string.IsNullOrEmpty(displayName) ? "User" : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(displayName.ToLower()))</div>
                    <div class="profile-avatar">@initials</div>
                    <svg class="profile-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
                <div class="profile-dropdown" id="dropdownMenu">
                    <a href="javascript:void(0)" onclick="currentStep=1; updateUI();" class="dropdown-item">
                        <i data-lucide="user" style="width: 16px; height: 16px;"></i> Profile
                    </a>
                    <a href="/Auth/Logout" class="dropdown-item logout" id="logoutBtn">
                        <i data-lucide="log-out" style="width: 16px; height: 16px;"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    @if (!isSubmitted)
    {
        <!-- Main Phases (A-D) -->
        <div class="main-stepper" id="govStepper">
            <div class="step-item active" id="phase-A">
                <div class="step-icon">A</div>
                <div class="step-text">Personal & Identity</div>
            </div>
            <div class="step-line"></div>
            <div class="step-item" id="phase-B">
                <div class="step-icon">B</div>
                <div class="step-text">Qualifications</div>
            </div>
            <div class="step-line"></div>
            <div class="step-item" id="phase-C">
                <div class="step-icon">C</div>
                <div class="step-text">Experience & Projects</div>
            </div>
            <div class="step-line"></div>
            <div class="step-item" id="phase-D">
                <div class="step-icon">D</div>
                <div class="step-text">Documents & Preview</div>
            </div>
        </div>

        <!-- Sub Stepper (Dynamic) -->
        <div class="sub-stepper">
            <div class="step-circles" id="subStepCircles">
                <!-- Dynamically populated by JS -->
            </div>
            <div class="step-title" id="currentSubStepTitle">Applicant Details</div>
            <div class="step-meta" id="subStepMeta">
                Step <span id="currentStepDisplay">1</span> of 15
            </div>
        </div>
    }
</div>

<div class="form-wrapper @(isSubmitted ? "submitted-view" : "")">
    <!-- Sidebar Navigation -->
    @if (!isSubmitted)
    {
    <aside class="sidebar-nav hidden-sidebar" id="sidebarNav">
        <a href="#step-1" class="nav-item active" data-step="1"><span class="nav-num">01</span><span class="nav-text">Applicant Details</span></a>
        <a href="#step-2" class="nav-item locked" data-step="2"><span class="nav-num">02</span><span class="nav-text">Category of Certification Applied For</span></a>
        <a href="#step-3" class="nav-item locked" data-step="3"><span class="nav-num">03</span><span class="nav-text">Educational Qualifications</span></a>
        <a href="#step-4" class="nav-item locked" data-step="4"><span class="nav-num">04</span><span class="nav-text">Professional Experience</span></a>
        <a href="#step-5" class="nav-item locked" data-step="5"><span class="nav-num">05</span><span class="nav-text">Project Experience</span></a>
        <a href="#step-6" class="nav-item locked" data-step="6"><span class="nav-num">06</span><span class="nav-text">Upload Reports</span></a>
        <a href="#step-7" class="nav-item locked" data-step="7"><span class="nav-num">07</span><span class="nav-text">Details of Certification / Training</span></a>
        <a href="#step-8" class="nav-item locked" data-step="8"><span class="nav-num">08</span><span class="nav-text">Membership in Professional Bodies</span></a>
        <a href="#step-9" class="nav-item locked" data-step="9"><span class="nav-num">09</span><span class="nav-text">Paper Published / Presented</span></a>
        <a href="#step-10" class="nav-item locked" data-step="10"><span class="nav-num">10</span><span class="nav-text">Awards / Recognition</span></a>
        <a href="#step-11" class="nav-item locked" data-step="11"><span class="nav-num">11</span><span class="nav-text">Software / Tools / Application Skills</span></a>
        <a href="#step-12" class="nav-item locked" data-step="12"><span class="nav-num">12</span><span class="nav-text">Other Relevant Enclosures</span></a>
        <a href="#step-13" class="nav-item locked" data-step="13"><span class="nav-num">13</span><span class="nav-text">Payment Details</span></a>
        <a href="#step-14" class="nav-item locked" data-step="14"><span class="nav-num">14</span><span class="nav-text">Declaration by Applicant</span></a>
        <a href="#step-15" class="nav-item locked" data-step="15"><span class="nav-num">15</span><span class="nav-text">Preview & Submit</span></a>
    </aside>
    }

    <!-- Main Content -->
    <main class="form-content">
        @if (ViewBag.ApplicationStatus != null && ViewBag.ApplicationStatus != "Draft")
        {
            var status = ViewBag.ApplicationStatus;
            var feedback = ViewBag.AdminFeedback;
            var statusColor = status switch {
                "Approved" => "#10b981",
                "Rejected" => "#ef4444",
                "Submitted" => "#f59e0b",
                "UnderReview" => "#0ea5a5",
                "Feedback Pending" => "#f59e0b",
                _ => "#64748b"
            };
            
            <div class="status-banner" style="background: white; border-radius: 16px; padding: 24px; margin-bottom: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-left: 6px solid @statusColor;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <h4 style="margin: 0; color: #333; font-weight: 700;">Application Status: <span style="color: @statusColor;">@status</span></h4>
                    <span class="badge" style="background: @statusColor; color: white; padding: 6px 16px; border-radius: 100px; font-size: 0.8rem; font-weight: 700;">LIVE</span>
                </div>
                
                @if (status == "Feedback Pending" && !string.IsNullOrEmpty(feedback))
                {
                    <div style="background: #fff8e1; border: 1px solid #ffecb3; border-radius: 12px; padding: 16px; margin-top: 15px;">
                        <strong style="color: #856404; display: block; margin-bottom: 5px;">Action Required: Admin Feedback</strong>
                        <p style="margin: 0; color: #856404; font-size: 0.95rem;">@feedback</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(feedback))
                {
                    <p style="margin: 10px 0 0; color: #666; font-size: 0.9rem;"><strong>Admin Remarks:</strong> @feedback</p>
                }
                
                <p style="margin: 15px 0 0; color: #888; font-size: 0.85rem;">
                    @if (status == "Submitted") { <span>Your application was submitted on <strong>@ViewBag.LastSavedAt</strong> and is in queue for review.</span> }
                    else if (status == "UnderReview") { <span>Your document verification is currently in progress. This usually takes 3-5 working days.</span> }
                    else if (status == "Approved") { <span>Congratulations! Your application has been approved. You can now download your digital certificate.</span> }
                </p>
            </div>
        }
        
        @if (isSubmitted)
        {
            <div id="submittedDashboard" class="dash-layout">
                <!-- SaaS HERO BANNER -->
                <div class="dash-hero-banner">
                    <div class="hero-text">
                        <p>Welcome back, @ViewBag.UserName</p>
                        <h1>Your Application is Submitted! 🎉</h1>
                        <p>Reference: <strong>@ViewBag.AppId</strong> • Filed on @(ViewBag.SubmittedAt ?? "Recently")</p>
                    </div>
                    <div class="status-badge-lg">
                        <div class="pulse-dot"></div>
                        @ViewBag.ApplicationStatus (LIVE)
                    </div>
                </div>

                <div class="dash-main-grid">
                    <!-- LEFT COLUMN (Main Content) -->
                    <div style="display: flex; flex-direction: column; gap: 32px;">
                        
                        <!-- UPDATED HORIZONTAL TIMELINE -->
                        <div class="dash-card">
                            <div class="card-header">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Submission Progress
                            </div>
                            <div class="timeline-container">
                                <div class="timeline-node completed">
                                    <div class="node-circle">✓</div>
                                    <div class="node-label">Submitted</div>
                                </div>
                                <div class="timeline-node active">
                                    <div class="node-circle">2</div>
                                    <div class="node-label">Under<br>Review</div>
                                </div>
                                <div class="timeline-node">
                                    <div class="node-circle">3</div>
                                    <div class="node-label">Auditor<br>Assigned</div>
                                </div>
                                <div class="timeline-node">
                                    <div class="node-circle">4</div>
                                    <div class="node-label">Final<br>Decision</div>
                                </div>
                            </div>
                        </div>

                        <!-- NEXT STEPS (STEP CARDS) -->
                        <div class="dash-card">
                            <div class="card-header">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 16 16 12 12 8"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                                What happens next?
                            </div>
                            <div class="next-steps-grid">
                                <div class="step-card">
                                    <div class="step-number">01</div>
                                    <div class="step-info">
                                        <h4>Application Quality Check</h4>
                                        <p>Our internal secretariat verifies your documents for technical completeness and accuracy.</p>
                                    </div>
                                </div>
                                <div class="step-card">
                                    <div class="step-number">02</div>
                                    <div class="step-info">
                                        <h4>Evidence Validation</h4>
                                        <p>Expert auditors evaluate your professional experience and training credentials against standard benchmarks.</p>
                                    </div>
                                </div>
                                <div class="step-card">
                                    <div class="step-number">03</div>
                                    <div class="step-info">
                                        <h4>Final Notification</h4>
                                        <p>Once the audit cycle is complete, you will receive your certification notification via email and your student portal.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- RIGHT COLUMN (Side Panel) -->
                    <div style="display: flex; flex-direction: column; gap: 32px;">
                        
                        <!-- QUICK ACTIONS -->
                        <div class="dash-card">
                            <div class="card-header">Actions</div>
                            <div class="action-stack">
                                <button class="btn-saas" onclick="document.getElementById('readOnlySummary').scrollIntoView({behavior: 'smooth'})">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:#0E5A3C;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    View Full Application
                                </button>
                                <button class="btn-saas" style="opacity: 0.6; cursor: not-allowed;" title="Service currently merging">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:#0E5A3C;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                    Download PDF
                                </button>
                                <button class="btn-saas" onclick="window.print()">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:#0E5A3C;"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                                    Print Application
                                </button>
                            </div>
                        </div>

                        <!-- APPLICATION SUMMARY -->
                        <div class="dash-card">
                            <div class="card-header">Application Info</div>
                            <div class="stats-list">
                                <div class="stat-item">
                                    <span class="stat-label">Reference ID</span>
                                    <span class="stat-value">@ViewBag.AppId</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Applied Category</span>
                                    <span class="stat-value">@ViewBag.AppliedCategories</span>
                                </div>
                                <div class="stat-item" style="border-left: 4px solid #4ade80;">
                                    <span class="stat-label">Application Fee</span>
                                    <span class="stat-value" style="color: #059669;">Verified (₹@((ViewBag.TotalAmount ?? 0).ToString("N0")))</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-label">Doc Inventory</span>
                                    <span class="stat-value">@ViewBag.DocCount Verified Files</span>
                                </div>
                            </div>
                        </div>

                        <!-- HELP CARD -->
                        <div class="dash-card" style="background: #f8fafb; border: 1px dashed var(--line);">
                            <h4 style="font-size: 1rem; margin-bottom: 12px; font-weight: 800;">Need Assistance?</h4>
                            <p style="font-size: 0.85rem; color: var(--muted); margin-bottom: 20px; line-height: 1.5;">Our support desk is available 24/7 for technical queries regarding your RPL application.</p>
                            <a href="mailto:support@cearpl.org" class="btn btn-primary" style="width: 100%; text-align: center; border-radius: 12px; padding: 12px;">Contact Secretariat</a>
                        </div>

                    </div>
                </div>

                <!-- FULL RECORD SECTION (Scroll target) -->
                <div id="readOnlySummary" class="review-grid" style="margin-top: 60px; padding-top: 60px; border-top: 2px solid var(--bg);">
                    <div class="card-header" style="font-size: 1.6rem; margin-bottom: 40px;">Detailed Submission Record</div>
                    <!-- Populated by JS -->
                </div>
            </div>
        }

        @if (!isSubmitted)
        {
        <form id="applicationForm" novalidate>
            @Html.AntiForgeryToken()
            
            <!-- STEP 1: APPLICANT DETAILS -->
            <div class="form-section active" id="step-1" style="background: transparent; border: none; box-shadow: none; padding: 0; margin-top: 0;">
                <div style="margin-bottom: 20px;">
                    <h2 style="font-size: 1.6rem; font-weight: 800; color: #1e293b; margin: 0 0 6px 0;">Applicant Details</h2>
                    <p style="color: #64748b; margin: 0; font-size: 0.9rem;">Fill in your personal information exactly as it appears on your government-issued identity proof.</p>
                </div>
                
                <div class="section-content" style="padding: 0;">
                    
                    <!-- CARD A: CANDIDATE PHOTOGRAPH -->
                    <div class="form-card">
                        <div class="form-card-header">
                            <div class="form-card-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                            </div>
                            <div>
                                <h3 class="form-card-title">Candidate Photograph</h3>
                                <div class="form-card-subtitle">Recent passport-size photo · JPG, PNG 500KB</div>
                            </div>
                        </div>
                        <div class="photo-section">
                            <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
                                <div class="profile-preview-box">
                                    <svg class="preview-placeholder-icon" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                    </svg>
                                    <img id="profilePreviewImage" src="" alt="Profile Preview" style="display: none; width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                                <span style="font-size: 0.7rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">PROFILE PREVIEW</span>
                            </div>

                            <input type="file" id="candidatePhotoInput" name="applicant_photo" accept=".jpg,.jpeg,.png" style="display:none;" onchange="validateFileUpload(this)" />

                            <div id="candidatePhotoUploadBox" class="compact-upload">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="compact-icon"><path d="M16 5h6"/><path d="M19 2v6"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                                <div class="compact-text">
                                    <div class="upload-title">Upload Candidate Photograph</div>
                                    <div class="upload-subtitle" id="uploadSubtitle">Click to browse image</div>
                                </div>
                                
                                <div class="photo-action-buttons" id="photoActions" style="display: none; position: relative; z-index: 20;">
                                    <button type="button" class="btn btn-primary" style="padding: 8px 16px; font-size: 0.85rem;" onclick="document.getElementById('candidatePhotoInput').click()">Change</button>
                                    <button type="button" class="btn btn-ghost" style="padding: 8px 16px; font-size: 0.85rem; color: var(--warn);" onclick="removePhoto()">Remove</button>
                                </div>
                            </div>
                        </div>
                        <div id="photoError" class="error-msg" style="display: none; margin-top: 16px; text-align: center;"></div>
                        </div>

                    <!-- CARD B: PERSONAL DETAILS -->
                    <div class="form-card">
                        <div class="form-card-header">
                            <div class="form-card-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            </div>
                            <div>
                                <h3 class="form-card-title">Personal Details</h3>
                                <div class="form-card-subtitle">All fields marked * are mandatory</div>
                            </div>
                        </div>

                        <div class="personal-details-form">
                            <!-- Row 1 -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Select Salutation <span class="req">*</span></label>
                                        <select name="title" required>
                                            <option value="">Select</option>
                                            <option>Mr.</option>
                                            <option>Mrs.</option>
                                            <option>Ms.</option>
                                            <option>Dr.</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group candidate-name">
                                        <label>Candidate Name <span class="req">*</span></label>
                                        <input name="full_name" type="text" required placeholder="Enter full name" value="@ViewBag.UserName" />
                                    </div>
                                </div>
                            </div>

                            <!-- Row 2 -->
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Select Salutation</label>
                                        <select name="parent_title">
                                            <option value="">Select</option>
                                            <option>Mr.</option>
                                            <option>Mrs.</option>
                                            <option>Dr.</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Parent / Guardian Name <span class="req">*</span></label>
                                        <input name="parent_name" type="text" required placeholder="Father/Mother/Guardian name" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Parent / Guardian Relation <span class="req">*</span></label>
                                        <select name="parent_relation" required>
                                            <option value="">Select Relation</option>
                                            <option>Father</option>
                                            <option>Mother</option>
                                            <option>Guardian</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Row 3 -->
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Email ID <span class="req">*</span></label>
                                        <input name="email" type="email" required value="@ViewBag.UserEmail" readonly class="prefilled-readonly" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Mobile Number (OTP Verification) <span class="req">*</span></label>
                                        <input name="mobile" id="mobile" type="tel" required value="@ViewBag.UserMobile" readonly class="prefilled-readonly" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Alternative Mobile Number</label>
                                        <input name="alt_mobile" type="tel" placeholder="10-digit mobile number" maxlength="10" oninput="this.value=this.value.replace(/[^0-9]/g,'');" />
                                    </div>
                                </div>
                            </div>

                            <!-- Row 4: DEMOGRAPHICS SECTION -->
                            <div class="form-card-group-title">Demographics</div>
                            
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Date of Birth <span class="req">*</span></label>
                                        <input id="dob" name="dob" type="date" required onchange="updateAgeEligibility()" />
                                        <div id="ageEligibilityFeedback" class="eligibility-feedback hide"></div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>Gender <span class="req">*</span></label>
                                        <select name="gender" required>
                                            <option value="">Select</option>
                                            <option>Male</option>
                                            <option>Female</option>
                                            <option>Other</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
