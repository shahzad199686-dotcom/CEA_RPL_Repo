}

/* Document Requirement Popup Modal Styles */
#docReqModal {
    z-index: 3000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}
#docReqModal.active {
    opacity: 1;
    visibility: visible;
}
.doc-modal {
    background: white;
    width: 100%;
    max-width: 600px;
    border-radius: 24px;
    padding: 40px;
    position: relative;
    box-shadow: 0 30px 60px rgba(0,0,0,0.15);
    transform: scale(0.9);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
#docReqModal.active .doc-modal { transform: scale(1); }

.modal-close-icon {
    position: absolute; top: 20px; right: 20px;
    background: none; border: none; font-size: 2rem;
    color: var(--muted); cursor: pointer; line-height: 1;
}

.modal-header { text-align: center; margin-bottom: 30px; }
.modal-icon-wrap { 
    width: 64px; height: 64px; background: var(--bg); color: var(--accent);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
}
.modal-header h2 { font-size: 1.5rem; color: var(--ink); margin-bottom: 12px; }
.modal-header p { color: var(--muted); font-size: 0.95rem; line-height: 1.5; margin: 0; }

.modal-scroll-area { max-height: 400px; overflow-y: auto; margin-bottom: 30px; padding-right: 10px; }
.checklist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
.check-item { display: flex; align-items: center; gap: 10px; font-size: 0.9rem; font-weight: 500; color: var(--ink); }
.check-box { 
    width: 20px; height: 20px; background: var(--accent-light); color: var(--accent);
    border-radius: 4px; display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 800; flex-shrink: 0;
}

.time-info-card {
    background: #fff8e1; border: 1px solid #ffecb3; border-radius: 12px;
    padding: 16px 20px; display: flex; gap: 15px; align-items: center;
    color: #856404;
}

.modal-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: 24px; border-top: 1px solid var(--line);
}
.noshow-label { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: var(--muted); cursor: pointer; }
.modal-btns { display: flex; gap: 12px; }

@@media (max-width: 640px) {
    .doc-modal { border-radius: 0; height: 100vh; max-width: 100%; padding: 30px 20px; overflow-y: auto; }
    .checklist-grid { grid-template-columns: 1fr; }
    .modal-footer { flex-direction: column; gap: 20px; align-items: flex-start; }
    .modal-btns { width: 100%; flex-direction: column; }
    .modal-btns .btn { width: 100%; }
}
</style>

<!-- Success Confirmation Modal (Submission) -->
<div class="modal-overlay" id="successModal">
    <div class="success-modal">
        <div class="success-icon">✓</div>
        <h2>Application Submitted!</h2>
        <p>Your application has been successfully submitted and is now under review. You will receive an email notification regarding the next steps.</p>
        <button class="btn-success-modal" onclick="window.location.href='/'">Go to Dashboard</button>
    </div>
</div>

<!-- Document Requirement Popup Modal (Post-Login) -->
