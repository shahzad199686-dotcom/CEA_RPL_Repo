                            targetRow.querySelector('[name="training_year[]"]').value = t.year || "";
                            if (t.hasFile) {
                                const fileInp = targetRow.querySelector('input[type="file"]');
                                if (fileInp) {
                                    fileInp.setAttribute('data-has-file', 'true');
                                    if (t.fileUrl) fileInp.setAttribute('data-file-url', t.fileUrl);
                                    refreshFileUI(fileInp);
                                }
                            }
                        }
                    });
                }
            });

            safeRestore('Memberships', () => {
                if (draftData.memberships && draftData.memberships.length > 0) {
                    const tbody = document.querySelector('#membershipTable tbody');
                    if (tbody) {
                        while (tbody.children.length < draftData.memberships.length) addGenericRow('membershipTable');
                        const rows = tbody.children;
                        draftData.memberships.forEach((m, i) => {
                            const row = rows[i];
                            if (row) {
                                row.querySelector('[name="membership_name[]"]').value = m.name || "";
                                row.querySelector('[name="membership_from[]"]').value = m.from || "";
                                row.querySelector('[name="membership_year[]"]').value = m.year || "";
                                row.querySelector('[name="membership_duration[]"]').value = m.duration || "";
                                if (m.hasFile) {
                                    const fileInp = row.querySelector('input[type="file"]');
                                    if (fileInp) {
                                        fileInp.setAttribute('data-has-file', 'true');
                                        if (m.fileUrl) fileInp.setAttribute('data-file-url', m.fileUrl);
                                        refreshFileUI(fileInp);
                                    }
                                }
                            }
                        });
                    }
                }
            });

            safeRestore('Papers', () => {
                if (draftData.papers && draftData.papers.length > 0) {
                    const tbody = document.querySelector('#publicationTable tbody');
                    if (tbody) {
                        while (tbody.querySelectorAll('tr').length < draftData.papers.length) addGenericRow('publicationTable');
                        const rows = tbody.querySelectorAll('tr');
                        draftData.papers.forEach((p, i) => {
                            const row = rows[i];
                            if (row) {
                                row.querySelector('[name="paper_name[]"]').value = p.name || "";
                                row.querySelector('[name="paper_place[]"]').value = p.place || "";
                                row.querySelector('[name="paper_year[]"]').value = p.year || "";
                                row.querySelector('[name="paper_role[]"]').value = p.role || "";
                                if (p.hasFile) {
                                    const fileInp = row.querySelector('input[type="file"]');
                                    if (fileInp) {
                                        fileInp.setAttribute('data-has-file', 'true');
                                        if (p.fileUrl) fileInp.setAttribute('data-file-url', p.fileUrl);
                                        refreshFileUI(fileInp);
                                    }
                                }
                            }
                        });
                    }
                }
            });

            safeRestore('Awards', () => {
                 if (draftData.awards && draftData.awards.length > 0) {
                    const tbody = document.querySelector('#awardTable tbody');
                    if (tbody) {
                        while (tbody.querySelectorAll('tr').length < draftData.awards.length) addGenericRow('awardTable');
                        const rows = tbody.querySelectorAll('tr');
                        draftData.awards.forEach((a, i) => {
                            const row = rows[i];
                            if (row) {
                                row.querySelector('[name="award_name[]"]').value = a.name || "";
                                row.querySelector('[name="award_from[]"]').value = a.from || "";
                                row.querySelector('[name="award_year[]"]').value = a.year || "";
                                if (a.hasFile) {
                                    const fileInp = row.querySelector('input[type="file"]');
                                    if (fileInp) {
                                        fileInp.setAttribute('data-has-file', 'true');
                                        if (a.fileUrl) fileInp.setAttribute('data-file-url', a.fileUrl);
                                        refreshFileUI(fileInp);
                                    }
                                }
                            }
                        });
                    }
                }
            });

            safeRestore('Software Skills', () => {
                if (draftData.software_skills && draftData.software_skills.length > 0) {
                    const tbody = document.querySelector('#softwareTable tbody');
                    if (tbody) {
                        while (tbody.querySelectorAll('tr').length < draftData.software_skills.length) addGenericRow('softwareTable');
                        const rows = tbody.querySelectorAll('tr');
                        draftData.software_skills.forEach((skill, i) => {
                            const row = rows[i];
                            if (row) {
                                row.querySelector('[name="software_skill[]"]').value = skill.skill || "";
                                row.querySelector('[name="proficiency_level[]"]').value = skill.level || "";
                            }
                        });
                    }
                }
            });

            safeRestore('Payment', () => {
                if (draftData.payment) {
                    setVal('payment_amount', draftData.payment.amount);
                    setVal('payment_date', draftData.payment.date);
                    setVal('payment_utr', draftData.payment.utr);
                    if (typeof calculateTotalFee === 'function') calculateTotalFee();
                    
                    const payRecInp = document.querySelector('[name="payment_receipt"]');
                    if (draftData.hasPaymentReceipt && payRecInp) {
                        payRecInp.setAttribute('data-has-file', 'true');
                        if (draftData.paymentReceiptUrl) payRecInp.setAttribute('data-file-url', draftData.paymentReceiptUrl);
                        refreshFileUI(payRecInp);
                    }
                }
            });

            safeRestore('Declaration', () => {
                if (draftData.declaration) {
                    setVal('decl_name', draftData.declaration.name);
                    setVal('decl_place', draftData.declaration.place);
                    if (draftData.declaration.isRetiredGovtEmployee !== null) {
                        const retiredVal = draftData.declaration.isRetiredGovtEmployee ? 'Yes' : 'No';
                        const retiredRadio = document.querySelector(`input[name="decl_retired_gov"][value="${retiredVal}"]`);
                        if (retiredRadio) {
                            retiredRadio.checked = true;
                            retiredRadio.dispatchEvent(new Event('change')); // Trigger auto-select logic
                        }
                    }
                    const sigInp = document.querySelector('[name="signature_file"]');
                    if (draftData.declaration.hasFile && sigInp) {
                        sigInp.setAttribute('data-has-file', 'true');
                        if (draftData.declaration.fileUrl) sigInp.setAttribute('data-file-url', draftData.declaration.fileUrl);
                        refreshFileUI(sigInp);
                    }
                }
            });

        } catch(e) {
            console.error('Critical error during resume:', e);
            showToast("Resume encountered errors, but some data may have been restored.", "error");
        } finally {
            const overlay = document.getElementById('resumeOverlay');
            if (overlay) overlay.classList.add('hide');
            btn.disabled = false;
            btn.textContent = oldText;
            try {
                updateUI();
                showToast("Application restored from draft.", "success");
            } catch(uiError) { console.error('UI Update failed after resume:', uiError); }
        }
    }

    function startNew() {
        if (confirm("Are you sure you want to start a new application? This will discard your current draft.")) {
            document.getElementById('resumeOverlay').classList.add('hide');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const isSubmitted = @(isSubmitted ? "true" : "false");
        
        if (isSubmitted) {
            // Submitted Mode: Fetch data and show read-only summary
            fetch('/get-draft')
                .then(r => r.json())
                .then(data => {
                    restoreDraft(data); // Fill the form (hidden)
                    populateReviewSummary(true); // Populate summary in read-only mode
                    
                    // Final tweak: If on dashboard, show progress as 100%
                    document.getElementById('progressBarFill').style.width = '100%';
                });
        } else {
            // Draft Mode: Normal behavior
            checkDraftOnLoad();
            
            // Attach auto-save to all inputs
            const form = document.getElementById('applicationForm');
            if (form) {
                form.addEventListener('input', (e) => {
                    autoSave();
                    // Real-time validation: If field has an error, re-validate immediately
                    const target = e.target;
                    
                    // Trigger address sync if checkbox is checked
                    const sameAddrCheck = document.getElementById('sameAddress');
                    if (sameAddrCheck && sameAddrCheck.checked) {
                        if (target.id === 'address_perm' || target.id === 'city_perm' || target.id === 'pincode_perm') {
                            syncAddress();
                        }
                    }

                    if (target.classList.contains('field-invalid') || target.closest('.form-section')?.querySelector('.error-guidance')) {
                        validateField(target);
                        
                        // Handle interdependent address fields
                        if (target.id.includes('city_') || target.id.includes('pincode_')) {
                            const prefix = target.id.includes('perm') ? 'perm' : 'corr';
                            const addr = document.getElementById(`address_${prefix}`);
                            if (addr) validateField(addr);
                        }
                    }
                });
                form.addEventListener('change', (e) => {
                    autoSave();
                    // For selects and files, always re-validate on change
                    validateField(e.target);
                    
                    if (e.target.id && e.target.id.includes('city_')) {
                        const prefix = e.target.id.includes('perm') ? 'perm' : 'corr';
                        const addr = document.getElementById(`address_${prefix}`);
                        if (addr) validateField(addr);
                    }
                });
            }

            // Bind Final Submit
            const finalBtn = document.getElementById('submitFinalApplicationBtn');
            if (finalBtn) finalBtn.onclick = submitFinalApplication;
        }
    });

    async function submitFinalApplication() {
        // 1. Mandatory Step Validation
        for(let i=1; i<totalSteps; i++) {
            if(!validateSection(i)) {
                currentStep = i;
                updateUI();
                showToast(`Step ${i} has incomplete or invalid fields.`, "error");
                return;
            }
        }

        // 2. Checklist confirmation check (Step 15)
        const mandatoryCbs = document.querySelectorAll('.mandatory-cb');
        let checklistValid = true;
        mandatoryCbs.forEach(cb => {
            if (!cb.checked) {
                checklistValid = false;
                cb.parentElement.style.color = '#c53030';
            } else {
                cb.parentElement.style.color = '';
            }
        });

        if (!checklistValid) {
            showToast("Please confirm all mandatory documents in the checklist (Step 15).", "error");
            document.getElementById('checklistError').style.display = 'block';
            return;
        }

        if (!confirm("Are you sure you want to submit your application? No further changes can be made.")) {
             return;
        }

        const btn = document.getElementById('submitFinalApplicationBtn');
        const oldText = btn.textContent;
        btn.disabled = true;
        btn.innerHTML = '<span class="pulse-dot"></span> Submitting...';

        try {
            const form = document.getElementById('applicationForm');
            
            // Prepare structured address strings
            const permAddr = document.getElementById('address_perm');
            const corrAddr = document.getElementById('address_corr');
            const oldPermVal = permAddr.value;
            const oldCorrVal = corrAddr.value;

            permAddr.value = formatStructuredAddress(oldPermVal, document.getElementById('city_perm').value, document.getElementById('pincode_perm').value);
            corrAddr.value = formatStructuredAddress(oldCorrVal, document.getElementById('city_corr').value, document.getElementById('pincode_corr').value);

            const formData = new FormData(form);
            
            // Restore UI values
            permAddr.value = oldPermVal;
            corrAddr.value = oldCorrVal;
            
            // Use real values for masked fields
            if (originalIdValue) formData.set('gov_id_number', originalIdValue);
            else {
                const realGovId = document.getElementById('govIdNumber')?.value;
                if (realGovId) formData.set('gov_id_number', realGovId);
            }
            
            if (originalMobile) formData.set('mobile', originalMobile);

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            const response = await fetch('/Application/Submit', {
                method: 'POST',
                headers: { 'X-CSRF-TOKEN': token },
                body: formData
            });

            const result = await response.json();

            if (response.ok) {
                showToast(result.message, "success");
                const overlay = document.getElementById('successOverlay');
                if (overlay) {
                    overlay.style.display = 'flex';
                    overlay.classList.add('active');
                }
                setTimeout(() => window.location.href = "/Application/Index", 3000);
            } else {
                btn.disabled = false;
                btn.textContent = oldText;
                handleServerValidation(result.message);
            }
        } catch (error) {
            console.error('Submission error:', error);
            showToast("An unexpected error occurred. Please try again.", "error");
            btn.disabled = false;
            btn.textContent = oldText;
        }
    }

    function validateChecklistState() {
        const mandatoryCbs = document.querySelectorAll('.mandatory-cb');
        const submitBtn = document.getElementById('submitFinalApplicationBtn');
        const errorMsg = document.getElementById('checklistError');
        
        const allChecked = Array.from(mandatoryCbs).every(cb => cb.checked);
        
        if (submitBtn) {
            submitBtn.disabled = !allChecked;
            submitBtn.style.opacity = allChecked ? '1' : '0.6';
            submitBtn.style.cursor = allChecked ? 'pointer' : 'not-allowed';
        }
        
        if (errorMsg) {
            errorMsg.style.display = allChecked ? 'none' : 'block';
        }
    }

    function populateReviewSummary(isReadOnly = false) {
        const summary = document.getElementById(isReadOnly ? 'readOnlySummary' : 'reviewSummary');
        if (!summary) return;

        const toTitleCase = (str) => {
            if (!str || str === 'Not provided') return str;
            return str.toLowerCase().split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
        };

        const getData = (name) => {
            let val = document.querySelector(`[name="${name}"]`)?.value || 'Not provided';
            if (['full_name', 'parent_name', 'decl_name'].includes(name)) return toTitleCase(val);
            return val;
        };
        const getCheckboxes = (name) => {
            const vals = Array.from(document.querySelectorAll(`input[name="${name}"]:checked`)).map(i => i.value);
            if (vals.length === 0) return '<span style="color: var(--warn); font-size: 0.85rem;">Not Provided</span>';
            return vals.map(v => `<span style="display: inline-block; padding: 2px 8px; background: #f0f9ff; color: #0369a1; border-radius: 4px; font-size: 0.75rem; margin-right: 4px; border: 1px solid #bae6fd;">${v}</span>`).join('');
        };

        const getMultiValues = (name) => {
            const vals = Array.from(document.querySelectorAll(`input[name="${name}"]`))
                              .map(i => i.value)
                              .filter(v => v && v.trim() !== '');
