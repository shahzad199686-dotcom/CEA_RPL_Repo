                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#856404" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                    <strong>Estimated Time: 20–30 Minutes</strong>
                    <p style="margin: 4px 0 0; color: #856404; font-size: 0.85rem;">Keep all documents ready for smooth submission</p>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <label class="noshow-label">
                <input type="checkbox" id="chkHideForever"> Do not show this again
            </label>
            <div class="modal-btns">
                <button class="btn btn-ghost" onclick="closeDocModal()">Close</button>
                <button class="btn btn-primary" onclick="closeDocModal()">Continue to Application</button>
            </div>
        </div>
    </div>
</div>

</body>
