            <!-- STEP 14: DECLARATION -->
            <div class="form-section hide" id="step-14">
                <div class="section-header"><h2>Step 14: Declaration by Applicant</h2></div>
                <div class="section-content">
                    <div class="retired-gov-question" style="margin-bottom: 24px; padding: 20px; background: #fff; border-radius: 12px; border: 1px solid var(--border);">
