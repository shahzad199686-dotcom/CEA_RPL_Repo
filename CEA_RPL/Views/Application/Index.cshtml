        ].map(s => ({ label: s, value: s })),
        subjectSelect: [
            { label: "Land Use", desc: "Land use planning, GIS mapping, and environmental impact analysis" },
            { label: "Air Pollution Monitoring, Prevention & Control", desc: "Air quality monitoring, emissions assessment, and pollution control systems" },
            { label: "Meteorology, Air Quality Modelling & Prediction", desc: "Meteorological data analysis, dispersion modelling, and impact prediction" },
            { label: "Water Pollution Monitoring, Prevention & Control", desc: "Water quality, wastewater treatment, and pollution prevention" },
            { label: "Ecology & Biodiversity", desc: "Ecological surveys, biodiversity assessment, and habitat impact analysis" },
            { label: "Noise & Vibration", desc: "Monitoring and mitigation of industrial noise and vibrations" },
            { label: "Socio-Economic Aspects", desc: "Social impact assessment, displacement, and community development" },
            { label: "Hydrology, Ground Water & Water Conservation", desc: "Ground water assessment, water balance, and recharge strategies" },
            { label: "Geology", desc: "Geological mapping, rock mass characterization, and mineral assessment" },
            { label: "Soil Conservation", desc: "Soil quality assessment, erosion control, and land restoration" },
            { label: "Risk & Hazards Management", desc: "Hazard identification, consequence analysis, and emergency planning" },
            { label: "Solid and Hazardous Waste Management", desc: "Waste characterization, treatment, disposal, and recycling strategies" }
        ].map(s => ({ label: s.label, value: s.label, desc: s.desc }))
    };

    const msState = {
        sectorSelect: [],
        subjectSelect: []
    };

    function initMultiSelects() {
        Object.keys(msData).forEach(id => {
            renderMsOptions(id);
            renderMsChips(id);
        });

        // Close dropdowns on outside click
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.l-multi-select')) {
                document.querySelectorAll('.l-ms-dropdown').forEach(d => d.classList.remove('show'));
                document.querySelectorAll('.l-ms-control').forEach(c => c.classList.remove('active'));
            }
        });
    }

    function toggleMsDropdown(id, event) {
        event.stopPropagation();
        const dropdown = document.getElementById(id + 'Dropdown');
        const control = dropdown.previousElementSibling;
        const isOpen = dropdown.classList.contains('show');

        // Close all others
        document.querySelectorAll('.l-ms-dropdown').forEach(d => d.classList.remove('show'));
        document.querySelectorAll('.l-ms-control').forEach(c => c.classList.remove('active'));

        if (!isOpen) {
            dropdown.classList.add('show');
            control.classList.add('active');
            const searchInput = document.getElementById(id + 'Search');
            if (searchInput) {
                setTimeout(() => searchInput.focus(), 10);
            }
        }
    }

    function renderMsOptions(id, filter = '') {
        const optionList = document.getElementById(id + 'OptionsList');
        const limit = parseInt(document.getElementById(id).dataset.limit);
        const isLimitReached = msState[id].length >= limit;
        
        const items = msData[id].filter(item => 
            item.label.toLowerCase().includes(filter.toLowerCase())
        );

        optionList.innerHTML = items.map(item => {
            const isSelected = msState[id].includes(item.value);
            const isDisabled = isLimitReached && !isSelected;
            
            return `
                <div class="l-ms-option ${isSelected ? 'selected' : ''} ${isDisabled ? 'disabled' : ''}" 
                     onclick="event.stopPropagation(); ${isDisabled ? '' : `toggleMsItem('${id}', '${item.value.replace(/'/g, "\\'")}')`}">
                    <div class="l-ms-checkbox-wrap">
                        <div class="l-ms-checkmark">
                             <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                    </div>
                    <div class="l-ms-option-content">
                        <span class="l-ms-option-label">${item.label}</span>
                        ${item.desc ? `<span class="l-ms-option-hint">${item.desc}</span>` : ''}
                    </div>
                </div>
            `;
        }).join('') || '<div class="p-3 text-center text-muted small">No matches found</div>';
        
        const limitMsg = document.getElementById(id + 'LimitMsg');
        if (limitMsg) {
            limitMsg.classList.toggle('show', isLimitReached);
            limitMsg.textContent = `You can select up to ${limit} ${id.includes('sector') ? 'sectors' : 'subject expertise areas'} only.`;
        }
    }

    function filterMsDropdown(id, query) {
        renderMsOptions(id, query);
    }

    function toggleMsItem(id, value) {
        const limit = parseInt(document.getElementById(id).dataset.limit);
        const index = msState[id].indexOf(value);

        if (index > -1) {
            msState[id].splice(index, 1);
        } else {
            if (msState[id].length < limit) {
                msState[id].push(value);
            }
        }

        renderMsChips(id);
        renderMsOptions(id, document.getElementById(id + 'Search').value);
        updateMsInputs(id);
    }

    function renderMsChips(id) {
        const chipsContainer = document.getElementById(id + 'Chips');
        const placeholder = document.getElementById(id + 'Placeholder');
        const labels = msState[id];

        placeholder.style.display = labels.length > 0 ? 'none' : 'block';
        
        chipsContainer.innerHTML = labels.map(val => {
            const item = msData[id].find(i => i.value === val);
            return `
                <div class="l-ms-chip" title="${item.desc || val}">
                    ${val}
                    <span class="l-ms-chip-remove" onclick="event.stopPropagation(); toggleMsItem('${id}', '${val.replace(/'/g, "\\'")}')">&times;</span>
                </div>
            `;
        }).join('');
    }

    function updateMsInputs(id) {
        const container = document.getElementById(id + 'HiddenInputs');
        const name = document.getElementById(id).dataset.name;
        container.innerHTML = msState[id].map(val => `
            <input type="hidden" name="${name}" value="${val}">
        `).join('');
    }

    document.addEventListener('DOMContentLoaded', function() {
        initMultiSelects();
        
        // --- BULLETPROOF PROFILE DROPDOWN & LOGOUT LOGIC ---
        const profileMenu = document.getElementById('profileMenu');
        const profileTrigger = document.getElementById('profileTrigger');
        const dropdownMenu = document.getElementById('dropdownMenu');

        if (profileTrigger && dropdownMenu) {
            // 1. Robust Toggle (Stop Propagation is key)
            profileTrigger.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const isOpen = dropdownMenu.classList.contains('open');
                
                // Toggle state
                if (isOpen) {
                    dropdownMenu.classList.remove('open');
                    profileMenu.classList.remove('active');
                } else {
                    dropdownMenu.classList.add('open');
                    profileMenu.classList.add('active');
                }
            });

            // 2. Prevent closing when clicking inside the dropdown (except on links)
            dropdownMenu.addEventListener('click', function(e) {
                e.stopPropagation();
            });

            // 3. Global Outside Click Close
            document.addEventListener('click', function() {
                dropdownMenu.classList.remove('open');
                profileMenu.classList.remove('active');
            });

            // 4. Global ESC Key Close
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    dropdownMenu.classList.remove('open');
                    profileMenu.classList.remove('active');
                }
            });
        }

        // 5. FAILSAFE LOGOUT (Event Delegation)
        document.addEventListener('click', function(e) {
            const logoutLink = e.target.closest('#logoutBtn');
            if (logoutLink) {
                e.preventDefault();
                e.stopPropagation();
                
                if (confirm("Are you sure you want to logout?")) {
                    // Clear all session artifacts
                    localStorage.clear();
                    sessionStorage.clear();
                    
                    // Clear cookies as an additional safeguard
                    document.cookie.split(";").forEach(function(c) {
                        document.cookie = c.replace(/^ +/, "").replace(/=.*/, "=;expires=" + new Date().toUTCString() + ";path=/");
                    });

                    // Redirect to secure logout route
                    window.location.href = logoutLink.getAttribute('href') || "/Auth/Logout";
                }
            }
        });
        
        // --- CATEGORY-WISE GROUPED UI LOGIC ---
        
        function syncCategoryGroups() {
            const selectedCategories = Array.from(document.querySelectorAll('input[name="cert_category[]"]:checked')).map(cb => cb.value);
            
            // Update Step 5 (Projects)
            const projectContainer = document.getElementById('projectContainerGrouped');
            const noProjectMsg = document.getElementById('noProjectMsg');
            
            if (selectedCategories.length === 0) {
                projectContainer.innerHTML = '';
                noProjectMsg.style.display = 'flex';
            } else {
                noProjectMsg.style.display = 'none';
                // Remove groups for unselected categories
                const currentGroups = projectContainer.querySelectorAll('.category-project-group');
                currentGroups.forEach(group => {
                    if (!selectedCategories.includes(group.dataset.category)) {
                        group.remove();
                    }
                });
                // Add groups for new selections
                selectedCategories.forEach(cat => {
                    if (!projectContainer.querySelector(`.category-project-group[data-category="${cat}"]`)) {
                        renderProjectGroup(cat);
                    }
                });
            }

            // Update Step 6 (Reports)
            const reportContainer = document.getElementById('reportContainerGrouped');
            const noReportMsg = document.getElementById('noReportMsg');
            
            if (selectedCategories.length === 0) {
                reportContainer.innerHTML = '';
                noReportMsg.style.display = 'flex';
            } else {
                noReportMsg.style.display = 'none';
                // Remove groups for unselected categories
                const currentGroups = reportContainer.querySelectorAll('.category-report-group');
                currentGroups.forEach(group => {
                    if (!selectedCategories.includes(group.dataset.category)) {
                        group.remove();
                    }
                });
                // Add groups for new selections
                selectedCategories.forEach(cat => {
                    if (!reportContainer.querySelector(`.category-report-group[data-category="${cat}"]`)) {
                        renderReportGroup(cat);
                    }
                });
            }
        }

        function renderProjectGroup(category) {
            const template = document.getElementById('projectGroupTemplate');
            const clone = template.content.cloneNode(true);
            const group = clone.querySelector('.category-project-group');
            group.dataset.category = category;
            group.querySelector('.category-group-title span').textContent = category;
            
            document.getElementById('projectContainerGrouped').appendChild(group);
            addProjectRowGrouped(group); // Add initial project
        }

        function renderReportGroup(category) {
            const template = document.getElementById('reportGroupTemplate');
            const clone = template.content.cloneNode(true);
            const group = clone.querySelector('.category-report-group');
            group.dataset.category = category;
            group.querySelector('.category-group-title span').textContent = category;
            
            document.getElementById('reportContainerGrouped').appendChild(group);
            addReportRowGrouped(group); // Add initial report
        }

        // Attach listeners to Step 2 checkboxes dynamically
        document.querySelectorAll('input[name="cert_category[]"]').forEach(cb => {
            cb.addEventListener('change', syncCategoryGroups);
        });
        
        // Initialize on load
        syncCategoryGroups();
    });

    function addProjectRowGrouped(groupElement) {
        const category = groupElement.dataset.category;
        const listContainer = groupElement.querySelector('.project-list-container');
        const currentCount = listContainer.querySelectorAll('.project-card').length;
        
        if (currentCount >= 15) {
            alert(`Maximum 15 projects allowed for ${category}.`);
            return;
        }

        const template = document.getElementById('projectCardTemplate');
        const clone = template.content.cloneNode(true);
        const card = clone.querySelector('.project-card');
        
        card.querySelector('.project-badge').textContent = `Project ${currentCount + 1}`;
        card.querySelector('.project-category-hidden').value = category;
        
        if (currentCount > 0) {
            card.querySelector('.remove-project-btn').style.display = 'flex';
        }
        
        listContainer.appendChild(card);
    }

    function removeProjectRowGrouped(btn) {
        const group = btn.closest('.category-project-group');
        btn.closest('.project-card').remove();
        
        // Re-index
        const cards = group.querySelectorAll('.project-card');
        cards.forEach((card, i) => {
            card.querySelector('.project-badge').textContent = `Project ${i + 1}`;
            card.querySelector('.remove-project-btn').style.display = i === 0 ? 'none' : 'flex';
        });
    }

    function addReportRowGrouped(groupElement) {
        const category = groupElement.dataset.category;
        const listContainer = groupElement.querySelector('.report-list-container');
        const currentCount = listContainer.querySelectorAll('.report-row').length;
        
        if (currentCount >= 5) {
            alert("Maximum 5 reports allowed per category.");
            return;
        }

        const template = document.getElementById('reportRowTemplate');
        const clone = template.content.cloneNode(true);
        const row = clone.querySelector('.report-row');
        
        row.querySelector('.report-label').innerHTML = `Report ${currentCount + 1} ${currentCount === 0 ? '<span class="req">*</span>' : '(Optional)'}`;
        row.querySelector('.report-category-hidden').value = category;
        
        if (currentCount > 0) {
            row.querySelector('.remove-report-btn').style.display = 'block';
            row.querySelector('input[type="file"]').removeAttribute('required');
        }
        
        listContainer.appendChild(row);
    }

    function removeReportRowGrouped(btn) {
        const group = btn.closest('.category-report-group');
        btn.closest('.report-row').remove();
        
        // Re-index
        const rows = group.querySelectorAll('.report-row');
        rows.forEach((row, i) => {
            row.querySelector('.report-label').innerHTML = `Report ${i + 1} ${i === 0 ? '<span class="req">*</span>' : '(Optional)'}`;
            row.querySelector('.remove-report-btn').style.display = i === 0 ? 'none' : 'block';
            if (i === 0) row.querySelector('input[type="file"]').setAttribute('required', 'required');
        });
    }

    function updateReportStatsGrouped(group) {
        // Optional: Implement category-specific progress if needed
    }
</script>
</body>
</html>
