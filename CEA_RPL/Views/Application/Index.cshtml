    function toggleGovIdUpload() {
        const type = document.getElementById('govIdType')?.value;
        const label = document.getElementById('govIdLabel');
        const govIdInput = document.getElementById('govIdNumber');
        const confirmGovIdInput = document.getElementById('confirmGovIdNumber');
        const confirmAadhaarGroup = document.getElementById('confirmAadhaarGroup');
        const confirmLabel = confirmAadhaarGroup?.querySelector('label');
        const fileInput = document.getElementById('govIdUpload');
        const aadhaarError = document.getElementById('aadhaarError');
        
        // --- 1. CLEAR ORIGINAL VALUES (VERY IMPORTANT) ---
        originalIdValue = "";
        originalConfirmValue = "";
        
        // --- 2. CLEAR INPUT FIELDS ---
        if (govIdInput) {
            govIdInput.value = '';
            govIdInput.style.borderColor = '';
        }
        if (confirmGovIdInput) {
            confirmGovIdInput.value = '';
            confirmGovIdInput.style.borderColor = '';
        }
        
        // --- 3. CLEAR FILE INPUT & 4. RESET FILE UI ---
        if (fileInput) {
            fileInput.value = '';
            fileInput.removeAttribute('data-has-file');
            hideFieldError(fileInput);
            
            // Reset hint text to original
            const fieldContainer = fileInput.closest('.form-group');
            const hint = fieldContainer?.querySelector('.identity-hint');
            if (hint) {
                hint.innerHTML = 'PDF 2MB';
            }
        }
        
        // --- 5. REMOVE SUCCESS / ERROR STATES ---
        if (aadhaarError) {
            aadhaarError.style.display = 'none';
            aadhaarError.innerText = '';
        }
        
        // --- 6. UPDATE LABELS & PLACEHOLDERS ---
        if (type === 'government_id') {
            if (label) label.innerHTML = 'Government ID Number <span class="req">*</span>';
            if (govIdInput) govIdInput.placeholder = 'Enter Government ID Number';
            if (confirmLabel) confirmLabel.innerHTML = 'Confirm ID Number <span class="req">*</span>';
            if (confirmGovIdInput) confirmGovIdInput.placeholder = 'Confirm ID Number';
            
            if (confirmAadhaarGroup) confirmAadhaarGroup.style.display = 'block';
            if (confirmGovIdInput) confirmGovIdInput.required = true;
        } else if (type === 'employee_id') {
            if (label) label.innerHTML = 'Employee ID <span class="req">*</span>';
            if (govIdInput) govIdInput.placeholder = 'Enter Employee ID';
            if (confirmLabel) confirmLabel.innerHTML = 'Confirm Employee ID <span class="req">*</span>';
            if (confirmGovIdInput) confirmGovIdInput.placeholder = 'Enter Employee ID';
            
            if (confirmAadhaarGroup) confirmAadhaarGroup.style.display = 'block';
            if (confirmGovIdInput) confirmGovIdInput.required = true;
        } else {
            if (confirmAadhaarGroup) confirmAadhaarGroup.style.display = 'none';
            if (confirmGovIdInput) confirmGovIdInput.required = false;
        }
    }

    function isMasked(val) {
        return val && val.includes("X");
    }

    function normalizeAadhaar(val) {
        if (!val) return "";
        return val.replace(/\D/g, ''); // remove spaces, X, everything except digits
    }

    function validateAadhaarMatch() {
        const errorDiv = document.getElementById('aadhaarError');
        const confirmInput = document.getElementById('confirmGovIdNumber');
        const idType = document.getElementById('govIdType')?.value;
        const idInput = document.getElementById('govIdNumber');

        const idValRaw = idInput?.value || "";
        const confirmValRaw = confirmInput?.value || "";

        // CASE 1: BOTH MASKED -> VALID
        if (isMasked(idValRaw) && isMasked(confirmValRaw)) {
            errorDiv.style.display = 'none';
            confirmInput.style.borderColor = '';
            return;
        }

        // Use original values if available, otherwise fallback to UI values for normalization
        let cleanOriginal = originalIdValue ? originalIdValue.replace(/\s/g, "") : idValRaw.replace(/\s/g, "");
        let cleanConfirm = originalConfirmValue ? originalConfirmValue.replace(/\s/g, "") : confirmValRaw.replace(/\s/g, "");

        // Only normalize for Government ID patterns if they look like Aadhaar
        if (idType === 'government_id' && cleanOriginal.length === 12 && /^\d+$/.test(cleanOriginal)) {
            cleanOriginal = normalizeAadhaar(cleanOriginal);
            cleanConfirm = normalizeAadhaar(cleanConfirm);
        }

        // CASE 2: BOTH EMPTY -> no error
        if (!cleanOriginal || !cleanConfirm) {
            errorDiv.style.display = 'none';
            confirmInput.style.borderColor = '';
            return;
        }

        // CASE 3: MATCH -> remove error
        if (cleanOriginal === cleanConfirm) {
            errorDiv.style.display = 'none';
            confirmInput.style.borderColor = '';
            errorDiv.innerText = '';
        } else {
            errorDiv.style.display = 'block';
            errorDiv.innerText = 'ID numbers do not match';
            confirmInput.style.borderColor = '#e53e3e';
        }
    }

    let originalIdValue = "";
    let originalConfirmValue = "";
    let originalMobile = "";

    function maskAadhaar(value) {
        if (!value || value.length < 4) return value;
        return "XXXX XXXX " + value.slice(-4);
    }

    function maskPAN(value) {
        if (!value || value.length < 5) return value;
        return value.slice(0, 3) + "XXXXX" + value.slice(-2);
    }

    function maskPassport(value) {
        if (!value || value.length < 2) return value;
        return value.charAt(0) + "XXXXXX" + value.slice(-1);
    }

    function maskOther(value) {
        if (!value || value.length < 4) return value;
        return "XXXXX" + value.slice(-4);
    }

    function maskValueByType(value, idType) {
        if (!value) return "";
        if (idType === 'government_id') {
            if (value.length === 12 && /^\d+$/.test(value)) return maskAadhaar(value);
            if (value.length === 10 && /^[A-Z]{5}[0-9]{4}[A-Z]$/.test(value)) return maskPAN(value);
            if (value.length === 8 && /^[A-Z][0-9]{7}$/.test(value)) return maskPassport(value);
            return maskOther(value);
        }
        if (idType === 'employee_id') return maskOther(value);
        return value;
    }

    function applyIdMask() {
        const idType = document.getElementById('govIdType')?.value;
        const input = document.getElementById('govIdNumber');
        const confirmInput = document.getElementById('confirmGovIdNumber');

        if (input) {
            if (!originalIdValue) input.value = "";
            else input.value = maskValueByType(originalIdValue, idType);
        }

        if (confirmInput) {
            if (!originalConfirmValue) confirmInput.value = "";
            else confirmInput.value = maskValueByType(originalConfirmValue, idType);
        }
    }

    function maskMobile(value) {
        if (!value || value.length < 4) return value;
        return "XXXXXX" + value.slice(-4);
    }

    document.addEventListener('DOMContentLoaded', () => {
        updateUI();

        // Step 14: Retired Govt Employee & Declaration Sync
        const retiredRadios = document.querySelectorAll('input[name="decl_retired_gov"]');
        const check1 = document.querySelector('input[name="declaration_consent_1"]');
