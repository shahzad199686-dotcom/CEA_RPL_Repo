    function handleServerValidation(message) {
        if (!message) return;
        
        let foundMatch = false;
        // Step mapping based on metadata and field names
        const stepMap = {
            'Applicant Details': 1, 'Candidate Name': 1, 'Parent': 1, 'Email': 1, 'Mobile': 1, 'DOB': 1, 'Address': 1, 'ID Proof': 1, 'Photograph': 1, 'Identity': 1,
            'Certification': 2,
            'Education': 3, 'Degree': 3, 'Institution': 3,
            'Professional Experience': 4, 'Organization': 4, 'Designation': 4, 'Experience': 4,
            'Project': 5,
            'Scientific Publication': 9, 'Publication': 9,
            'Award': 10,
            'Software': 11,
            'Other Enclosure': 12, 'Enclosure': 12,
            'Payment': 13, 'UTR': 13, 'Receipt': 13,
            'Declaration': 14, 'Signature': 14
        };

        // Scan validationMetadata for keywords in the message
        for (const [fieldName, meta] of Object.entries(validationMetadata)) {
            if (meta.keywords && meta.keywords.some(k => message.includes(k))) {
                // Determine step
                let targetStep = 0;
                for (const [kw, step] of Object.entries(stepMap)) {
                    if (message.includes(kw)) {
                        targetStep = step;
                        break;
                    }
                }

                if (targetStep > 0) {
                    currentStep = targetStep;
                    updateUI();
                }

                // Find the field
                const field = document.getElementsByName(fieldName)[0] || document.getElementById(fieldName);
                if (field) {
                    showFieldError(field, message);
                    field.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    foundMatch = true;
                }
                break;
            }
        }

        if (!foundMatch) {
            showToast(message, "error");
        }
    }

    function showFieldError(input, customMsg = null) {
        if (!input) return;
        
        input.classList.add('field-invalid');
        input.classList.add('field-error-pulse');
        
        // For file inputs, also highlight the parent wrapper if it exists (like custom upload UI)
        if (input.type === 'file') {
            const wrapper = input.closest('.file-upload-wrapper') || input.parentElement;
            wrapper.style.borderColor = '#c53030';
            wrapper.style.backgroundColor = '#fff5f5';
        }

        const name = input.name || input.id;
        const meta = validationMetadata[name] || {};
        const errorMsg = customMsg || meta.error || 'This field is required.';
        
        // Remove existing error logic
        hideFieldError(input);
        
        const guidance = document.createElement('div');
        guidance.className = 'error-guidance';
        guidance.innerHTML = `
            <span class="error-text">⚠️ ${errorMsg}</span>
        `;
        
        // Find best place to insert
        let container = input.parentElement;
        if (input.type === 'checkbox' || input.type === 'radio') {
            container = input.closest('.category-card-v2') || input.parentElement;
            container.appendChild(guidance);
        } else if (input.type === 'file') {
            const fieldContainer = input.closest('.form-group') || input.closest('td') || input.parentElement;
            const hint = fieldContainer.querySelector('.file-validation-hint, .identity-hint');
            if (hint) {
                 hint.insertAdjacentElement('afterend', guidance);
            } else {
                 fieldContainer.appendChild(guidance);
            }
        } else if (input.tagName === 'TEXTAREA') {
            // Place directly after the textarea (before word counters if any)
            input.insertAdjacentElement('afterend', guidance);
        } else {
            container.appendChild(guidance);
        }
    }

    function hideFieldError(input) {
        if (!input) return;
        input.classList.remove('field-invalid');
        input.classList.remove('field-error-pulse');
        
        if (input.type === 'file') {
            const wrapper = input.closest('.file-upload-wrapper') || input.parentElement;
            if (wrapper) {
                wrapper.style.borderColor = '';
                wrapper.style.backgroundColor = '';
            }
        }
        
        const fieldContainer = input.closest('.form-group') || input.closest('td') || input.closest('.category-card-v2') || input.parentElement;
        if (fieldContainer) {
            const existing = fieldContainer.querySelectorAll('.error-guidance');
            existing.forEach(el => el.remove());

            // Also clean up old-style errors
            const oldMeaningful = fieldContainer.querySelectorAll('.meaningful-error');
            oldMeaningful.forEach(el => el.remove());
            const oldAddress = fieldContainer.querySelector('.address-error');
            if (oldAddress) oldAddress.remove();
        }
    }

    function validateField(input) {
        if (!input) return true;
        
        let isInvalid = false;
        let customMsg = null;
        
        // Step mapping context for address fields
        const isAddressField = input.name === 'address_perm' || input.name === 'address_corr';
        const isPincodeField = input.name === 'pincode_perm' || input.name === 'pincode_corr';
        const isCityField = input.name === 'city_perm' || input.name === 'city_corr';

        if (input.name === 'enclosure_desc' && !input.hasAttribute('required')) {
            if (input.value.trim() !== '' && typeof isMeaningfulText === 'function' && !isMeaningfulText(input.value, true)) {
                isInvalid = true;
                customMsg = "Please enter a meaningful description for your enclosure.";
            }
        } else if (input.type === 'checkbox' || input.type === 'radio') {
            const section = input.closest('.form-section') || document;
            if (input.type === 'radio' || input.name.includes('[]')) {
                const group = section.querySelectorAll(`input[name="${input.name}"]`);
                const checkedCount = Array.from(group).filter(i => i.checked).length;
                if (checkedCount === 0 && input.hasAttribute('required')) isInvalid = true;
            } else if (!input.checked && input.hasAttribute('required')) {
                isInvalid = true;
            }
        } else {
            const isFile = input.type === 'file';
            const hasFile = isFile && (input.files?.length > 0 || input.getAttribute('data-has-file') === 'true');
            const isEmpty = !input.value || input.value.trim() === '';

            if (isFile) {
                if (!hasFile && input.hasAttribute('required')) {
                    if (input.id === 'govIdUpload') {
                        const idType = document.getElementById('govIdType')?.value;
                        if (idType) isInvalid = true;
                    } else {
                        isInvalid = true;
                    }
                }
            } else if (isEmpty) {
                if (input.hasAttribute('required')) isInvalid = true;
            } else if (input.type === 'text' || input.tagName === 'TEXTAREA' || input.tagName === 'SELECT') {
                const isDesc = input.tagName === 'TEXTAREA' || input.name === 'enclosure_desc';
                const skipNames = ['gov_id_number', 'payment_utr', 'mobile', 'alt_mobile', 'email', 'total_experience', 'payment_amount', 'address_perm', 'address_corr'];
                
                if (isAddressField || isPincodeField || isCityField) {
                    const prefix = (input.name.includes('perm') || (input.id && input.id.includes('perm'))) ? 'perm' : 'corr';
                    const cityField = document.getElementById(`city_${prefix}`);
                    const pinField = document.getElementById(`pincode_${prefix}`);
                    const addrField = document.getElementById(`address_${prefix}`);
                    
                    if (cityField && !cityField.value) {
                        isInvalid = true;
                        customMsg = "This field is required.";
                    } else if (pinField && (!/^[0-9]{6}$/.test(pinField.value))) {
                        isInvalid = true;
                        customMsg = "Pincode must be exactly 6 digits.";
                    } else if (addrField && (addrField.value.trim().length < 3 || !/^[a-zA-Z0-9\s,.\-/#]{3,}$/.test(addrField.value.trim()))) {
                        isInvalid = true;
                        customMsg = "This field is required.";
                    }
                } else if (input.name === 'mobile' || input.name === 'alt_mobile') {
                    if (input.value.trim() !== '' && !/^[0-9]{10}$/.test(input.value.trim())) {
                        isInvalid = true;
                        customMsg = "Please enter a valid 10-digit mobile number.";
                    }
                } else if (!skipNames.includes(input.name) && typeof isMeaningfulText === 'function' && !isMeaningfulText(input.value, isDesc)) {
                    isInvalid = true;
                    customMsg = "This field is required.";
                }
            }
        }

        if (input.id === 'govIdNumber' || input.id === 'confirmGovIdNumber') {
            const type = document.getElementById('govIdType')?.value;
            if (type === 'aadhaar') {
                const govIdRaw = document.getElementById('govIdNumber')?.value || "";
                const confirmGovIdRaw = document.getElementById('confirmGovIdNumber')?.value || "";

                // IF both values are masked → treat as valid
                if (isMasked(govIdRaw) && isMasked(confirmGovIdRaw)) {
                    isInvalid = false;
                } else {
                    const cleanOriginal = normalizeAadhaar(originalIdValue || govIdRaw);
                    const cleanConfirm = normalizeAadhaar(originalConfirmValue || confirmGovIdRaw);

                    if (cleanOriginal && cleanConfirm && cleanOriginal !== cleanConfirm) {
                        isInvalid = true;
                        customMsg = "ID numbers do not match.";
                    } else {
                        isInvalid = false;
                    }
                }
            }
        }

        // DOB / Age Logic
        if (input.id === 'dob' && input.value) {
            const dob = new Date(input.value);
            const today = new Date();
            if (dob >= today) {
                isInvalid = true;
                customMsg = "Please select a valid Date of Birth.";
            } else {
                let age = today.getFullYear() - dob.getFullYear();
                const m = today.getMonth() - dob.getMonth();
                if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
                if (age < 18) {
                    isInvalid = true;
                    customMsg = "Applicant must be at least 18 years old.";
                } else if (age >= 70) {
                    isInvalid = true;
                    customMsg = "Applicant must be below 70 years of age.";
                }
            }
        }

        if (isInvalid) {
            showFieldError(input, customMsg);
            return false;
        } else {
            hideFieldError(input);
            return true;
        }
    }

    function validateSection(step) {
        const section = document.getElementById('step-' + step);
        if (!section) return true;

        const inputs = section.querySelectorAll('[required], .required-group, textarea[name="enclosure_desc"], select[id^="city_"], input[id^="pincode_"]');
        let firstInvalid = null;
        let valid = true;

        // Clear all previous errors in this section
        section.querySelectorAll('input, select, textarea').forEach(input => hideFieldError(input));

        inputs.forEach(input => {
            if (!validateField(input)) {
                valid = false;
                if (!firstInvalid) firstInvalid = input;
            }
        });

        // Step 5 specific check: enforce min 1 project per category
        if (step === 5) {
            const selectedCategories = Array.from(document.querySelectorAll('input[name="cert_category[]"]:checked')).map(cb => cb.value);
            for (const cat of selectedCategories) {
                const group = section.querySelector(`.category-project-group[data-category="${cat}"]`);
                const projects = group ? group.querySelectorAll('.project-card') : [];
                if (projects.length === 0) {
                    valid = false;
                    showToast(`Please add at least one project for ${cat}.`, "error");
                    break;
                }
                const firstProjName = projects[0].querySelector('[name="project_name_cat1[]"]');
                if (firstProjName && !firstProjName.value.trim()) {
                    valid = false;
                    showFieldError(firstProjName, "This field is required.");
                    if (!firstInvalid) firstInvalid = firstProjName;
                }
            }
        }

        // Step 6 specific check: enforce min 1 report per category
        if (step === 6) {
            const selectedCategories = Array.from(document.querySelectorAll('input[name="cert_category[]"]:checked')).map(cb => cb.value);
            for (const cat of selectedCategories) {
                const group = section.querySelector(`.category-report-group[data-category="${cat}"]`);
                if (group) {
                    const reports = group.querySelectorAll('input[name="audit_report"]');
                    let catUploads = 0;
                    reports.forEach(inp => { if (inp.files && inp.files.length > 0) catUploads++; });
                    
                    if (catUploads < 1) {
                        valid = false;
                        showToast(`Please upload at least one report for ${cat}.`, "error");
                        const firstInput = group.querySelector('input[name="audit_report"]');
                        if (firstInput && !firstInvalid) firstInvalid = firstInput;
                        break;
                    }
                }
            }
        }

        if (step === 2) {
            const categories = section.querySelectorAll('input[name="cert_category[]"]:checked');
            if (categories.length === 0) {
                valid = false;
                showToast("Please select at least one certification category.", "error");
                const gridElem = section.querySelector('.cat-container-v2');
                if (gridElem) {
                    gridElem.classList.add('field-invalid');
                    gridElem.classList.add('field-error-pulse');
                    if (!firstInvalid) firstInvalid = gridElem;
                }
            }
        }

        // Step 4 specific check: Dynamic Experience Requirement
        if (step === 4) {
            const expInput = document.getElementById('total_experience');
            if (expInput) {
                const minRequired = 20;
                const roundedValue = roundExperience(expInput.value);

                if (!expInput.value || roundedValue < minRequired) {
                    valid = false;
                    showFieldError(expInput, `Minimum required professional experience is ${minRequired} years.`);
                    if (!firstInvalid) firstInvalid = expInput;
                }
            }


            // Note: Sector and Subject selection are now optional.
            const sectorSelect = document.getElementById('sectorSelect');
            if (sectorSelect) sectorSelect.querySelector('.l-ms-control').classList.remove('invalid');
            
            const subjectSelect = document.getElementById('subjectSelect');
            if (subjectSelect) subjectSelect.querySelector('.l-ms-control').classList.remove('invalid');
        }

        if (step === 14) {
            const retiredRadio = section.querySelector('input[name="decl_retired_gov"]:checked');
            if (!retiredRadio) {
                valid = false;
                const radioGroup = section.querySelector('.retired-gov-question');
                showFieldError(section.querySelector('input[name="decl_retired_gov"]'), "This field is required.");
                if (!firstInvalid) firstInvalid = section.querySelector('input[name="decl_retired_gov"]');
            } else {
                const retiredVal = retiredRadio.value;
                const check1 = section.querySelector('input[name="declaration_consent_1"]');
                const check2 = section.querySelector('input[name="declaration_consent_2"]');
                
                if (retiredVal === 'Yes' && !check1.checked) {
                    valid = false;
                    showFieldError(check1, "This field is required.");
                    if (!firstInvalid) firstInvalid = check1;
                } else if (retiredVal === 'No' && !check2.checked) {
                    valid = false;
                    showFieldError(check2, "This field is required.");
                    if (!firstInvalid) firstInvalid = check2;
                }
            }
        }


        if (!valid) {
            showToast("Please correct the highlighted fields to proceed.", "error");
            if (firstInvalid) {
                const rect = firstInvalid.getBoundingClientRect();
                const absoluteTop = rect.top + window.pageYOffset;
                window.scrollTo({ top: absoluteTop - 180, behavior: 'smooth' });
                try { firstInvalid.focus({ preventScroll: true }); } catch(e) {}
            }
        }
        return valid;
    }


