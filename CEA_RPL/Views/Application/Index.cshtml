                                    <label>Project Name</label>
                                    <input name="project_name_cat1[]" placeholder="Enter Project Name" />
                                </div>
                                <div>
                                    <label>Client</label>
                                    <input name="project_client_cat1[]" placeholder="Client Name" />
                                </div>
                                <div>
                                    <label>Location</label>
                                    <input name="project_location_cat1[]" placeholder="Location" />
                                </div>
                                <div>
                                    <label>Executed in Year</label>
                                    <input type="number" name="project_year_cat1[]" placeholder="Year" />
                                </div>
                                <div>
                                    <label>Role of Applicant</label>
                                    <select name="project_role_cat1[]">
                                        <option value="">Select</option>
                                        <option>Team Lead</option>
                                        <option>Team Member</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <button type="button" class="btn btn-ghost" style="margin-top: 24px;" onclick="addProjectRow()">+ Add Project</button>
                </div>
            </div>

            <!-- STEP 6: UPLOAD REPORTS -->
            <div class="form-section hide" id="step-6">
                <div class="section-header">
                    <h2>Step 6: Upload Reports</h2>
                    
                </div>
                <div class="section-content">
                    <div class="info-note-blue" style="margin-bottom: 24px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                        <div style="flex: 1;">
                            <b style="font-weight: 700; display: block; margin-bottom: 4px;">Upload your environmental audit / study reports.</b>
                            <p style="margin: 0; font-size: 0.9rem; opacity: 0.9;">Please provide a minimum of 2 reports and a maximum of 5 reports in PDF format (Max 10MB each).</p>
                        </div>
                    </div>

                    <div id="reportGuidance" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 12px 20px; margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <div id="reportProgressDot" style="width: 10px; height: 10px; border-radius: 50%; background: #cbd5e1;"></div>
                            <span id="reportCountText" style="font-weight: 700; color: #475569; font-size: 0.9rem;">Requirement: 0 of 5 Reports Uploaded</span>
                        </div>
                        <span id="reportStatusBadge" style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; background: #fee2e2; color: #991b1b;">Minimum 2 Required</span>
                    </div>

                    <div id="auditReportContainer" style="display: flex; flex-direction: column; gap: 16px;">
                        <!-- Report 1 & 2 (Always Visible) -->
                        <div class="report-row active" data-index="1" style="display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 16px; background: #fff; border: 1px solid var(--line); border-radius: 12px;">
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-weight: 700;">Report 1 <span class="req">*</span></label>
                                <input type="file" name="audit_report" accept=".pdf" required onchange="validateFileUpload(this); updateReportStats();" />
                                <div class="file-validation-hint" style="font-size: 0.7rem; color: var(--muted); margin-top: 4px;">PDF ONLY ≤ 10 MB</div>
                            </div>
                        </div>

                        <div class="report-row active" data-index="2" style="display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 16px; background: #fff; border: 1px solid var(--line); border-radius: 12px;">
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-weight: 700;">Report 2 <span class="req">*</span></label>
                                <input type="file" name="audit_report" accept=".pdf" required onchange="validateFileUpload(this); updateReportStats();" />
                                <div class="file-validation-hint" style="font-size: 0.7rem; color: var(--muted); margin-top: 4px;">PDF ONLY ≤ 10 MB</div>
                            </div>
                        </div>

                        <!-- Optional Slots 3, 4, 5 (Hidden by default) -->
                        <div class="report-row" data-index="3" style="display: none; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 16px; background: #fcfdfd; border: 1px dashed var(--line); border-radius: 12px; transition: all 0.3s ease;">
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--accent);">Report 3 (Optional)</label>
                                <input type="file" name="audit_report" accept=".pdf" onchange="validateFileUpload(this); updateReportStats();" />
                                <div class="file-validation-hint" style="font-size: 0.7rem; color: var(--muted); margin-top: 4px;">PDF ONLY ≤ 10 MB</div>
                            </div>
                            <button type="button" class="btn btn-ghost" onclick="removeAuditReport(3)" style="color: #ef4444; border-color: #fee2e2;">Remove</button>
                        </div>

                        <div class="report-row" data-index="4" style="display: none; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 16px; background: #fcfdfd; border: 1px dashed var(--line); border-radius: 12px; transition: all 0.3s ease;">
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--accent);">Report 4 (Optional)</label>
                                <input type="file" name="audit_report" accept=".pdf" onchange="validateFileUpload(this); updateReportStats();" />
                                <div class="file-validation-hint" style="font-size: 0.7rem; color: var(--muted); margin-top: 4px;">PDF ONLY ≤ 10 MB</div>
                            </div>
                            <button type="button" class="btn btn-ghost" onclick="removeAuditReport(4)" style="color: #ef4444; border-color: #fee2e2;">Remove</button>
                        </div>

                        <div class="report-row" data-index="5" style="display: none; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 16px; background: #fcfdfd; border: 1px dashed var(--line); border-radius: 12px; transition: all 0.3s ease;">
                            <div>
                                <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--accent);">Report 5 (Optional)</label>
                                <input type="file" name="audit_report" accept=".pdf" onchange="validateFileUpload(this); updateReportStats();" />
                                <div class="file-validation-hint" style="font-size: 0.7rem; color: var(--muted); margin-top: 4px;">PDF ONLY ≤ 10 MB</div>
                            </div>
                            <button type="button" class="btn btn-ghost" onclick="removeAuditReport(5)" style="color: #ef4444; border-color: #fee2e2;">Remove</button>
                        </div>
                    </div>

                    <button type="button" id="btnAddReport" class="btn btn-ghost" style="margin-top: 24px; padding: 12px 24px; width: 100%; border: 2px dashed #0F9D9A; color: #0F9D9A;" onclick="addAuditReport()">+ Add Another Report (Optional)</button>
                </div>
            </div>

            <!-- STEP 7: TRAINING / CERTIFICATION -->
            <div class="form-section hide" id="step-7">
                <div class="section-header"><h2>Step 7: Details of Certification / Training</h2></div>
                <div class="section-content">
                    <div class="step7-section-container">
                        <!-- SECTION 1: TRAINING DETAILS -->
                        <div class="step7-card">
                            <div class="step7-card-header">
                                <span class="step7-card-title">Training Details</span>
                            </div>
                            <div id="trainingRowsContainer">
                                <div class="step7-grid">
                                    <div>
                                        <label>Topic of Training</label>
                                        <input name="training_name[]" placeholder="Topic" />
                                    </div>
                                    <div>
                                        <label>Organized By</label>
                                        <input name="training_from[]" placeholder="Institution" />
                                    </div>
                                    <div>
                                        <label>Duration (Days)</label>
                                        <input type="number" name="training_duration[]" placeholder="Days" />
                                    </div>
                                    <div>
                                        <label>Executed in Year</label>
                                        <select name="training_year[]">
                                            <option value="">Year</option>
                                            @for(int y = DateTime.Now.Year; y >= 1970; y--) { <option>@y</option> }
                                        </select>
                                    </div>
                                    <div>
                                        <label>Proof of Training</label>
                                        <input type="file" name="training_proof[]" accept=".pdf,.jpg,.jpeg,.png" onchange="validateFileUpload(this)" />
                                        <div class="file-validation-hint" style="font-size: 0.72rem; color: var(--muted);">Image 2MB | PDF 10MB</div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-ghost" onclick="addTrainingRow()">+ Add Training</button>
                        </div>

                        <!-- SECTION 2: CERTIFICATION DETAILS -->
                        <div class="step7-card">
                            <div class="step7-card-header">
                                <span class="step7-card-title">Certification Details</span>
                            </div>
                            <div id="certificationRowsContainer">
                                <div class="step7-grid">
                                    <div>
                                        <label>Name of Certification</label>
                                        <input name="training_name[]" placeholder="Certification Name" />
                                    </div>
                                    <div>
                                        <label>Issuing Authority</label>
                                        <input name="training_from[]" placeholder="Institution" />
                                    </div>
                                    <div>
                                        <label>Validity Status</label>
                                        <select name="training_duration[]">
                                            <option value="">Select</option>
                                            <option>Valid</option>
                                            <option>Expired</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label>Conducted in Year</label>
                                        <select name="training_year[]">
                                            <option value="">Year</option>
                                            @for(int y = DateTime.Now.Year; y >= 1970; y--) { <option>@y</option> }
                                        </select>
                                    </div>
                                    <div>
                                        <label>Proof of Certificate</label>
                                        <input type="file" name="training_proof[]" accept=".pdf,.jpg,.jpeg,.png" onchange="validateFileUpload(this)" />
                                        <div class="file-validation-hint" style="font-size: 0.72rem; color: var(--muted);">Image 2MB | PDF 10MB</div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-ghost" onclick="addCertificationRow()">+ Add Certification</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 8: MEMBERSHIP (LABLED AS 9 IN UI) -->
            <div class="form-section hide" id="step-8">
                <div class="section-header"><h2>Step 8: Membership in Professional Bodies</h2></div>
                <div class="section-content">
                    <div class="membership-header-grid">
                        <span>S.No</span>
                        <span>Institution / Association / Body</span>
                        <span>Position Held</span>
                        <span>Status</span>
                        <span>From Year</span>
                        <span>To Year</span>
                        <span>Proof</span>
                    </div>
                    <div class="membership-container" id="membershipContainer">
                        <div class="membership-row">
                            <div class="membership-grid-7">
                                <div class="membership-serial" style="font-weight: 700; color: var(--accent);">1</div>
                                
                                <div>
                                    <label>Institution / Association / Body</label>
                                    <input name="membership_name[]" placeholder="Enter institution name" />
                                </div>
                                
                                <div>
                                    <label>Position Held</label>
                                    <input name="membership_from[]" placeholder="Enter position held" />
                                </div>
                                
                                <div>
                                    <label>Validity Status</label>
                                    <select class="membership-status-val" onchange="toggleMembershipYears(this)">
                                        <option value="Active">Active</option>
                                        <option value="Expired">Expired</option>
                                    </select>
                                    <input type="hidden" name="membership_duration[]" class="membership-duration-hidden" value="Active" />
                                </div>
                                
                                <div class="membership-year-cell">
                                    <label>From Year</label>
                                    <select name="membership_year[]">
                                        <option value="">Year</option>
                                        @for(int y = DateTime.Now.Year; y >= 1970; y--) { <option>@y</option> }
                                    </select>
                                </div>
                                
                                <div class="membership-year-cell">
                                    <label>To Year</label>
                                    <select class="membership-to-year-val" onchange="syncMembershipDuration(this)">
                                        <option value="">Year</option>
                                        <option value="Present">Present</option>
                                        @for(int y = DateTime.Now.Year; y >= 1970; y--) { <option>@y</option> }
                                    </select>
                                </div>
                                
                                <div class="membership-file-wrap">
                                    <label>Proof of Membership</label>
                                    <input type="file" name="membership_proof[]" accept=".pdf,.jpg,.jpeg,.png" onchange="validateFileUpload(this)" />
                                    <div class="file-validation-hint" style="font-size: 0.72rem; color: var(--muted);">Image 2MB | PDF 10MB</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <button type="button" class="btn btn-ghost" style="margin-top: 24px;" onclick="addMembershipRow()">+ Add Membership</button>
                </div>
            </div>

