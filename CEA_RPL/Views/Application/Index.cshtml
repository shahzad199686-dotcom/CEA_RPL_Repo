    function calculateTotalFee() {
        const categories = document.querySelectorAll('input[name="cert_category[]"]:checked');
        const breakdown = document.getElementById('feeBreakdownLines');
        const discountSection = document.getElementById('discountSection');
        const discountLabel = document.getElementById('discountLabel');
        const discountAmount = document.getElementById('discountAmount');
        const subtotalDisplay = document.getElementById('subtotalDisplay');
        const gstDisplay = document.getElementById('gstDisplay');
        const totalFeeDisplay = document.getElementById('totalFeeDisplay');
        const amountInput = document.getElementById('payment_amount');

        let cat1Count = 0;
        let subtotal = 0;
        const cat1BasePrice = 21000;
        const cat23Price = 16000;

        if (breakdown) breakdown.innerHTML = '';

        categories.forEach(cat => {
            let price = 0;
            if (cat.value.includes('Category 1')) {
                cat1Count++;
                price = cat1BasePrice;
            } else {
                price = cat23Price;
            }
            
            subtotal += price;

            if (breakdown) {
                const line = document.createElement('div');
                line.className = 'fee-item';
                line.innerHTML = `<span>✓ ${cat.value}</span><span>₹${price.toLocaleString('en-IN')}</span>`;
                breakdown.appendChild(line);
            }
        });

        // Bundle Discount Logic (Only for Category 1 sub-types: 1A, 1B, 1C, 1D)
        let discountPercent = 0;
        if (cat1Count === 2) discountPercent = 10;
        else if (cat1Count === 3) discountPercent = 15;
        else if (cat1Count === 4) discountPercent = 20;

        let discountValue = 0;
        if (discountPercent > 0) {
            discountValue = (cat1Count * cat1BasePrice) * (discountPercent / 100);
            subtotal -= discountValue;
            
            if (discountSection) {
                discountSection.style.display = 'block';
                discountLabel.textContent = `Applicable Fee Rebate (${discountPercent}%)`;
                discountAmount.textContent = `- ₹${discountValue.toLocaleString('en-IN')}`;
            }
        } else {
            if (discountSection) discountSection.style.display = 'none';
        }

        const gst = subtotal * 0.18;
        const finalTotal = subtotal + gst;

        if (subtotalDisplay) subtotalDisplay.textContent = `₹${subtotal.toLocaleString('en-IN')}`;
        if (gstDisplay) gstDisplay.textContent = `₹${gst.toLocaleString('en-IN')}`;
        if (totalFeeDisplay) totalFeeDisplay.textContent = `₹${finalTotal.toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
        if (amountInput) amountInput.value = finalTotal.toFixed(2);

        if (categories.length === 0 && breakdown) {
            breakdown.innerHTML = '<div class="fee-item"><span>No categories selected</span><span>₹0</span></div>';
        }

        validatePaymentStep();
    }

    function validatePaymentStep() {
        if (currentStep === 13) {
            const utr = document.getElementById('payment_utr').value.trim();
            const date = document.getElementById('payment_date').value;
            const receipt = document.getElementById('payment_receipt').files.length > 0;
            const amount = parseFloat(document.getElementById('payment_amount').value) || 0;

            const nextBtn = document.getElementById('btnNext');
            
            // Payment is valid if all fields are filled AND amount > 0
            const isValid = utr !== '' && date !== '' && receipt && amount > 0;
            
            if (nextBtn) {
                nextBtn.disabled = !isValid;
                nextBtn.style.opacity = isValid ? '1' : '0.5';
                nextBtn.style.cursor = isValid ? 'pointer' : 'not-allowed';
            }
        }
    }

