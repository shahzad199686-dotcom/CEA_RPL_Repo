                                    <ul style="list-style-type: disc; margin-left: 20px; color: #2d3748; line-height: 1.5; font-size: 14px; text-align: left; margin-bottom: 0;">
                                        <li>No disciplinary/vigilance proceedings or criminal case is pending or contemplated against me.</li>
                                        <li>No penalty has been imposed on me which renders me unsuitable for such engagement.</li>
                                        <li>The information furnished by me is true and correct to the best of my knowledge.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="col-12" id="decl-card-general">
                            <div style="display: flex; align-items: flex-start; gap: 8px;">
                                <div style="padding-top: 12px; flex-shrink: 0;">
                                    <input type="checkbox" name="declaration_consent_1" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
                                </div>
                                <div class="declaration-statement" style="flex: 1; padding: 12px 16px; background: #f8fafc; border-radius: 12px; border: 1px solid var(--line); margin-bottom: 0; text-align: left;">
                                    <p style="font-weight: 700; color: var(--ink); margin-bottom: 4px; text-align: left; line-height: 1.2;">I hereby declare that:</p>
                                    <ul style="list-style-type: disc; margin-left: 20px; color: #2d3748; line-height: 1.5; font-size: 14px; text-align: left; margin-bottom: 0;">
                                        <li>All information provided in this application is true and correct to the best of my knowledge.</li>
                                        <li>I am not engaged in any activity or employment that may create a conflict of interest.</li>
                                        <li>I agree to abide by the Code of Conduct of EADA and Environment Audit Rules, 2025.</li>
                                        <li>I understand that any false information may lead to disqualification of application or revocation of certification.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="grid">
                        <div class="col-6"><label>Candidate Name <span class="req">*</span></label><input type="text" name="decl_name" required placeholder="Type Candidate Name" class="title-case-input" /></div>
                        <div class="col-6"><label>Place</label><input type="text" name="decl_place" placeholder="City" /></div>
                        <div class="col-6"><label>Date <span class="req">*</span></label><input type="text" name="decl_date" id="declaration_date" required readonly style="background-color: #f8fafc; cursor: not-allowed; color: var(--muted);" /></div>
                        <div class="col-6">
                            <label>Signature File (Upload Image) <span class="req">*</span></label>
                            <div class="upload-container">
                                <input type="file" name="signature_file" accept=".jpg,.jpeg,.png" required onchange="validateFileUpload(this)" />
                            </div>
                            <div class="file-validation-hint" style="font-size: 0.72rem; color: var(--muted); margin-top: 4px;">JPG, PNG 500KB</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 15: REVIEW & SUBMIT -->
            <div class="form-section hide" id="step-15">
                <div class="section-header"><h2>Step 15: Preview & Submit</h2></div>
                <div class="section-content">
                    <!-- 1. Real-time Review Summary -->
                    <div id="reviewSummary" class="review-grid">
                        <!-- Populated by JS -->
                    </div>

                    <!-- 2. Document Confirmation Checklist -->
                    <div class="review-section" style="margin-top: 32px; border: none; box-shadow: none; padding: 0; background: transparent;">
                        <h4 style="margin-bottom: 8px; color: var(--ink);">Document Upload Confirmation</h4>
                        <p class="hint" style="margin-bottom: 20px;">Please confirm that you have uploaded the following documents in their respective sections.</p>
                        
                        <div class="checklist-container" style="background: #fff; border: 1px solid var(--line); border-radius: var(--radius-md); overflow: hidden; padding: 1px;">
                            <table class="checklist-table">
                                <thead>
                                    <tr>
                                        <th style="text-align: left; padding-left: 20px;">Document Type</th>
                                        <th style="text-align: left; width: 140px;">Mandatory</th>
                                        <th style="text-align: center; width: 100px;">Confirmed</th>
                                    </tr>
                                </thead>
                                <tbody id="checklistBody">
                                    <tr><td style="padding-left: 20px;">Applicant Photograph</td><td>Yes</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Photograph"></td></tr>
                                    <tr><td style="padding-left: 20px;">Identity Proof (Government ID/Employee ID)</td><td>Yes</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Gov ID"></td></tr>
                                    <tr><td style="padding-left: 20px;">Step 3: Degree Certificates / Marksheets</td><td>Yes</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Degree"></td></tr>
                                    <tr><td style="padding-left: 20px;">Step 4: Experience Certificates / Proof</td><td>Yes</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Experience"></td></tr>
                                    <tr><td style="padding-left: 20px;">Step 6: Environmental Audit Reports</td><td>Yes</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Reports"></td></tr>
                                    <tr><td style="padding-left: 20px;">Step 13: Payment Receipt / UTR Proof</td><td>Yes</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Payment"></td></tr>
                                    <tr><td style="padding-left: 20px;">Details of Certification / Training</td><td>Optional</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Training"></td></tr>
                                    <tr><td style="padding-left: 20px;">Details of Membership in Professional Bodies</td><td>Optional</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Membership"></td></tr>
                                    <tr><td style="padding-left: 20px;">Details of Paper Published / Presented</td><td>Optional</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Publications"></td></tr>
                                    <tr><td style="padding-left: 20px;">Details of Awards / Recognitions</td><td>Optional</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Awards"></td></tr>
                                    <tr><td style="padding-left: 20px;">Details of Software / Tools</td><td>Optional</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Software"></td></tr>
                                    <tr><td style="padding-left: 20px;">Any Additional Enclosure</td><td>Optional</td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Extra"></td></tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <div id="checklistError" style="margin-top: 12px; color: #c53030; font-size: 0.85rem; display: none; font-weight: 600;">
                            ⚠️ Please confirm all mandatory documents are uploaded before submitting.
                        </div>

                        <div class="submit-actions-wrap" style="margin-top: 32px; display: flex; flex-direction: column; align-items: flex-end; gap: 16px;">
                            <div style="display: flex; gap: 12px; justify-content: flex-end; align-items: center;">
                                <button type="button" class="btn btn-ghost" style="padding: 10px 24px; font-size: 0.9rem;" onclick="clearChecklist()">Clear</button>
                                <button id="submitFinalApplicationBtn" type="button" class="btn" style="background: #0E5A3C; color: white; padding: 10px 32px; font-size: 0.9rem; border-radius: 8px;" disabled>Submit Application</button>
                            </div>
                            <p style="color: var(--muted); font-size: 0.85rem; text-align: left; max-width: 100%; margin: 0; line-height: 1.5;">
                                By submitting, you consent to EADA verifying your credentials and contacting you via email/SMS/portal notifications.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </form>
        }
    </main>
</div>

@if (!isSubmitted)
{
<!-- Sticky Bottom Action Bar -->
<div class="action-bar">
    <div class="action-inner">
        <div class="save-status-wrap">
            <button type="button" id="btnPrev" class="btn btn-ghost" onclick="prevStep()">Previous Step</button>
            <span id="saveStatus" class="save-status-text">Draft automatically saved</span>
        </div>
        <div style="display: flex; gap: 12px; align-items: center;">
            <button type="button" id="btnSaveDraft" class="btn btn-ghost" onclick="saveDraft()">Save Draft</button>
            <button type="button" id="btnNext" class="btn btn-primary" onclick="nextStep()" style="background: #0E5A3C; color: white; border: none; box-shadow: 0 4px 12px rgba(14, 90, 60, 0.3); border-radius: 8px;">Next Section</button>
        </div>
    </div>
</div>

<!-- Resume Draft Prompt Overlay -->
<div id="resumeOverlay" class="resume-overlay hide">
    <div class="resume-card">
        <div class="resume-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <h3>Resume Application?</h3>
        <p id="resumePromptText">We found an incomplete application from your last session. Would you like to continue where you left off or start a new application?</p>
        <div class="resume-actions">
            <button type="button" id="btnResume" class="btn btn-primary" onclick="confirmResume()">Resume Application</button>
            <button type="button" class="btn btn-ghost" onclick="startNew()">Start New</button>
        </div>
    </div>
</div>
}

<script>
    let currentStep = 1;
    let maxReachedStep = 1; 
    const totalSteps = 15;
    let isFaceApiLoaded = false;

    // --- FACE API INITIALIZATION ---
    async function loadFaceApiModels() {
        try {
            await faceapi.nets.tinyFaceDetector.loadFromUri('/models');
            isFaceApiLoaded = true;
            console.log("Face-api models loaded successfully.");
        } catch (e) {
            console.error("Error loading face-api models:", e);
        }
    }
    
    document.addEventListener('DOMContentLoaded', loadFaceApiModels);

    // Helper to set field value safely (used by Resume logic)
    const setVal = (name, val) => {
        if (val === null || val === undefined) return;
        const form = document.getElementById('applicationForm');
        if (!form) return;
        const input = form.querySelector(`[name="${name}"]`);
        if (input) {
            if (input.type === 'checkbox') input.checked = !!val;
            else if (input.type === 'radio') {
                const radio = form.querySelector(`[name="${name}"][value="${val}"]`);
                if (radio) radio.checked = true;
            } else input.value = val;
            
            // Trigger change for fields with dynamic logic (like Gov ID)
            input.dispatchEvent(new Event('change'));
        }
    };
    const stepNames = [
        "Applicant Details",
        "Category of Certification Applied For",
        "Educational Qualifications",
        "Professional Experience",
        "Project Experience",
        "Upload Reports",
        "Details of Certification / Training",
        "Membership in Professional Bodies",
        "Paper Published / Presented",
        "Awards / Recognition",
        "Software / Tools / Application Skills",
        "Other Relevant Enclosures",
        "Payment Details",
        "Declaration by Applicant",
        "Preview & Submit"
    ];

    function updateUI() {
        // Force sequential redirect if user tries to bypass
        if (currentStep > maxReachedStep + 1) currentStep = maxReachedStep + 1;

        // Update Gov Stepper Phases
        document.querySelectorAll('.step-item').forEach(phase => phase.classList.remove('active', 'completed'));
        if (currentStep >= 1 && currentStep <= 4) document.getElementById('phase-A')?.classList.add('active');
        if (currentStep > 4) document.getElementById('phase-A')?.classList.add('completed');
        if (currentStep >= 5 && currentStep <= 8) document.getElementById('phase-B')?.classList.add('active');
        if (currentStep > 8) document.getElementById('phase-B')?.classList.add('completed');
        if (currentStep >= 9 && currentStep <= 12) document.getElementById('phase-C')?.classList.add('active');
        if (currentStep > 12) document.getElementById('phase-C')?.classList.add('completed');
        if (currentStep >= 13 && currentStep <= 15) document.getElementById('phase-D')?.classList.add('active');

        // Calculate current group/phase info
        let groupName = "";
        let stepInGroup = 0;
        let totalInGroup = 0;
        if (currentStep >= 1 && currentStep <= 4) {
            groupName = "Personal & Identity";
            stepInGroup = currentStep;
            totalInGroup = 4;
        } else if (currentStep >= 5 && currentStep <= 8) {
            groupName = "Qualifications";
            stepInGroup = currentStep - 4;
            totalInGroup = 4;
        } else if (currentStep >= 9 && currentStep <= 12) {
            groupName = "Experience & Projects";
            stepInGroup = currentStep - 8;
            totalInGroup = 4;
        } else if (currentStep >= 13 && currentStep <= 15) {
            groupName = "Documents & Review";
            stepInGroup = currentStep - 12;
            totalInGroup = 3;
        }

        // Update Sub Stepper UI
        const subStepCircles = document.getElementById('subStepCircles');
        const currentSubStepTitle = document.getElementById('currentSubStepTitle');
        const currentPhaseDisplay = document.getElementById('currentPhaseDisplay');
        const currentStepDisplay = document.getElementById('currentStepDisplay');
        
        if (subStepCircles) {
            let circlesHtml = "";
            for (let i = 1; i <= totalInGroup; i++) {
                let statusClass = "";
                if (i < stepInGroup) statusClass = "completed";
                else if (i === stepInGroup) statusClass = "active";
                circlesHtml += `<div class="sub-circle ${statusClass}">${i < stepInGroup ? '✓' : i}</div>`;
            }
            subStepCircles.innerHTML = circlesHtml;
        }
        
        if (currentSubStepTitle) {
            currentSubStepTitle.textContent = stepNames[currentStep - 1];
        }
        
        if (currentStepDisplay) {
            currentStepDisplay.textContent = currentStep;
        }



        // Toggle Sections
        document.querySelectorAll('.form-section').forEach((sec, idx) => {
            const stepNum = idx + 1;
            if (stepNum === currentStep) {
                sec.classList.remove('hide');
                sec.classList.add('active');
            } else {
                sec.classList.add('hide');
                sec.classList.remove('active');
            }
        });

        // Update Sidebar items
        document.querySelectorAll('.nav-item').forEach((item, idx) => {
            const stepNum = idx + 1;
            item.classList.toggle('active', stepNum === currentStep);
            
            if (stepNum <= maxReachedStep) {
                item.classList.add('completed');
                item.classList.remove('locked');
            } else if (stepNum === maxReachedStep + 1) {
                item.classList.remove('locked', 'completed');
            } else {
                item.classList.add('locked');
                item.classList.remove('completed');
            }
        });

        // Progress
        // Old progress bar logic removed
        
        // Buttons
        document.getElementById('btnPrev').style.visibility = (currentStep === 1) ? 'hidden' : 'visible';
        
        // Final Submit Logic
        const nextBtn = document.getElementById('btnNext');
        if (currentStep === totalSteps) {
            nextBtn.style.display = 'none';
