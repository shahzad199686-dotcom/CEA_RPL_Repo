@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>CEA RPL Application – Modern Portal</title>
    <link rel="stylesheet" href="~/css/index.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div id="toast-container"></div>

<!-- Top Progress Header -->
<header class="top-progress">
    <div class="progress-info">
        <h3>Application Progress</h3>
        <p>Step <span id="currentStepDisplay">1</span> of 15: <span id="currentStepName">Applicant Details</span></p>
    </div>
    <div class="progress-bar-wrap">
        <div class="progress-bar">
            <div class="progress-bar-fill" id="progressBarFill" style="width: 6.67%;"></div>
        </div>
    </div>
    <div class="profile-section">
        <div class="profile-trigger">
            <div class="profile-avatar">
                @{
                    var displayName = ViewBag.UserName as string ?? "User";
                    var initials = "";
                    if (!string.IsNullOrEmpty(displayName))
                    {
                        var words = displayName.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
                        if (words.Length >= 2) {
                            initials = (words[0][0].ToString() + words[1][0].ToString()).ToUpper();
                        } else if (words[0].Length >= 2) {
                            initials = words[0].Substring(0, 2).ToUpper();
                        } else {
                            initials = words[0][0].ToString().ToUpper();
                        }
                    }
                }
                @initials
            </div>
            <span>Welcome, @displayName</span>
        </div>
        <div class="profile-dropdown">
            <a href="#" class="dropdown-item">My Profile</a>
            <a href="#" class="dropdown-item">My Applications</a>
            <hr style="border: 0; border-top: 1px solid var(--line); margin: 4px 0;">
            <a href="/Auth/Logout" class="dropdown-item logout">Sign Out</a>
        </div>
    </div>
</header>

<div class="application-wrap">
    <!-- Sidebar Navigation -->
    <aside class="sidebar-nav" id="sidebarNav">
        <a href="#step-1" class="nav-item active" data-step="1"><span class="nav-num">01</span><span class="nav-text">Applicant Details</span></a>
        <a href="#step-2" class="nav-item locked" data-step="2"><span class="nav-num">02</span><span class="nav-text">Category Selection</span></a>
        <a href="#step-3" class="nav-item locked" data-step="3"><span class="nav-num">03</span><span class="nav-text">Education</span></a>
        <a href="#step-4" class="nav-item locked" data-step="4"><span class="nav-num">04</span><span class="nav-text">Work Experience</span></a>
        <a href="#step-5" class="nav-item locked" data-step="5"><span class="nav-num">05</span><span class="nav-text">Project Experience</span></a>
        <a href="#step-6" class="nav-item locked" data-step="6"><span class="nav-num">06</span><span class="nav-text">Upload Reports</span></a>
        <a href="#step-7" class="nav-item locked" data-step="7"><span class="nav-num">07</span><span class="nav-text">Training/Cert.</span></a>
        <a href="#step-8" class="nav-item locked" data-step="8"><span class="nav-num">08</span><span class="nav-text">Membership</span></a>
        <a href="#step-9" class="nav-item locked" data-step="9"><span class="nav-num">09</span><span class="nav-text">Publications</span></a>
        <a href="#step-10" class="nav-item locked" data-step="10"><span class="nav-num">10</span><span class="nav-text">Awards</span></a>
        <a href="#step-11" class="nav-item locked" data-step="11"><span class="nav-num">11</span><span class="nav-text">Software Skills</span></a>
        <a href="#step-12" class="nav-item locked" data-step="12"><span class="nav-num">12</span><span class="nav-text">Other Enclosures</span></a>
        <a href="#step-13" class="nav-item locked" data-step="13"><span class="nav-num">13</span><span class="nav-text">Payment Details</span></a>
        <a href="#step-14" class="nav-item locked" data-step="14"><span class="nav-num">14</span><span class="nav-text">Declaration</span></a>
        <a href="#step-15" class="nav-item locked" data-step="15"><span class="nav-num">15</span><span class="nav-text">Review & Submit</span></a>
    </aside>

    <!-- Main Content -->
    <main class="form-content">
        <form id="rplForm" novalidate>
            
            <!-- STEP 1: APPLICANT DETAILS -->
            <div class="form-section active" id="step-1">
                <div class="section-header"><h2>Step 1: Applicant Details</h2><span class="section-status">Active</span></div>
                <div class="section-content">
                    <div class="grid">
                        <div class="col-6"><label>Full Name <span class="req">*</span></label><input name="full_name" type="text" required placeholder="As per ID proof" /></div>
                        <div class="col-6"><label>Father’s / Mother’s Name</label><input name="parent_name" type="text" placeholder="Optional" /></div>
                        <div class="col-4"><label>Date of Birth <span class="req">*</span></label><input name="dob" type="date" required /></div>
                        <div class="col-4"><label>Gender</label><select name="gender"><option value="">Select</option><option>Male</option><option>Female</option><option>Other</option></select></div>
                        <div class="col-4"><label>Citizenship <span class="req">*</span></label><select name="citizenship" required><option value="">Select</option><option>Indian</option></select></div>
                        <div class="col-4">
                            <label>Applicant Photograph <span class="req">*</span></label>
                            <input type="file" name="applicant_photo" accept=".jpg,.jpeg,.png" required onchange="previewPhoto(event)" />
                            <div style="margin-top: 12px; display: flex; justify-content: center;">
                                <img id="photoPreview" src="" alt="" style="display:none; width:120px; height:150px; border:2px solid var(--line); border-radius: var(--radius-sm); object-fit: cover;" />
                            </div>
                        </div>
                        <div class="col-8">
                            <div class="grid">
                                <div class="col-12"><label>Permanent Address <span class="req">*</span></label><textarea name="address_perm" required placeholder="Include City, State, ZIP"></textarea></div>
                                <div class="col-12"><label>Correspondence Address</label><textarea name="address_corr" placeholder="Leave blank if same as permanent"></textarea></div>
                            </div>
                        </div>
                        <div class="col-4"><label>Email ID <span class="req">*</span></label><input name="email" type="email" required /></div>
                        <div class="col-4"><label>Mobile Number <span class="req">*</span></label><input name="mobile" type="text" inputmode="numeric" required placeholder="10-digit number" /></div>
                        <div class="col-4"><label>Alternate Number</label><input name="alt_mobile" type="text" inputmode="numeric" /></div>
                        <div class="col-6"><label>Government ID Type <span class="req">*</span></label><select id="govIdType" name="gov_id_type" required onchange="toggleGovIdUpload()"><option value="">Select</option><option value="aadhaar">Aadhaar</option><option value="pan">PAN</option><option value="passport">Passport</option></select></div>
                        <div class="col-6"><label id="govIdLabel">ID Number <span class="req">*</span></label><input id="govIdNumber" name="gov_id_number" type="text" required /></div>
                        <div class="col-12"><label>Upload ID Proof <span class="req">*</span></label><input id="govIdUpload" name="gov_id_upload" type="file" accept=".jpg,.jpeg,.png,.pdf" required /><span class="hint">JPG/PNG/PDF, max 2MB</span></div>
                    </div>
                </div>
            </div>

            <!-- STEP 2: CATEGORY SELECTION -->
            <div class="form-section hide" id="step-2">
                <div class="section-header"><h2>Step 2: Category of Certification</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <div class="alert"><strong>Note:</strong> You may choose multiple categories. Certification fees apply per category.</div>
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <label class="cat-label"><input type="checkbox" name="cert_category[]" value="Category 1"><div><strong>Category 1: Environment Auditing / Assessment</strong><small>EPA Act, Air/Water Act, Waste Management, CRZ Regulation, Eco-mark, etc.</small></div></label>
                        <label class="cat-label"><input type="checkbox" name="cert_category[]" value="Category 2"><div><strong>Category 2: Sustainability or ESG Audit</strong><small>SEBI Act, ESG / Sustainability / SEBI BRSR compliance.</small></div></label>
                        <label class="cat-label"><input type="checkbox" name="cert_category[]" value="Category 3"><div><strong>Category 3: Forest Conservation Audit</strong><small>Forest Conservation Act / Van Sanrakshan evam Samvardhan Adhiniyam.</small></div></label>
                        <label class="cat-label"><input type="checkbox" name="cert_category[]" value="Category 4"><div><strong>Category 4: Wildlife Protection Audit</strong><small>Wildlife Protection Act compliance and verification.</small></div></label>
                    </div>
                </div>
            </div>

            <!-- STEP 3: EDUCATIONAL QUALIFICATIONS -->
            <div class="form-section hide" id="step-3">
                <div class="section-header"><h2>Step 3: Educational Qualifications</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="educationTable">
                        <thead><tr><th>Degree/Diploma</th><th>Discipline</th><th>Institution</th><th>Year</th></tr></thead>
                        <tbody><tr><td><input name="edu_degree[]" required /></td><td><input name="edu_discipline[]" required /></td><td><input name="edu_institution[]" required /></td><td><input type="number" name="edu_year[]" required /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('educationTable')">+ Add Degree</button>
                </div>
            </div>

            <!-- STEP 4: PROFESSIONAL EXPERIENCE -->
            <div class="form-section hide" id="step-4">
                <div class="section-header"><h2>Step 4: Professional Experience</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <div class="grid" style="margin-bottom: 24px;"><div class="col-6"><label>Total Experience (Years) <span class="req">*</span></label><input name="total_experience" type="text" required placeholder="e.g. 5.5" /></div></div>
                    <table class="modern-table" id="experienceTable">
                        <thead><tr><th>Organization</th><th>Designation</th><th>Duration</th><th>Nature of Work</th></tr></thead>
                        <tbody><tr><td><input name="exp_org[]" required /></td><td><input name="exp_designation[]" required /></td><td><input name="exp_duration[]" required /></td><td><input name="exp_nature[]" required /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('experienceTable')">+ Add Experience</button>
                    <div class="grid" style="margin-top: 24px;">
                        <div class="col-6"><label>Ref Name</label><input name="ref2_name[]" /></div>
                        <div class="col-6"><label>Ref Phone</label><input name="ref2_phone[]" /></div>
                    </div>
                </div>
            </div>

            <!-- STEP 5: PROJECT EXPERIENCE (CAT 1) -->
            <div class="form-section hide" id="step-5">
                <div class="section-header"><h2>Step 5: Project Experience (Category 1)</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="cat1Projects">
                        <thead><tr><th>Project Name</th><th>Client</th><th>Location</th><th>Year</th><th>Role</th></tr></thead>
                        <tbody><tr><td><input name="project_name_cat1[]" /></td><td><input name="project_client_cat1[]" /></td><td><input name="project_location_cat1[]" /></td><td><input type="number" name="project_year_cat1[]" /></td><td><input name="project_role_cat1[]" /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('cat1Projects')">+ Add Project</button>
                </div>
            </div>

            <!-- STEP 6: UPLOAD REPORTS -->
            <div class="form-section hide" id="step-6">
                <div class="section-header"><h2>Step 6: Upload Audit Reports</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <div class="alert">Upload PDF reports of recent audits (Max 2MB each).</div>
                    <div class="grid">
                        <div class="col-6"><label>Report 1 <span class="req">*</span></label><input type="file" name="audit_report" accept=".pdf" required /></div>
                        <div class="col-6"><label>Report 2 <span class="req">*</span></label><input type="file" name="audit_report" accept=".pdf" required /></div>
                    </div>
                </div>
            </div>

            <!-- STEP 7: TRAINING / CERTIFICATION -->
            <div class="form-section hide" id="step-7">
                <div class="section-header"><h2>Step 7: Details of Certification / Training</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="trainingTable">
                        <thead><tr><th>Training Name</th><th>Institution</th><th>Duration</th><th>Year</th></tr></thead>
                        <tbody><tr><td><input name="training_name[]" /></td><td><input name="training_from[]" /></td><td><input name="training_duration[]" /></td><td><input type="number" name="training_year[]" /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('trainingTable')">+ Add Training</button>
                </div>
            </div>

            <!-- STEP 8: MEMBERSHIP -->
            <div class="form-section hide" id="step-8">
                <div class="section-header"><h2>Step 8: Membership in Professional Bodies</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="membershipTable">
                        <thead><tr><th>Body/Society</th><th>From (Year)</th><th>Duration</th></tr></thead>
                        <tbody><tr><td><input name="membership_name[]" /></td><td><input type="number" name="membership_year[]" /></td><td><input name="membership_duration[]" /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('membershipTable')">+ Add Membership</button>
                </div>
            </div>

            <!-- STEP 9: PUBLICATIONS -->
            <div class="form-section hide" id="step-9">
                <div class="section-header"><h2>Step 9: Paper Published / Presented</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="paperTable">
                        <thead><tr><th>Paper Title</th><th>Place/Journal</th><th>Year</th><th>Role</th></tr></thead>
                        <tbody><tr><td><input name="paper_name[]" /></td><td><input name="paper_place[]" /></td><td><input type="number" name="paper_year[]" /></td><td><input name="paper_role[]" /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('paperTable')">+ Add Paper</button>
                </div>
            </div>

            <!-- STEP 10: AWARDS -->
            <div class="form-section hide" id="step-10">
                <div class="section-header"><h2>Step 10: Awards / Recognition</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="awardTable">
                        <thead><tr><th>Award/Recognition</th><th>From</th><th>Year</th></tr></thead>
                        <tbody><tr><td><input name="award_name[]" /></td><td><input name="award_from[]" /></td><td><input type="number" name="award_year[]" /></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('awardTable')">+ Add Award</button>
                </div>
            </div>

            <!-- STEP 11: SOFTWARE SKILLS -->
            <div class="form-section hide" id="step-11">
                <div class="section-header"><h2>Step 11: Software Skills</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <table class="modern-table" id="softwareTable">
                        <thead><tr><th>Software Skill</th><th>Proficiency</th></tr></thead>
                        <tbody><tr><td><input name="software_skill[]" /></td><td><select name="proficiency_level[]"><option>Basic</option><option>Intermediate</option><option>Expert</option></select></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" onclick="addGenericRow('softwareTable')">+ Add Skill</button>
                </div>
            </div>

            <!-- STEP 12: OTHER ENCLOSURES -->
            <div class="form-section hide" id="step-12">
                <div class="section-header"><h2>Step 12: Other Relevant Enclosures</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <label>Upload additional supporting documents (if any)</label>
                    <input type="file" name="other_enclosure" accept=".pdf,.zip,.rar" />
                    <span class="hint">PDF/ZIP/RAR, max 5MB</span>
                </div>
            </div>

            <!-- STEP 13: PAYMENT DETAILS -->
            <div class="form-section hide" id="step-13">
                <div class="section-header"><h2>Step 13: Payment Details</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <div class="grid">
                        <div class="col-4"><label>Amount Paid <span class="req">*</span></label><input name="payment_amount" type="number" step="0.01" required /></div>
                        <div class="col-4"><label>Payment Date <span class="req">*</span></label><input name="payment_date" type="date" required /></div>
                        <div class="col-4"><label>UTR / Transaction ID <span class="req">*</span></label><input name="payment_utr" type="text" required /></div>
                        <div class="col-12"><label>Upload Payment Receipt <span class="req">*</span></label><input name="payment_receipt" type="file" accept=".pdf,.jpg,.png" required /></div>
                    </div>
                </div>
            </div>

            <!-- STEP 14: DECLARATION -->
            <div class="form-section hide" id="step-14">
                <div class="section-header"><h2>Step 14: Declaration by Applicant</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <div class="alert alert-info">I hereby certify that the information given in this application is true and correct to the best of my knowledge and belief.</div>
                    <div class="grid">
                        <div class="col-6"><label>Full Name as Signature <span class="req">*</span></label><input type="text" name="decl_name" required placeholder="Type your full name" /></div>
                        <div class="col-6"><label>Place</label><input type="text" name="decl_place" placeholder="City" /></div>
                        <div class="col-6"><label>Date <span class="req">*</span></label><input type="date" name="decl_date" required /></div>
                        <div class="col-6"><label>Signature File (Upload Image) <span class="req">*</span></label><input type="file" name="Any_other_doc" accept=".jpg,.jpeg,.png" required /></div>
                    </div>
                </div>
            </div>

            <!-- STEP 15: REVIEW & SUBMIT -->
            <div class="form-section hide" id="step-15">
                <div class="section-header"><h2>Step 15: Review & Submit</h2><span class="section-status">Pending</span></div>
                <div class="section-content">
                    <!-- 1. Real-time Review Summary -->
                    <div id="reviewSummary" class="review-grid">
                        <!-- Populated by JS -->
                    </div>

                    <!-- 2. Document Confirmation Checklist -->
                    <div class="review-section" style="margin-top: 32px;">
                        <h4>Document Upload Confirmation</h4>
                        <p class="hint" style="margin-bottom: 16px;">Please confirm that you have uploaded the following documents in their respective sections.</p>
                        <table class="checklist-table">
                            <thead>
                                <tr><th>Document Type</th><th>Mandatory</th><th style="width: 80px; text-align: center;">Confirmed</th></tr>
                            </thead>
                            <tbody id="checklistBody">
                                <tr><td>Applicant Photograph</td><td><span class="status-tag status-yes">Yes</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Photograph"></td></tr>
                                <tr><td>Government ID Proof (Aadhaar/PAN/Passport)</td><td><span class="status-tag status-yes">Yes</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Gov ID"></td></tr>
                                <tr><td>Step 3: Degree Certificates / Marksheets</td><td><span class="status-tag status-yes">Yes</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Degree"></td></tr>
                                <tr><td>Step 4: Experience Certificates / Proof</td><td><span class="status-tag status-yes">Yes</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Experience"></td></tr>
                                <tr><td>Step 6: Environmental Audit Reports</td><td><span class="status-tag status-yes">Yes</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Reports"></td></tr>
                                <tr><td>Step 13: Payment Receipt / UTR Proof</td><td><span class="status-tag status-yes">Yes</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb mandatory-cb" data-doc="Payment"></td></tr>
                                <tr><td>Step 7: Training Certificates</td><td><span class="status-tag status-opt">Optional</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Training"></td></tr>
                                <tr><td>Step 8: Professional Membership Proof</td><td><span class="status-tag status-opt">Optional</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Membership"></td></tr>
                                <tr><td>Step 9: Research Publications / Presentations</td><td><span class="status-tag status-opt">Optional</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Publications"></td></tr>
                                <tr><td>Step 10: Awards / Recognitions Proof</td><td><span class="status-tag status-opt">Optional</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Awards"></td></tr>
                                <tr><td>Step 12: Other Relevant Documents</td><td><span class="status-tag status-opt">Optional</span></td><td style="text-align: center;"><input type="checkbox" class="checklist-cb" data-doc="Extra"></td></tr>
                            </tbody>
                        </table>
                        <div id="checklistError">⚠️ Please confirm all mandatory documents are uploaded before submitting.</div>
                    </div>
                    
                    <div style="margin-top: 40px; padding: 24px; border: 2px dashed var(--line); border-radius: var(--radius-lg); text-align: center;">
                        <div class="alert alert-info" style="margin-bottom: 24px; text-align: left;">
                            <strong>Ready to Submit?</strong><br>
                            Clicking "Submit Final Application" will lock your application for review by the administrators.
                        </div>
                        <button type="submit" id="btnSubmitApp" class="btn btn-primary" style="padding: 18px 60px; font-size: 1.1rem; width: 100%; box-shadow: 0 10px 15px -3px rgba(180, 84, 35, 0.3);">Submit Final Application</button>
                    </div>
                </div>
            </div>

        </form>
    </main>
</div>

<!-- Sticky Bottom Action Bar -->
<div class="action-bar">
    <div class="action-inner">
        <button type="button" id="btnPrev" class="btn btn-ghost" onclick="prevStep()">Previous Step</button>
        <div style="display: flex; gap: 12px;">
            <button type="button" class="btn btn-ghost" onclick="saveDraft()">Save Draft</button>
            <button type="button" id="btnNext" class="btn btn-primary" onclick="nextStep()">Next Section</button>
        </div>
    </div>
</div>

<script>
    let currentStep = 1;
    let maxReachedStep = 1; 
    const totalSteps = 15;
    const stepNames = ["Applicant Details", "Category Selection", "Education", "Work Experience", "Project Experience", "Upload Reports", "Training/Cert.", "Membership", "Publications", "Awards", "Software Skills", "Other Enclosures", "Payment Details", "Declaration", "Review & Submit"];

    function updateUI() {
        // Force sequential redirect if user tries to bypass
        if (currentStep > maxReachedStep + 1) currentStep = maxReachedStep + 1;

        // Toggle Sections
        document.querySelectorAll('.form-section').forEach((sec, idx) => {
            const stepNum = idx + 1;
            if (stepNum === currentStep) {
                sec.classList.remove('hide');
                sec.classList.add('active');
                sec.querySelector('.section-status').textContent = 'Active';
            } else {
                sec.classList.add('hide');
                sec.classList.remove('active');
                sec.querySelector('.section-status').textContent = (stepNum <= maxReachedStep) ? 'Completed' : 'Pending';
            }
        });

        // Update Sidebar items
        document.querySelectorAll('.nav-item').forEach((item, idx) => {
            const stepNum = idx + 1;
            item.classList.toggle('active', stepNum === currentStep);
            
            if (stepNum <= maxReachedStep) {
                item.classList.add('completed');
                item.classList.remove('locked');
            } else if (stepNum === maxReachedStep + 1) {
                item.classList.remove('locked', 'completed');
            } else {
                item.classList.add('locked');
                item.classList.remove('completed');
            }
        });

        // Progress
        const progress = (currentStep / totalSteps) * 100;
        const fill = document.getElementById('progressBarFill');
        if (fill) fill.style.width = progress + '%';
        
        document.getElementById('currentStepDisplay').textContent = currentStep;
        document.getElementById('currentStepName').textContent = stepNames[currentStep - 1];

        // Buttons
        document.getElementById('btnPrev').style.visibility = (currentStep === 1) ? 'hidden' : 'visible';
        
        // Final Submit Logic
        const nextBtn = document.getElementById('btnNext');
        if (currentStep === totalSteps) {
            nextBtn.style.display = 'none';
            populateReviewSummary(); // Refresh review data when on last step
        } else {
            nextBtn.style.display = 'inline-block';
            nextBtn.textContent = (currentStep === totalSteps - 1) ? 'Go to Review' : 'Next Section';
        }

        // Scroll
        const activeSec = document.getElementById('step-' + currentStep);
        if (activeSec) {
            window.scrollTo({ top: activeSec.offsetTop - 120, behavior: 'smooth' });
        }
    }

    function validateSection(step) {
        const section = document.getElementById('step-' + step);
        if (!section) return true;

        const inputs = section.querySelectorAll('[required]');
        let firstInvalid = null;
        let valid = true;
        
        section.querySelectorAll('.field-error-pulse').forEach(el => el.classList.remove('field-error-pulse'));

        inputs.forEach(input => {
            let isInvalid = false;
            if (input.type === 'checkbox' || input.type === 'radio') {
                if (!input.checked) isInvalid = true;
            } else {
                if (!input.value || input.value.trim() === '') isInvalid = true;
            }

            if (isInvalid) {
                valid = false;
                input.style.borderColor = 'var(--warn)';
                input.classList.add('field-error-pulse');
                if (!firstInvalid) firstInvalid = input;
            } else {
                input.style.borderColor = '';
            }
        });

        // Step 2 specific check
        if (step === 2) {
            const categories = section.querySelectorAll('input[name="cert_category[]"]:checked');
            if (categories.length === 0) {
                valid = false;
                showToast("Please select at least one certification category.", "error");
                const gridElem = section.querySelector('.alert').nextElementSibling;
                if (!firstInvalid) firstInvalid = gridElem;
                gridElem.classList.add('field-error-pulse');
            }
        }

        if (!valid) {
            showToast("Required fields are missing. Please complete them to proceed.", "error");
            if (firstInvalid) {
                const rect = firstInvalid.getBoundingClientRect();
                const absoluteTop = rect.top + window.pageYOffset;
                window.scrollTo({ top: absoluteTop - 180, behavior: 'smooth' });
                try { firstInvalid.focus({ preventScroll: true }); } catch(e) {}
            }
        }
        return valid;
    }

    function nextStep() {
        if (!validateSection(currentStep)) return;
        if (currentStep < totalSteps) {
            maxReachedStep = Math.max(maxReachedStep, currentStep);
            currentStep++;
            updateUI();
        }
    }

    function prevStep() {
        if (currentStep > 1) {
            currentStep--;
            updateUI();
        }
    }

    function showToast(msg, type = 'info') {
        const container = document.getElementById('toast-container');
        if (!container) return;
        const toast = document.createElement('div');
        toast.className = 'toast ' + type;
        toast.textContent = msg;
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
    }

    function saveDraft() {
        showToast("Progress saved. You can continue later.", "success");
    }

    function addGenericRow(tableId) {
        const tbody = document.querySelector(`#${tableId} tbody`);
        if (!tbody) return;
        const row = tbody.querySelector('tr').cloneNode(true);
        row.querySelectorAll('input, select').forEach(el => el.value = '');
        tbody.appendChild(row);
    }

    function populateReviewSummary() {
        const summary = document.getElementById('reviewSummary');
        if (!summary) return;

        const getData = (name) => document.querySelector(`[name="${name}"]`)?.value || 'N/A';
        const getCheckboxes = (name) => {
            const checked = Array.from(document.querySelectorAll(`input[name="${name}"]:checked`)).map(i => i.value);
            return checked.length > 0 ? checked.join(', ') : 'None selected';
        };

        let html = `
            <div class="review-section">
                <h4>Applicant Information <a href="#" onclick="event.preventDefault(); currentStep=1; updateUI();" style="font-size: 0.7rem; text-decoration: underline;">Edit</a></h4>
                <div class="review-dl">
                    <div><dt>Full Name</dt><dd>${getData('full_name')}</dd></div>
                    <div><dt>Date of Birth</dt><dd>${getData('dob')}</dd></div>
                    <div><dt>Gender</dt><dd>${getData('gender')}</dd></div>
                    <div><dt>Citizenship</dt><dd>${getData('citizenship')}</dd></div>
                    <div><dt>Email</dt><dd>${getData('email')}</dd></div>
                    <div><dt>Mobile</dt><dd>${getData('mobile')}</dd></div>
                    <div><dt>Permanent Address</dt><dd>${getData('address_perm')}</dd></div>
                </div>
            </div>

            <div class="review-section">
                <h4>Certification Categories <a href="#" onclick="event.preventDefault(); currentStep=2; updateUI();" style="font-size: 0.7rem;">Edit</a></h4>
                <div class="review-dl">
                    <div><dt>Selected Categories</dt><dd>${getCheckboxes('cert_category[]')}</dd></div>
                </div>
            </div>

            <div class="review-section">
                <h4>Education Summary <a href="#" onclick="event.preventDefault(); currentStep=3; updateUI();" style="font-size: 0.7rem;">Edit</a></h4>
                <div id="eduSummary">
                    ${Array.from(document.querySelectorAll('#educationTable tbody tr')).map(tr => {
                        const deg = tr.querySelector('[name="edu_degree[]"]')?.value;
                        const inst = tr.querySelector('[name="edu_institution[]"]')?.value;
                        return deg ? `<div style="padding: 8px 0; border-bottom: 1px solid var(--line); font-size: 0.9rem;"><strong>${deg}</strong> from ${inst}</div>` : '';
                    }).join('') || 'No education records added.'}
                </div>
            </div>

            <div class="review-section">
                <h4>Payment Details <a href="#" onclick="event.preventDefault(); currentStep=13; updateUI();" style="font-size: 0.7rem;">Edit</a></h4>
                <div class="review-dl">
                    <div><dt>Amount</dt><dd>${getData('payment_amount')}</dd></div>
                    <div><dt>Date</dt><dd>${getData('payment_date')}</dd></div>
                    <div><dt>UTR No</dt><dd>${getData('payment_utr')}</dd></div>
                </div>
            </div>
        `;
        summary.innerHTML = html;
        validateChecklistState(); // Initial button state on review
    }

    function validateChecklistState() {
        const mandatoryCbs = document.querySelectorAll('.mandatory-cb');
        const submitBtn = document.getElementById('btnSubmitApp');
        const errorMsg = document.getElementById('checklistError');
        
        const allChecked = Array.from(mandatoryCbs).every(cb => cb.checked);
        submitBtn.disabled = !allChecked;
        errorMsg.style.display = allChecked ? 'none' : 'block';
    }

    function previewPhoto(event) {
        const file = event.target.files[0];
        const preview = document.getElementById('photoPreview');
        if (file && preview) {
            const reader = new FileReader();
            reader.onload = e => { preview.src = e.target.result; preview.style.display = 'block'; };
            reader.readAsDataURL(file);
        }
    }

    function toggleGovIdUpload() {
        const type = document.getElementById('govIdType')?.value;
        const label = document.getElementById('govIdLabel');
        if (label) label.textContent = (type === 'aadhaar' ? 'Aadhaar' : (type === 'pan' ? 'PAN' : 'Passport')) + ' Number *';
    }

    document.addEventListener('DOMContentLoaded', () => {
        updateUI();
        
        // Sidebar Navigation Handling
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                const target = parseInt(item.getAttribute('data-step'));
                
                if (target <= maxReachedStep + 1) {
                    if (target > currentStep && !validateSection(currentStep)) return;
                    currentStep = target;
                    updateUI();
                } else {
                    showToast("Please complete previous steps first.", "error");
                }
            });
        });

        // Checklist Change Listener
        document.getElementById('checklistBody').addEventListener('change', (e) => {
            if (e.target.classList.contains('checklist-cb')) {
                validateChecklistState();
            }
        });

        // Form Submit
        document.getElementById('rplForm').addEventListener('submit', async e => {
            e.preventDefault();
            
            // Final integrity check
            for (let i = 1; i < totalSteps; i++) {
                if (!validateSection(i)) {
                    currentStep = i;
                    updateUI();
                    showToast("Your application is incomplete. Please fix errors.", "error");
                    return;
                }
            }

            // Final checklist check
            const mandatoryCbs = document.querySelectorAll('.mandatory-cb');
            if (Array.from(mandatoryCbs).some(cb => !cb.checked)) {
                showToast("Please confirm all mandatory documents are uploaded.", "error");
                return;
            }
            
            const btn = document.getElementById('btnSubmitApp');
            btn.disabled = true;
            btn.textContent = "Finalizing Submission...";

            try {
                const formData = new FormData(e.target);
                const res = await fetch('/submit', { method: 'POST', body: formData });
                if (res.ok) {
                    // Show Success Modal
                    const modal = document.getElementById('successModal');
                    modal.classList.add('active');
                } else {
                    const result = await res.json();
                    showToast(result.message || "Submission failed. Please try again.", "error");
                    btn.disabled = false;
                    btn.textContent = "Submit Final Application";
                }
            } catch (err) {
                showToast("Connection lost. Please check internet.", "error");
                btn.disabled = false;
                btn.textContent = "Submit Final Application";
            }
        });
    });
</script>

<style>
/* Cat Label Styling */
.cat-label {
    display: flex; gap: 12px; align-items: flex-start; cursor: pointer; padding: 16px; 
    border: 2px solid var(--line); border-radius: var(--radius-md); transition: all 0.2s;
}
.cat-label:hover { background: var(--accent-light); border-color: var(--accent); }
.cat-label input[type="checkbox"] { width: 22px; height: 22px; margin-top: 4px; }
.cat-label div { display: flex; flex-direction: column; }
.cat-label small { color: var(--muted); margin-top: 4px; }
</style>

<!-- Success Confirmation Modal -->
<div class="modal-overlay" id="successModal">
    <div class="success-modal">
        <div class="success-icon">✓</div>
        <h2>Application Submitted!</h2>
        <p>Your application has been successfully submitted and is now under review. You will receive an email notification regarding the next steps.</p>
        <button class="btn-success-modal" onclick="window.location.href='/'">Go to Dashboard</button>
    </div>
</div>

</body>
</html>
