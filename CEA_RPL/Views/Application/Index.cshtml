    async function saveDraft() {
        const statusEl = document.getElementById('saveStatus');
        const saveBtn = document.getElementById('btnSaveDraft');
        const oldText = saveBtn ? saveBtn.textContent : 'Save Draft';
        
        if (statusEl) {
            statusEl.textContent = 'Saving draft...';
            statusEl.style.opacity = '1';
        }

        if (saveBtn) {
            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';
        }

        // Prepare structured address strings
        const permAddr = document.getElementById('address_perm');
        const corrAddr = document.getElementById('address_corr');
        const oldPermVal = permAddr.value;
        const oldCorrVal = corrAddr.value;

        permAddr.value = formatStructuredAddress(oldPermVal, document.getElementById('city_perm').value, document.getElementById('pincode_perm').value);
        corrAddr.value = formatStructuredAddress(oldCorrVal, document.getElementById('city_corr').value, document.getElementById('pincode_corr').value);

        const formData = new FormData(document.getElementById('applicationForm'));
        
        // Restore UI values
        permAddr.value = oldPermVal;
        corrAddr.value = oldCorrVal;
        
        // Use real values for masked fields
        if (originalIdValue) formData.set('gov_id_number', originalIdValue);
        else {
            const realGovId = document.getElementById('govIdNumber')?.value;
            if (realGovId) formData.set('gov_id_number', realGovId);
        }
        
        if (originalMobile) formData.set('mobile', originalMobile);

        formData.append('current_step', currentStep);

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        try {
            const response = await fetch('/Application/SaveDraft', {
                method: 'POST',
                headers: { 'X-CSRF-TOKEN': token },
                body: formData
            });
            const textRaw = await response.text();
            let result;
            try {
                result = JSON.parse(textRaw);
            } catch(e) {
                console.error("Non-JSON Server Error Output:", textRaw);
                throw new Error("Invalid format returned by server.");
            }

            if (response.ok) {
                if (statusEl) {
                    statusEl.textContent = `Draft saved at ${result.savedAt || new Date().toLocaleTimeString()}`;
                    setTimeout(() => { statusEl.style.opacity = '0.7'; }, 4000);
                }
            } else {
                console.error('Save Draft Server Rejection:', result.message);
                if (statusEl) statusEl.textContent = 'Save failed (Validation Errors)';
                handleServerValidation(result.message);
            }

        } catch (error) {
            console.error('Save draft failed:', error);
            if (statusEl) statusEl.textContent = 'Save failed (Check Connection)';
        } finally {
            if (saveBtn) {
                saveBtn.disabled = false;
                saveBtn.textContent = oldText;
            }
        }
    }

    function autoSave() {
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(saveDraft, 2000); // Save 2s after typing stops
    }

