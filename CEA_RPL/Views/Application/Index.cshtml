    function roundExperience(val) {
        if (!val || isNaN(val)) return 0;
        const num = parseFloat(val);
        const integerPart = Math.floor(num);
        const decimalPart = num - integerPart;
        
        // Rule: Decimal <= 0.5 round DOWN, > 0.5 round UP
        if (decimalPart <= 0.5) return integerPart;
        else return integerPart + 1;
    }

    function updateExperienceEligibility() {
        const expInput = document.getElementById('total_experience');
        const feedback = document.getElementById('experienceEligibilityFeedback');
        const helper = document.getElementById('experienceHelperInfo');
        const tick = document.getElementById('experienceSuccessTick');
        if (!expInput || !feedback || !helper) return;

        const rawValue = expInput.value;
        const roundedValue = roundExperience(rawValue);

        // Force integer display
        if (rawValue && rawValue.toString().includes('.')) {
            expInput.value = roundedValue;
        }

        const minRequired = 20;

        // Update Helper Text
        helper.innerHTML = `Minimum experience required: <strong>${minRequired} years</strong>`;

        if (!rawValue) {
            feedback.classList.add('hide');
            if (tick) tick.style.display = 'none';
            return;
        }

        feedback.classList.remove('hide');
        const isEligible = roundedValue >= minRequired;

        if (isEligible) {
            feedback.classList.add('hide');
            if (tick) tick.style.display = 'block';
            expInput.classList.remove('field-invalid');
            hideFieldError(expInput);
        } else {
            if (tick) tick.style.display = 'none';
            feedback.classList.remove('hide');
            feedback.className = "eligibility-feedback ineligible-error";
            feedback.innerHTML = `❌ Not Eligible – Minimum ${minRequired} years of experience is required.`;
            expInput.classList.add('field-invalid');
        }
    }

    function updateAgeEligibility() {
        const dobInput = document.getElementById('dob');
        const feedback = document.getElementById('ageEligibilityFeedback');
        if (!dobInput || !feedback) return;

        const dobValue = dobInput.value;
        if (!dobValue) {
            feedback.classList.add('hide');
            return;
        }

        const dob = new Date(dobValue);
        const today = new Date();
        
        // Block today's date or future dates specifically
        if (dob >= today) {
            feedback.classList.remove('hide');
            feedback.className = "eligibility-feedback ineligible-error";
            feedback.innerHTML = `❌ Please select a valid Date of Birth.`;
            dobInput.classList.add('field-invalid');
            return;
        }

        let age = today.getFullYear() - dob.getFullYear();
        const m = today.getMonth() - dob.getMonth();
        if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) {
            age--;
        }

        feedback.classList.remove('hide');
        if (age < 18) {
            feedback.className = "eligibility-feedback ineligible-error";
            feedback.innerHTML = `❌ Not Eligible – Applicant must be at least 18 years old.`;
            dobInput.classList.add('field-invalid');
        } else if (age >= 70) {
            feedback.className = "eligibility-feedback ineligible-error";
            feedback.innerHTML = `❌ Not Eligible – Applicant must be below 70 years of age.`;
            dobInput.classList.add('field-invalid');
        } else {
            feedback.classList.add('hide');
            dobInput.classList.remove('field-invalid');
            hideFieldError(dobInput);
        }
    }



