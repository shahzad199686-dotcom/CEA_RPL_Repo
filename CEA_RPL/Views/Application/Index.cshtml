                <div class="check-item"><span class="check-box">✓</span> Government ID / Citizenship Proof</div>
                <div class="check-item"><span class="check-box">✓</span> Educational Certificates</div>
                <div class="check-item"><span class="check-box">✓</span> Experience Certificates</div>
                <div class="check-item"><span class="check-box">✓</span> Project / Audit Reports</div>
                <div class="check-item"><span class="check-box">✓</span> Training / Certifications</div>
                <div class="check-item"><span class="check-box">✓</span> Publications / Research Papers</div>
                <div class="check-item"><span class="check-box">✓</span> Awards / Recognition</div>
                <div class="check-item"><span class="check-box">✓</span> Payment Receipt / Transaction ID</div>
                <div class="check-item"><span class="check-box">✓</span> Signed Declaration</div>
            </div>

            <div class="time-info-card">
