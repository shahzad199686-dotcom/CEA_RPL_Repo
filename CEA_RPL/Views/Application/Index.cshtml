<script>
    function isMeaningfulText(val, isDesc = false) {
        if (!val || val.trim() === '') return true; // emptiness validated by form layer securely
        const text = val.trim();
        if (text.length < 2) return false; // Hard threshold filter
        
        // Block pure redundant repeat characters (e.g. jjjjjjj, eeee)
        if (/^(.)\1{3,}$/.test(text)) return false;
        
        // Trap known layout smashes & specific testing artifacts intelligently
        const lower = text.toLowerCase();
        if (/^qwerty|^asdf|^zxcv/.test(lower) || /^test(\s+test)*$/.test(lower) || /^abc(\s+abc)*$/.test(lower)) return false;
        
        // Word analysis algorithms to determine unique redundancy loops computationally
        const words = lower.split(/\s+/).filter(w => w.length > 0);
        if (words.length >= 3) {
            const unique = new Set(words);
            if (unique.size === 1) return false; // Aborts "test test test" definitively
        }

        // Expanded logic explicitly for descriptive text blocks (enclosures/nature of work)
        if (isDesc) {
            if (words.length < 5) return false;
            let validWords = words.filter(w => w.length >= 3);
            if (validWords.length < 3) return false;
            
            let uniqueWords = new Set(words);
            if (uniqueWords.size < words.length / 2) return false;
        }
        
        return true;
    }
</script>
