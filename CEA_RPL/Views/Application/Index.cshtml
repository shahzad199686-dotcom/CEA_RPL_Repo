@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>CEA RPL Application – Full Version</title>

<style>

/* =========================
   Design Tokens
========================= */
:root {
  --ink:#0c3b2e;
  --muted:#5b6b68;
  --line:#e7eceb;
  --bg:#f8fbfa;
  --accent:#0ea5a5;
  --accent-light:#d1f2f0;
  --warn:#b42318;
  --success:#0b7a53;
  --shadow:0 4px 6px -1px rgba(0,0,0,.1);
  --shadow-lg:0 10px 15px -3px rgba(0,0,0,.1);
}

/* =========================
   Base
========================= */
* { box-sizing: border-box; }

body {
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  background: linear-gradient(135deg, var(--bg), #e8f5f2);
  color: var(--ink);
  margin: 0;
}

.wrap {
  max-width: 1120px;
  margin: 0 auto 64px;
  padding: 0 16px;
}

header {
  text-align: center;
  padding: 36px 0 20px;
  background: linear-gradient(135deg, var(--accent), #00b3a5);
  color: #fff;
  border-radius: 0 0 24px 24px;
  box-shadow: var(--shadow-lg);
}

header h1 {
  margin: 0 0 6px;
  font-size: 1.8rem;
}

header p {
  margin: 0;
  opacity: 0.95;
}

/* =========================
   Sections
========================= */
section {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 28px;
  margin: 24px 0;
  box-shadow: var(--shadow);
  position: relative;
}

section::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--accent), var(--success));
}

h2 {
  font-size: 1.25rem;
  margin: 0 0 16px;
}

/* =========================
   Layout Grid
========================= */
.grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 16px;
}

.col-3 { grid-column: span 3; }
.col-4 { grid-column: span 4; }
.col-6 { grid-column: span 6; }
.col-8 { grid-column: span 8; }
.col-12 { grid-column: span 12; }

/* =========================
   Form Controls
========================= */
label {
  display: block;
  font-weight: 600;
  margin: 4px 0 6px;
}

input,
select,
textarea {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: 2px solid var(--line);
  font-size: 1rem;
  background: #fff;
}

textarea {
  min-height: 110px;
  resize: vertical;
}

input:focus,
select:focus,
textarea:focus {
  outline: none;
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-light);
}

.req {
  color: var(--warn);
  font-weight: 600;
  margin-left: 4px;
}

.caption,
small.hint {
  color: var(--muted);
  font-size: 0.9rem;
}

/* =========================
   Tables
========================= */
.table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 12px;
}

.table th,
.table td {
  border: 1px solid var(--line);
  padding: 10px;
  text-align: left;
  vertical-align: middle;
}

.table th {
  background: #f4f8f7;
  font-weight: 600;
}

/* ===== Category Chips ===== */
.chip input[type="checkbox"] {
  width: 16px;
  height: 16px;
  min-width: 16px;
  min-height: 16px;
  margin: 2px 0 0 0;
  padding: 0;
  flex-shrink: 0;
  transform: scale(1);
}

.chip {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.chips {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* =========================
   Buttons & Actions
========================= */
.actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 20px;
}

button {
  appearance: none;
  border: none;
  border-radius: 10px;
  padding: 10px 16px;
  font-weight: 600;
  cursor: pointer;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent), #00b3a5);
  color: #fff;
}

.btn-ghost {
  background: #fff;
  border: 1px solid var(--line);
  color: var(--ink);
}

.add-row {
  background: var(--success);
  color: #fff;
}

.delete-row {
  background: var(--warn);
  color: #fff;
  padding: 6px 10px;
}

/* =========================
   Utility
========================= */
.rowline {
  border-top: 1px dashed var(--line);
  margin: 16px 0;
}

.alert {
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid var(--line);
  background: #fffdf6;
}

.ok { color: var(--success); font-weight: 600; }
.fail { color: var(--warn); font-weight: 600; }

.disabled {
  opacity: .6;
  pointer-events: none;
}
.hint {
  color: var(--muted);
  display: block;
  margin-top: 12px;
  font-size: 0.9rem;
}

/* =========================
   Toast Notifications
========================= */
#toast-container {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.toast {
  background: #fff;
  border-left: 4px solid var(--accent);
  box-shadow: var(--shadow-lg);
  padding: 16px 20px;
  border-radius: 8px;
  color: var(--ink);
  font-weight: 500;
  animation: slideIn 0.3s ease-out forwards;
  max-width: 350px;
}
.toast.error { border-left-color: var(--warn); }
.toast.success { border-left-color: var(--success); }
@@keyframes slideIn {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

/* =========================
   Responsive & Modals
========================= */
@@media (max-width: 768px) {
  .grid { grid-template-columns: 1fr; }
}

.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);
  display: none; align-items: center; justify-content: center; z-index: 1000;
}
.modal-card {
  background: #fff; border-radius: 16px; padding: 32px; width: 100%; max-width: 400px;
  box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); text-align: center;
  animation: slideIn 0.3s ease-out forwards;
}
.auth-tabs {
  display: flex; background: #f4f8f7; border-radius: 12px; padding: 4px; margin-bottom: 24px;
}
.auth-tab {
  flex: 1; text-align: center; padding: 10px; border-radius: 8px; cursor: pointer;
  font-weight: 600; color: var(--muted); transition: all 0.2s;
}
.auth-tab.active { background: #fff; color: var(--accent); box-shadow: var(--shadow); }
.auth-container { max-width: 440px; margin: 0 auto; }

/* Enhanced Button States */
.btn-primary:hover, .btn-ghost:hover, .add-row:hover {
  transform: translateY(-2px);
  filter: brightness(1.05);
  box-shadow: 0 8px 15px -3px rgba(0,0,0,0.15);
}
.btn-primary:active, .btn-ghost:active {
  transform: translateY(0);
}
.btn-ghost:hover {
  border-color: var(--accent);
  color: var(--accent);
}

/* Modal Animations */
.modal-overlay {
  transition: opacity 0.3s ease;
}
.modal-card {
  transform: translateY(20px);
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.modal-overlay.show .modal-card {
  transform: translateY(0);
  opacity: 1;
}

#authSection {
  animation: fadeIn 0.5s ease-out;
}

@@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* FORM LAYOUT STYLES */
section {
  background: white;
  padding: 30px;
  border-radius: 12px;
  border: 1px solid var(--border);
  margin-bottom: 40px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}
section h2 {
  color: var(--accent);
  margin-top: 0;
  margin-bottom: 20px;
  font-size: 1.5rem;
  border-bottom: 2px solid #e6f6f6;
  padding-bottom: 10px;
}
.actions {
  display: flex;
  justify-content: flex-end;
  gap: 15px;
  margin-top: 20px;
}
</style>

</head>

<body>
<div id="toast-container"></div>
<div class="wrap">
</header>

<div style="max-width: 1000px; margin: 0 auto; display: flex; justify-content: flex-end; padding: 10px 20px;">
    <a href="/Auth/Logout" style="color: var(--accent); font-weight: 600; text-decoration: none; font-size: 0.9rem;">Sign Out</a>
</div>

<form id="rplForm" novalidate>

<!-- Start Application Sections -->
<div id="applicationSections" style="position: relative; max-width: 1000px; margin: 0 auto; padding: 20px;">

  <!-- APPLICANT DETAILS -->
    <section>
      <h2>Step 1: Applicant Details</h2>
      <p class="caption">Please provide your basic contact and identity information</p>
      <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

<!-- PERSONAL DETAILS -->
    </section>
  <!-- CATEGORY OF CERTIFICATION -->
    <section>
      <h2>Step 2: Category of Certification Applied For</h2>
      <p class="caption">Select the categories you wish to be certified in</p>
      <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
  <div class="grid">
    <div class="col-6">
      <label>Full Name <span class="req">*</span></label>
      <input name="full_name" type="text" required />
    </div>
    <div class="col-6">
      <label>Father’s / Mother’s Name</label>
      <input name="parent_name" type="text" />
    </div>
    <div class="col-4">
      <label>Date of Birth <span class="req">*</span></label>
      <input name="dob" type="date" required />
    </div>
    <div class="col-4">
      <label>Gender</label>
      <select name="gender">
        <option value="">Select</option>
        <option>Male</option><option>Female</option><option>Other</option>
      </select>
    </div>
    <div class="col-4">
      <label>Citizenship (Indian) <span class="req">*</span></label>
      <select name="citizenship" required>
        <option value="">Select</option>
        <option>Indian</option>
      </select>
    </div>
    <div class="col-4">
      <label>
        Applicant Photograph <span class="req">*</span>
      </label>
      <input
        type="file"
        name="applicant_photo"
        accept=".jpg,.jpeg,.png"
        required
        onchange="previewPhoto(event)"
      />
      <small class="hint">
        JPG / PNG only, max size 2 MB, recent passport-size photo
      </small>

      <div style="margin-top:8px;">
        <img
          id="photoPreview"
          src=""
          alt="Photo Preview"
          style="display:none; width:120px; height:150px; border:1px solid #000; object-fit:cover;"
        />
      </div>
    </div>

    <div class="col-6">
      <label>Permanent Address <span class="req">*</span></label>
      <textarea name="address_perm" required></textarea>
    </div>
    <div class="col-6">
      <label>Correspondence Address</label>
      <textarea name="address_corr"></textarea>
    </div>
    <div class="col-4">
      <label>Email ID <span class="req">*</span></label>
      <input name="email" type="email" required />
      <small class="hint">Pre-filled from your account after sign-in.</small>
    </div>
    <div class="col-4">
      <label>Mobile Number (OTP verification) <span class="req">*</span></label>
      <input name="mobile" type="text" inputmode="numeric" pattern="[6-9]\d{9}" placeholder="10-digit Indian number" required />
    </div>
    <div class="col-4">
      <label>Alternate Contact No.</label>
      <input name="alt_mobile" type="text" inputmode="numeric" pattern="[0-9]{10}" />
    </div>
  <div class="col-6">
    <label>Government Photo ID Type <span class="req">*</span></label>
    <select id="govIdType" name="gov_id_type" required onchange="toggleGovIdUpload()">
      <option value="">Select</option>
      <option value="aadhaar">Aadhaar</option>
      <option value="pan">PAN</option>
      <option value="passport">Passport</option>
    </select>
  </div>

  <div class="col-6">
    <label id="govIdLabel">ID Number <span class="req">*</span></label>
    <input id="govIdNumber" name="gov_id_number" type="text" required />
    <small class="hint" id="govIdHint">
      Only the selected ID number is required. Full value stored securely.
    </small>
  </div>

  <div class="col-6">
    <label id="govUploadLabel">
      Upload Selected ID Proof (JPG / PNG / PDF ≤ 2 MB) <span class="req">*</span>
    </label>
    <input
      id="govIdUpload"
      name="gov_id_upload"
      type="file"
      accept=".jpg,.jpeg,.png,.pdf"
      required
    />
  </div>

</section>

  <!-- EDUCATIONAL QUALIFICATIONS -->
    <section>
      <h2>Step 3: Educational Qualifications</h2>
      <p class="caption">Provide details of your academic background</p>
      <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

  <div class="chips">
    <label class="chip">
      <input type="checkbox" name="cert_category[]" value="Category 1">
      <span>
        <strong>Category 1 — Compliance or Verification audits </strong><br>
        EPA Act & Rules, Air Act, Water Act, GHG emission intensity target Rules,Waste management Rules, CRZ Regulation, Eco-mark Rules , Green Credit Rules etc
      </span>
    </label>

    <label class="chip">
      <input type="checkbox" name="cert_category[]" value="Category 2">
      <span>
        <strong>Category 2 — Compliance or Verification audits  </strong><br>
        SEBI Act, ESG / Sustainability/ SEBI BRSR
      </span>
    </label>

    <label class="chip">
      <input type="checkbox" name="cert_category[]" value="Category 3">
      <span>
        <strong>Category 3 — Compliance or Verification audits </strong><br>
        Forest Conservation Act / Van (Sanrakshan evam Samvardhan) Adhiniyam
      </span>

    </label>

    <label class="chip">
      <input type="checkbox" name="cert_category[]" value="Category 4">
      <span>
      <strong>Category 4 — Compliance or Verification audits </strong><br>
      Wildlife Protection Act
      </span>

    </label>
  </div>

  <small class="hint">
    You may choose one or more categories. Certification fees apply per selected category.
  </small>
</section>


  <!-- PROFESSIONAL EXPERIENCE -->
    <section>
      <h2>Step 4: Professional Experience</h2>
      <p class="caption">Detail your relevant work history</p>
      <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
  <table class="table" id="educationTable">
    <thead>
      <tr>
        <th>Degree</th>
        <th>Discipline</th>
        <th>Institution</th>
        <th>Year</th>
        <th>Certificate</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <tr>
        <td>
          <select name="edu_degree[]" required>
            <option value="">Select</option>
            <option>Bachelor's</option>
            <option>Master's</option>
            <option>PhD</option>
          </select>
        </td>
        <td><input name="edu_discipline[]" required></td>
        <td><input name="edu_institution[]" required></td>
        <td>
          <input type="number" name="edu_year[]" min="1950" max="2026" required>
        </td>
        <td>
          <input type="file" name="edu_cert" accept=".pdf,.jpg,.png" required>
        </td>
        <td class="row-actions">
          <!-- initial row has no delete button -->
        </td>
      </tr>
    </tbody>
  </table>

  <button type="button" class="add-row" onclick="addEducationRow()">+ Add Row</button>
</section>

  <!-- PROJECT EXPERIENCE -->
    <section>
      <h2>Step 5: Project Experience</h2>
      <p class="caption">List major projects undertaken in the applied categories</p>
      <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

  <label>Total Years of Experience <span class="req">*</span></label>
  <input name="total_experience" required>
  <table class="table" id="experienceTable">
    <thead>
      <tr>
        <th>S. No.</th>
        <th>Organization</th>
        <th>Designation</th>
        <th>Duration</th>
        <th>Nature of Work</th>
        <th>Proof of Experience <br> (Experiance Certificate/ Goverment reference)</th>
        <th>Contact details of two organizational references</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <tr>
        <td class="row-no"></td>
        <td><input name="exp_org[]" required></td>
        <td><input name="exp_designation[]" required></td>
        <td>
          <input name="exp_duration[]" placeholder="MM/YYYY – MM/YYYY" required>
        </td>
        <td>
          <textarea name="exp_nature[]" required></textarea>
        </td>
        <td>
          <input type="file" name="exp_proof" accept=".pdf,.jpg,.png" required>
        </td>
        <td>
          <input type="tel" name="ref2_phone[]" required />
        </td>
        <td class="row-actions">
          <!-- initial row: no delete -->
        </td>
      </tr>
    </tbody>
  </table>

  <button type="button" class="add-row" onclick="addExperienceRow()">+ Add Row</button>
</section>



  <h3> 6.1 For Category 1: List the  major Environment Auditing / Assessment / verification/ Inspection Projects undertaken by applicant </h3>
  <table class="table" aria-label="Projects" id="cat1Projects">
    <thead>
      <tr>
