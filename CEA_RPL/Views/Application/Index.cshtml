                        <thead><tr><th style="width: 60px; text-align: center;">S. No.</th><th>Software (e.g., MS Office, SPSS, MATLAB, ArcGIS, AutoCAD, AERMOD, etc.)</th><th style="width: 200px;">Level of Proficiency</th><th style="width: 70px; text-align: center;">Action</th></tr></thead>
                        <tbody><tr><td style="text-align: center; font-weight: 700; color: var(--accent);">1</td><td><input name="software_skill[]" placeholder="Enter Software Name" /></td><td><select name="proficiency_level[]"><option value="">Select</option><option>Basic</option><option>Intermediate</option><option>Expert</option></select></td><td style="text-align: center;"><button type="button" class="btn-remove" onclick="removeGenericRow(this, 'softwareTable')" style="display: none;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6"/></svg></button></td></tr></tbody>
                    </table>
                    <button type="button" class="btn btn-ghost" style="margin-top: 16px; background-color: var(--accent); color: white;" onclick="addGenericRow('softwareTable')">+ Add Row</button>
                </div>
            </div>

            <!-- STEP 12: OTHER ENCLOSURES -->
            <div class="form-section hide" id="step-12">
                <div class="section-header"><h2>Step 12: Other Relevant Enclosures</h2></div>
                <div class="section-content">

                    <div class="upload-container">
                        <input type="file" name="other_enclosure" accept=".pdf" onchange="validateFileUpload(this)" />
                        <div class="file-validation-hint" style="font-size: 0.72rem; color: var(--muted); margin-left: auto;">PDF 2MB</div>
                    </div>

                    <div class="description-box-wrap" style="margin-top: 24px;">
                        <label style="font-weight: 600; color: var(--ink); margin-bottom: 8px; display: block;">Description</label>
                        <textarea class="description-box" id="enclosure_desc" name="enclosure_desc" 
                                  placeholder="Describe the enclosures you uploaded (Maximum 200 words)"
                                  oninput="updateWordCount(this)"></textarea>
                        
                        <div class="word-counter-wrap">
                            <span class="word-counter-hint">Maximum 200 words</span>
                            <span class="word-counter-label" id="wordCountLabel">0 / 200 words</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 13: PAYMENT DETAILS -->
            <div class="form-section hide" id="step-13">
                <div class="section-header"><h2>Step 13: Payment Details</h2></div>
                <div class="section-content">
                    
                    <!-- Bank Details Card -->
                    <div class="payment-details-card">
                        <div class="payee-header">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            Payee Details (Bank Transfer)
                        </div>
                        <div class="bank-grid">
                            <div class="bank-item"><span class="bank-label">Beneficiary Name</span><span class="bank-value">NATIONAL PRODUCTIVITY COUNCIL -(EADA)</span></div>
                            <div class="bank-item"><span class="bank-label">Bank Name</span><span class="bank-value">Indian Overseas Bank</span></div>
                            <div class="bank-item"><span class="bank-label">Account Number</span><span class="bank-value">026501000030809</span></div>
                            <div class="bank-item"><span class="bank-label">IFSC Code</span><span class="bank-value">IOBA0000265</span></div>
                            <div class="bank-item"><span class="bank-label">Branch</span><span class="bank-value">Golf Links</span></div>
                            <div class="bank-item"><span class="bank-label">Mode</span><span class="bank-value">NEFT / RTGS / UPI</span></div>
                        </div>

                    </div>

                    <!-- Auto-Calculation Summary -->
                    <div class="fee-calc-summary" id="feeSummaryCard">
                        <div style="margin-bottom: 12px; font-weight: 800; color: var(--accent); font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.025em;">Fee Calculation</div>
                        
                        <div style="margin-bottom: 8px; font-weight: 600; color: var(--accent); font-size: 0.9rem;">Application Categories</div>
                        <div id="feeBreakdownLines" style="margin-bottom: 16px;">
                            <!-- Dynamic lines like: Category 1A: ₹21,000 -->
                        </div>

                        <div id="discountSection" style="display: none; border-top: 1px dashed #cbd5e1; padding-top: 12px; margin-top: 12px;">
                            <div class="fee-item" style="color: #059669; font-weight: 600;">
                                <span id="discountLabel">Applicable Fee Rebate (0%)</span>
                                <span id="discountAmount">- ₹0</span>
                            </div>
                        </div>

                        <div style="border-top: 2px solid #e2e8f0; margin: 16px 0; padding-top: 12px;">
                            <div class="fee-item" style="font-weight: 600;">
                                <span>Subtotal</span>
                                <span id="subtotalDisplay">₹0</span>
                            </div>
                            <div class="fee-item" style="color: var(--muted); margin-top: 4px;">
                                <span>GST (18%)</span>
                                <span id="gstDisplay">₹0</span>
                            </div>
                        </div>

                        <div class="fee-item fee-total" style="background: var(--accent); color: white; padding: 16px; border-radius: 12px; margin-top: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                            <span style="font-weight: 700; font-size: 1.1rem;">Total Fee to be Paid</span>
                            <span id="totalFeeDisplay" style="font-weight: 800; font-size: 1.25rem;">₹0</span>
                        </div>
                    </div>

                    <span class="payment-instruction-bold">Please complete the payment using the details above before proceeding.</span>

                    <div class="grid">
                        <div class="col-4">
                            <label>Certification Fee Amount Paid <span class="req">*</span></label>
                            <input name="payment_amount" id="payment_amount" type="number" step="0.01" readonly required title="This is auto-calculated based on selected categories" />
                        </div>
                        <div class="col-4">
                            <label>Date of Payment <span class="req">*</span></label>
                            <input name="payment_date" id="payment_date" type="date" required onchange="validatePaymentStep()" />
