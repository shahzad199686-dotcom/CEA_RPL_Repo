<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="admin-layout">
    <header class="admin-header">
        <a class="admin-brand" asp-controller="@(User.IsInRole("Finance") ? "Finance" : "Admin")" asp-action="Dashboard">
            <div class="admin-logo-box">C</div>
            <div class="admin-portal-name">
                CEA RPL <span class="admin-badge">@(User.IsInRole("Finance") ? "Finance" : "Admin")</span>
            </div>
        </a>

        <nav class="admin-nav d-none d-lg-flex">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Dashboard" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i data-lucide="layout-dashboard" style="width: 18px; height: 18px;"></i> Dashboard
                </a>
                <a asp-controller="Admin" asp-action="Applications" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Applications" ? "active" : "")">
                    <i data-lucide="users" style="width: 18px; height: 18px;"></i> Applications
                </a>
                <a asp-controller="Admin" asp-action="Documents" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Documents" ? "active" : "")">
                    <i data-lucide="file-text" style="width: 18px; height: 18px;"></i> Documents
                </a>
                <a asp-controller="Admin" asp-action="Reports" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Reports" ? "active" : "")">
                    <i data-lucide="bar-chart-3" style="width: 18px; height: 18px;"></i> Reports
                </a>
                <a asp-controller="Admin" asp-action="Help" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Help" ? "active" : "")">
                    <i data-lucide="help-circle" style="width: 18px; height: 18px;"></i> Help
                </a>
            }
            else if (User.IsInRole("Finance"))
            {
                <a asp-controller="Finance" asp-action="Dashboard" class="nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i data-lucide="layout-dashboard" style="width: 18px; height: 18px;"></i> Dashboard
                </a>
                <a asp-controller="Finance" asp-action="Dashboard" class="nav-item">
                    <i data-lucide="banknote" style="width: 18px; height: 18px;"></i> Payments
                </a>
            }
        </nav>

        <div class="admin-nav-actions">
            <!-- Notifications -->
            <button class="btn btn-link text-muted p-0 me-2" style="position: relative; border:none; box-shadow:none;">
                <i data-lucide="bell" style="width: 20px; height: 20px;"></i>
                <span style="position: absolute; top: -2px; right: -2px; width: 8px; height: 8px; background: #ef4444; border: 2px solid white; border-radius: 50%;"></span>
            </button>

            <!-- Profile Group -->
            <div class="admin-profile">
                <div class="admin-info d-none d-md-block">
                    <span class="admin-name">@(User.IsInRole("Finance") ? "Finance Officer" : "Administrator")</span>
                    <span class="admin-email">@(User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)</span>
                </div>
                <div class="admin-avatar ms-2">@(User.IsInRole("Finance") ? "FN" : "AD")</div>
                <a asp-controller="Auth" asp-action="Logout" class="logout-btn ms-3" title="Sign Out">
                    <i data-lucide="log-out" style="width: 18px; height: 18px;"></i>
                </a>
            </div>
        </div>
    </header>

    <main class="admin-main">
        @RenderBody()
    </main>

    <footer class="admin-footer" style="padding: 24px 40px; border-top: 1px solid var(--a-line); background: white; font-size: 0.8rem; color: var(--a-muted); opacity: 0.8;">
        <div class="admin-container-limit d-flex justify-content-between align-items-center" style="padding: 0;">
            <div>&copy; 2026 CEA RPL Portal &bull; <span class="fw-bold">Administrative System</span></div>
            <div class="d-flex gap-4">
                <a href="/#home" class="text-muted text-decoration-none hover-teal">View Portal</a>
                <a href="#" class="text-muted text-decoration-none hover-teal">Support Center</a>
                <a href="#" class="text-muted text-decoration-none hover-teal">Documentation</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
