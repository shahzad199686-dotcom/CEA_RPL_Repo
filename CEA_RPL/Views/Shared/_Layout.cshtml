<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEA RPL</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
    <header class="l-header-wrapper" id="mainHeader">
        <!-- 1. Top Strip (Accessibility & Language) -->
        <div class="l-header-top-strip">
            <div class="l-container">
                <div class="l-top-strip-content">
                    <div class="l-top-strip-left">
                        <span style="font-size: 1.1rem; filter: grayscale(0.2);">🇮🇳</span>
                        <span class="ms-1">भारत सरकार | Government of India</span>
                    </div>
                    <div class="l-top-strip-right">
                        <div class="l-acc-controls d-none d-md-flex">
                            <span class="l-acc-btn">A-</span>
                            <span class="l-acc-btn">A</span>
                            <span class="l-acc-btn">A+</span>
                        </div>
                        <div class="l-lang-dropdown d-flex align-items-center gap-1">
                            <span class="fw-bold">EN</span> 
                            <i data-lucide="chevron-down" style="width: 14px; height: 14px;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. Main Branding Header (Logo Strip) -->
        <div class="l-header-branding">
            <div class="l-container">
                <div class="l-branding-container">
                    <!-- Left: EADA + MoEFCC Identity -->
                    <div class="l-brand-left">
                        <div class="l-brand-group l-brand-eada">
                            <img src="/images/eada_logo.png" alt="EADA Logo" class="l-brand-logo">
                            <div class="l-brand-text">
                                <span class="l-brand-hindi">ई. ए. डी. ए.</span>
                                <span class="l-brand-english">EADA</span>
                            </div>
                        </div>
                        
                        <div class="l-brand-separator"></div>

                        <div class="l-brand-group l-brand-ministry">
                            <img src="/images/moef_logo.png" alt="MoEFCC Logo" class="l-brand-logo">
                            <div class="l-brand-text">
                                <div class="l-ministry-hindi">पर्यावरण, वन और जलवायु परिवर्तन मंत्रालय</div>
                                <div class="l-ministry-english">Ministry of Environment, Forest and Climate Change</div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Partners & Emblem -->
                    <div class="l-brand-right">
                        <img src="/images/npc_logo.png" alt="NPC" class="l-partner-logo">
                        <img src="/images/life_logo.png" alt="LiFE" class="l-partner-logo">
                        <img src="/images/satyamev_jayate.png" alt="Satyamev Jayate" class="l-partner-logo emblem">
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. Navigation Bar Strip -->
        <div class="l-header-nav-strip">
            <div class="l-container l-navbar-container">
                <nav class="l-nav d-none d-lg-flex">
                    <a asp-controller="Home" asp-action="Index" class="l-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">Home</a>
                    <div class="l-dropdown">
                        <a asp-controller="Home" asp-action="About" class="l-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")">About <i data-lucide="chevron-down" style="width: 14px; height: 14px; margin-left: 4px;"></i></a>
                        <div class="l-dropdown-menu">
                            <a class="l-dropdown-item" asp-controller="Home" asp-action="About" asp-fragment="cea">CEA</a>
                            <a class="l-dropdown-item" asp-controller="Home" asp-action="About" asp-fragment="npc">NPC</a>
                        </div>
                    </div>
                    <a asp-controller="Home" asp-action="Eligibility" class="l-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Eligibility" ? "active" : "")">Eligibility</a>
                    <a asp-controller="Home" asp-action="Process" class="l-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Process" ? "active" : "")">Process</a>
                    <a asp-controller="Home" asp-action="Documents" class="l-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Documents" ? "active" : "")">Document Required</a>
                    <a asp-controller="Home" asp-action="Faq" class="l-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Faq" ? "active" : "")">FAQ'S</a>
                </nav>

                <div class="l-auth-group d-none d-lg-flex">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="l-dropdown">
                            <button class="l-btn-dropdown">
                                <i data-lucide="user" style="width: 18px; height: 18px;"></i>
                                <span>Account</span>
                                <i data-lucide="chevron-down" style="width: 14px; height: 14px;"></i>
                            </button>
                            <div class="l-dropdown-menu">
                                @if (User.IsInRole("Admin"))
                                {
                                    <a class="l-dropdown-item" href="/Admin/Dashboard">
                                        <i data-lucide="layout-dashboard" style="width: 16px; height: 16px;"></i> Admin Dashboard
                                    </a>
                                }
                                else
                                {
                                    <a class="l-dropdown-item" asp-controller="Application" asp-action="Index">
                                        <i data-lucide="file-text" style="width: 16px; height: 16px;"></i> My Application
                                    </a>
                                }
                                <hr style="margin: 4px 8px; border-top: 1px solid #eee;">
                                <a class="l-dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                    <i data-lucide="log-out" style="width: 16px; height: 16px;"></i> Logout
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Login Dropdown -->
                        <div class="l-dropdown">
                            <button class="l-btn-dropdown">
                                <span>Login</span>
                                <i data-lucide="chevron-down" style="width: 14px; height: 14px;"></i>
                            </button>
                            <div class="l-dropdown-menu">
                                <a class="l-dropdown-item" asp-controller="Auth" asp-action="CandidateLogin">
                                    <i data-lucide="user" style="width: 16px; height: 16px;"></i> Candidate Login
                                </a>
                                <a class="l-dropdown-item" asp-controller="Auth" asp-action="AdminLogin">
                                    <i data-lucide="shield-check" style="width: 16px; height: 16px;"></i> Admin Login
                                </a>
                            </div>
                        </div>

                        <!-- Sign Up Dropdown -->
                        <div class="l-dropdown">
                            <button class="l-btn-dropdown l-btn-register">
                                <span>Sign Up</span>
                                <i data-lucide="chevron-up" style="width: 14px; height: 14px; transform: rotate(180deg);"></i>
                            </button>
                            <div class="l-dropdown-menu">
                                <a class="l-dropdown-item" asp-controller="Auth" asp-action="CandidateRegister">
                                    <i data-lucide="user-plus" style="width: 16px; height: 16px;"></i> Register as Candidate
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <!-- Mobile Menu Toggle -->
                <button class="d-lg-none btn btn-link p-2 text-white" onclick="toggleMobileMenu()">
                    <i data-lucide="menu" id="menuIcon"></i>
                </button>
            </div>
        </div>

        <!-- 4. Latest Update Strip -->
        <div class="l-update-strip">
            <div class="l-update-label">LATEST UPDATE</div>
            <div class="l-update-content">
                <span class="l-update-text">Application forms for CEA (RPL) & REA will be available soon.</span>
            </div>
        </div>
    </header>


        <!-- Mobile Menu Overlay -->
        <div class="mobile-menu-overlay d-lg-none" id="mobileMenu">
             <div class="p-4 pt-5">
                <nav class="d-flex flex-column gap-4 mb-5">
                    <a asp-controller="Home" asp-action="Index" class="l-nav-link fs-4 fw-bold" onclick="toggleMobileMenu()">Home</a>
                    <div class="mobile-dropdown">
                        <a class="l-nav-link fs-4 fw-bold d-flex justify-content-between align-items-center" onclick="toggleMobileSubmenu('aboutSub')">About <i data-lucide="chevron-down"></i></a>
                        <div class="mobile-submenu" id="aboutSub" style="display: none; padding-left: 20px;">
                            <a asp-controller="Home" asp-action="About" asp-fragment="cea" class="l-nav-link fs-5 py-2" onclick="toggleMobileMenu()">CEA</a>
                            <a asp-controller="Home" asp-action="About" asp-fragment="npc" class="l-nav-link fs-5 py-2" onclick="toggleMobileMenu()">NPC</a>
                        </div>
                    </div>
                    <a asp-controller="Home" asp-action="Eligibility" class="l-nav-link fs-4 fw-bold" onclick="toggleMobileMenu()">Eligibility</a>
                    <a asp-controller="Home" asp-action="Process" class="l-nav-link fs-4 fw-bold" onclick="toggleMobileMenu()">Process</a>
                    <a asp-controller="Home" asp-action="Documents" class="l-nav-link fs-4 fw-bold" onclick="toggleMobileMenu()">Document Required</a>
                    <a asp-controller="Home" asp-action="Faq" class="l-nav-link fs-4 fw-bold" onclick="toggleMobileMenu()">FAQ'S</a>
                </nav>
                <div class="d-flex flex-column gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="btn btn-primary p-3 fw-bold" asp-controller="Application" asp-action="Index">My Dashboard</a>
                        <a class="btn btn-outline-danger p-3 fw-bold" asp-controller="Auth" asp-action="Logout">Logout</a>
                    }
                    else
                    {
                        <a class="btn btn-primary p-3 fw-bold" asp-controller="Auth" asp-action="Login">Sign In</a>
                        <a class="btn btn-outline-primary p-3 fw-bold" asp-controller="Auth" asp-action="CandidateRegister">Create Account</a>
                    }
                </div>
             </div>
        </div>
    </header>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="l-footer">
        <div class="l-container">
            <div class="row g-5">
                <!-- Column 1: Quick Links -->
                <div class="col-lg-3">
                    <h5>Quick Links</h5>
                    <ul class="l-footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Home" asp-action="About">About EADA</a></li>
                        <li><a asp-controller="Home" asp-action="Eligibility">Eligibility</a></li>
                        <li><a asp-controller="Home" asp-action="Process">Application Process</a></li>
                    </ul>
                </div>

                <!-- Column 2: Contact Us -->
                <div class="col-lg-3">
                    <h5>Contact Us</h5>
                    <div class="l-footer-contact-item">
                        <span class="l-footer-contact-label">Phone:</span>
                        <span class="l-footer-contact-value">011-24607306</span>
                    </div>
                    <div class="l-footer-contact-item">
                        <span class="l-footer-contact-label">Email:</span>
                        <a href="mailto:eada.npc@npcindia.gov.in" class="l-footer-contact-value">eada.npc@npcindia.gov.in</a>
                    </div>
                </div>

                <!-- Column 3: Address -->
                <div class="col-lg-3">
                    <h5>Address</h5>
                    <address class="l-footer-address">
                        Environment Audit Designated Agency (EADA)<br>
                        VIKRAM SARABHAI BLOCK<br>
                        National Productivity Council,<br>
                        Utpadata Bhavan, 5-6, Institutional Area,<br>
                        Lodhi Rd, Lodi Colony, New Delhi, Delhi<br>
                        110003
                    </address>
                </div>

                <!-- Column 4: Map View -->
                <div class="col-lg-3">
                    <h5>Map View</h5>
                    <div class="l-footer-map-container">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3503.461245648831!2d77.2274436758469!3d28.58591327568972!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390ce2f986420f5b%3A0x63251c9113636f9a!2sNational%20Productivity%20Council!5e0!3m2!1sen!2sin!4v1714202345678!5m2!1sen!2sin" width="100%" height="150" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
            </div>

            <!-- Bottom Copyright -->
            <div class="l-footer-bottom">
                <span class="l-footer-copyright">
                    &copy; @DateTime.Now.Year Environment Audit Designated Agency. All Rights Reserved.
                </span>
            </div>
        </div>
    </footer>

    <!-- ROLE SELECTION MODAL -->
    <div class="l-modal-overlay" id="roleModal">
        <div class="l-modal">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">Select Your Role</h2>
                <button class="btn btn-ghost p-2 rounded-circle" onclick="closeRoleModal()"><i data-lucide="x"></i></button>
            </div>
            <p class="text-muted">How would you like to use the portal today? Please choose your role to proceed.</p>
            
            <div class="l-role-grid">
                <a asp-controller="Auth" asp-action="CandidateLogin" class="l-role-card">
                    <div class="l-role-icon"><i data-lucide="user"></i></div>
                    <h3>Candidate</h3>
                    <p>Register or Login to start/track your auditor certification application.</p>
                </a>
                <a asp-controller="Auth" asp-action="AdminLogin" class="l-role-card">
                    <div class="l-role-icon"><i data-lucide="shield-check"></i></div>
                    <h3>Admin</h3>
                    <p>Audit and manage applications. This requires authorized personnel credentials.</p>
                </a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        lucide.createIcons();

        function toggleFaq(header) {
            const item = header.parentElement;
            const container = item.parentElement;
            const allItems = container.querySelectorAll('.l-faq-item');
            const isActive = item.classList.contains('active');
            allItems.forEach(i => i.classList.remove('active'));
            if (!isActive) {
                item.classList.add('active');
            }
        }

        function openRoleModal() {
            document.getElementById('roleModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeRoleModal() {
            document.getElementById('roleModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        function toggleExpand(id) {
            const ids = ['eada', 'npc', 'cea'];
            const content = document.getElementById('expand-' + id);
            const btn = document.getElementById('btn-' + id);
            if(!content || !btn) return;
            const isClosing = content.classList.contains('active');
            ids.forEach(otherId => {
                if (otherId !== id) {
                    const otherContent = document.getElementById('expand-' + otherId);
                    const otherBtn = document.getElementById('btn-' + otherId);
                    if (otherContent) otherContent.classList.remove('active');
                    if (otherBtn) {
                        otherBtn.classList.remove('active');
                        otherBtn.textContent = 'Read More';
                    }
                }
            });
            if (isClosing) {
                content.classList.remove('active');
                btn.classList.remove('active');
                btn.textContent = 'Read More';
            } else {
                content.classList.add('active');
                btn.classList.add('active');
                btn.textContent = 'Read Less';
            }
        }

        window.addEventListener('scroll', () => {
            const header = document.getElementById('mainHeader');
            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });

        function toggleMobileSubmenu(id) {
            const submenu = document.getElementById(id);
            if (submenu.style.display === 'none') {
                submenu.style.display = 'block';
            } else {
                submenu.style.display = 'none';
            }
        }

        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            const icon = document.getElementById('menuIcon');
            const isOpen = menu.classList.contains('active');
            if (isOpen) {
                menu.classList.remove('active');
                icon.setAttribute('data-lucide', 'menu');
                document.body.style.overflow = 'auto';
            } else {
                menu.classList.add('active');
                icon.setAttribute('data-lucide', 'x');
                document.body.style.overflow = 'hidden';
            }
            lucide.createIcons();
        }
    </script>
</body>
</html>
