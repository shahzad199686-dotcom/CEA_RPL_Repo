@{
    ViewData["Title"] = "Official Certification Portal - CEA RPL";
}

<!-- ID Anchors for Navigation -->
<div id="home"></div>

<!-- HERO SECTION -->
<div class="l-hero">
    <div class="l-container">
        <div class="l-hero-content">
            <span class="l-badge">Official Government RPL Portal</span>
            <h1 class="l-hero-title">Certification of <span>Environment Auditors</span></h1>
            <p class="l-hero-sub">
                Official Recognition of Prior Learning (RPL) Application Portal. <br>
                Under Clause 7(i) of Environment Audit Rules, 2025.
            </p>
            
            <div class="l-hero-actions">
                <a href="javascript:void(0)" class="l-cta-btn" onclick="openRoleModal()">
                    <span>Start Your Application</span>
                    <i data-lucide="arrow-right" style="width: 24px; height: 24px;"></i>
                </a>
                <p style="margin-top: 24px; color: var(--l-muted); font-weight: 600;">
                    Already have an account? <a asp-controller="Auth" asp-action="Login" style="color: var(--l-primary); text-decoration: none;">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- HOW IT WORKS SECTION -->
<section class="l-section" id="process">
    <div class="l-container">
        <h2 class="l-section-title">How the Application Process Works</h2>
        <p class="l-section-sub">A streamlined 5-step process designed for industry professionals.</p>
        
        <div class="l-step-grid">
            <div class="l-step-card">
                <div class="l-step-num">1</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="user-plus" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Create Account</h4>
                <p class="text-muted small">Sign up or sign in to your secure portal.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">2</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="edit-3" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Fill Form</h4>
                <p class="text-muted small">Complete 15 sections of professional details.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">3</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="upload-cloud" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Upload Docs</h4>
                <p class="text-muted small">Attach all required certificates and proofs.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">4</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="check-circle" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Review</h4>
                <p class="text-muted small">Verify all details before final submission.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">5</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="map-pin" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Track</h4>
                <p class="text-muted small">Receive confirmation and track progress.</p>
            </div>
        </div>
    </div>
</section>

<!-- DOCUMENTS REQUIRED SECTION -->
<section class="l-section" id="docs" style="background: var(--l-accent); border-radius: 60px; margin: 0 20px;">
    <div class="l-container">
        <h2 class="l-section-title">Documents Required</h2>
        <p class="l-section-sub">Please keep the following documents ready for smooth application submission.</p>
        
        <div class="row g-4 text-start">
            @{
                string[] docs = { 
                    "Recent Photograph", "Government ID / Citizenship Proof", "Educational Certificates", 
                    "Experience Certificates", "Project / Audit Reports", "Training Documents", 
                    "Research Papers", "Awards / Recognition", "Payment Receipt", "Declaration" 
                };
            }
            @foreach(var doc in docs) {
                <div class="col-md-6 col-lg-4">
                    <div class="d-flex align-items-center p-3 bg-white shadow-sm border" style="border-radius: 16px; transition: 0.3s; cursor: default;">
                        <div class="me-3" style="width: 32px; height: 32px; background: #e6f6f6; color: #0ea5a5; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i data-lucide="check" style="width: 16px; height: 16px;"></i>
                        </div>
                        <span class="fw-bold text-muted small">@doc</span>
                    </div>
                </div>
            }
        </div>

        <div class="row g-4 mt-5 text-start">
            <div class="col-md-6">
                <div class="p-4 bg-white border h-100" style="border-radius: 24px; border-left: 6px solid #0ea5a5 !important;">
                     <div class="d-flex gap-3 align-items-start">
                        <i data-lucide="clock" class="text-primary" style="width: 24px; height: 24px; margin-top: 4px;"></i>
                        <div>
                            <h5 class="fw-bold">Estimated Time</h5>
                            <p class="text-muted mb-0">It typically takes 20-30 minutes to complete the dynamic form if all documents are ready.</p>
                        </div>
                     </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-4 bg-white border h-100" style="border-radius: 24px; border-left: 6px solid #f59e0b !important;">
                    <div class="d-flex gap-3 align-items-start">
                        <i data-lucide="alert-circle" style="width: 24px; height: 24px; color: #f59e0b; margin-top: 4px;"></i>
                        <div>
                            <h5 class="fw-bold" style="color: #92400e;">Important Notice</h5>
                            <p class="text-muted mb-0">Incomplete submissions or incorrect document uploads may lead to application rejection or processing delays.</p>
                        </div>
                     </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES SECTION -->
<section class="l-section" id="help">
    <div class="l-container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 text-start">
                <h2 class="l-section-title">Professional Excellence in Environment Auditing</h2>
                <p class="l-section-sub ms-0">We provide a secure, official gateway for environmental professionals to gain certification under official audit rules.</p>
                <div class="d-flex flex-column gap-4 mt-5">
                    <div class="d-flex gap-3">
                        <div class="p-3 bg-light rounded-3 text-primary"><i data-lucide="shield-check"></i></div>
                        <div><h5 class="fw-bold">Two-Step Verification</h5><p class="text-muted small">Secure OTP-based authentication to protect your official data records.</p></div>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="p-3 bg-light rounded-3 text-primary"><i data-lucide="bar-chart-3"></i></div>
                        <div><h5 class="fw-bold">Real-time Progress</h5><p class="text-muted small">Track your auditor application status directly from your secure candidate portal.</p></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                 <div class="p-5 bg-white shadow-lg" style="border-radius: 40px; border: 1px solid #f1f5f9;">
                    <i data-lucide="help-circle" class="text-primary mb-4" style="width: 48px; height: 48px;"></i>
                    <h3 class="fw-bold">Need Help?</h3>
                    <p class="text-muted">Our dedicated support team is available during official working hours to assist you with the application process.</p>
                    <a href="mailto:support@cearpl.gov.in" class="btn btn-hero-primary mt-4" style="background: #0ea5a5; color: white; padding: 12px 30px; border-radius: 12px; text-decoration: none; font-weight: 700;">Contact Support</a>
                 </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA FINAL -->
<section class="l-section">
    <div class="l-container">
        <div class="cta-card p-5" style="border-radius: 40px; background: linear-gradient(135deg, #0ea5a5 0%, #064e4e 100%);">
            <h2 class="text-white fw-bold display-5">Become a Certified Auditor</h2>
            <p class="text-white opacity-75 fs-5">Fast-track your professional certification today.</p>
            <button onclick="openRoleModal()" class="btn btn-light btn-lg px-5 py-3 fw-bold mt-4" style="color: #0ea5a5; border-radius: 16px;">Begin Application Process</button>
        </div>
    </div>
</section>

<!-- ROLE SELECTION MODAL -->
<div class="l-modal-overlay" id="roleModal">
    <div class="l-modal">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Select Your Role</h2>
            <button class="btn btn-ghost p-2 rounded-circle" onclick="closeRoleModal()"><i data-lucide="x"></i></button>
        </div>
        <p class="text-muted">How would you like to use the portal today? Please choose your role to proceed.</p>
        
        <div class="l-role-grid">
            <a asp-controller="Auth" asp-action="CandidateLogin" class="l-role-card">
                <div class="l-role-icon"><i data-lucide="user"></i></div>
                <h3>Candidate</h3>
                <p>Register or Login to start/track your auditor certification application.</p>
            </a>
            <a asp-controller="Auth" asp-action="AdminLogin" class="l-role-card">
                <div class="l-role-icon"><i data-lucide="shield-check"></i></div>
                <h3>Admin</h3>
                <p>Audit and manage applications. This requires authorized personnel credentials.</p>
            </a>
        </div>
    </div>
</div>

<script>
    function openRoleModal() {
        document.getElementById('roleModal').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function closeRoleModal() {
        document.getElementById('roleModal').style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    // Smooth anchor scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            if (targetId === '#') return;
            const target = document.querySelector(targetId);
            if (target) {
                const headerOffset = 100;
                const elementPosition = target.getBoundingClientRect().top;
                const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

                window.scrollTo({
                    top: offsetPosition,
                    behavior: "smooth"
                });
            }
        });
    });
</script>
