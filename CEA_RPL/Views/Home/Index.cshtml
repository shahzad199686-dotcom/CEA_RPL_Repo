@{
    ViewData["Title"] = "Official Certification Portal - CEA RPL";
}

<!-- ID Anchors for Navigation -->
<div id="home"></div>

<!-- HERO SECTION -->
<div class="l-hero">
    <div class="l-container">
        <div class="l-hero-content">
            <h1 class="l-hero-title">Certification of <span>Environmental Auditors</span></h1>
            <p class="l-hero-sub" style="font-size: 1.25rem;">
                Welcome to the application portal for Certification of Environmental Auditors (CEA) through Recognition of Prior Learning (RPL) under the Environment Audit Rules, 2025.
            </p>
            
            <p class="text-muted fw-bold mb-5" style="font-size: 1rem;">
                Applicants are advised to carefully review the following guidelines before proceeding with the application.
            </p>

            <div class="l-hero-actions">
                <a href="javascript:void(0)" class="l-cta-btn" onclick="openRoleModal()">
                    <span>Start Your Application</span>
                    <i data-lucide="arrow-right" style="width: 24px; height: 24px;"></i>
                </a>
                <p style="margin-top: 24px; color: var(--l-muted); font-weight: 600;">
                    Already have an account? <a asp-controller="Auth" asp-action="Login" style="color: var(--l-primary); text-decoration: none;">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- ELIGIBILITY SECTION -->
<section class="l-section" id="eligibility" style="background: white;">
    <div class="l-container">
        <h2 class="l-section-title">Eligibility Criteria</h2>
        <p class="l-section-sub">Please ensure you meet the following requirements before applying.</p>
        
        <div class="l-eligibility-grid">
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="user-check"></i></div>
                <div class="l-elig-content">
                    <h4>Citizenship</h4>
                    <p>Applicant must be an Indian citizen.</p>
                </div>
            </div>
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="graduation-cap"></i></div>
                <div class="l-elig-content">
                    <h4>Educational Qualification</h4>
                    <p>Must possess a Bachelor’s / Master’s / Ph.D. degree from a recognized institution (UGC/AICTE) in relevant disciplines. Refer detailed guidelines for list of eligible disciplines.</p>
                </div>
            </div>
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="briefcase"></i></div>
                <div class="l-elig-content">
                    <h4>Professional Experience</h4>
                    <p>Post-qualification experience required: <br>• Bachelor’s: 12 years <br>• Master’s: 10 years <br>• Ph.D.: 8 years</p>
                </div>
            </div>
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="calendar"></i></div>
                <div class="l-elig-content">
                    <h4>Age Limit</h4>
                    <p>Applicant must be below 70 years as on the closing date of application.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- HOW IT WORKS SECTION -->
<section class="l-section" id="process" style="background: var(--l-accent);">
    <div class="l-container">
        <h2 class="l-section-title">How the Application Process Works</h2>
        <p class="l-section-sub">A streamlined process designed for industry professionals.</p>
        
        <div class="l-step-grid">
            <div class="l-step-card">
                <div class="l-step-num">1</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="user-plus" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Create Account</h4>
                <p class="text-muted small">Sign up or sign in to your secure portal.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">2</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="file-edit" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Fill Form</h4>
                <p class="text-muted small">Complete the comprehensive application details.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">3</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="upload-cloud" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Upload Docs</h4>
                <p class="text-muted small">Attach all required certificates and reports.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">4</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="eye" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Review</h4>
                <p class="text-muted small">Verify all details before final submission.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">5</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="check-circle" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Submit & Track</h4>
                <p class="text-muted small">Finalize application and track its progress.</p>
            </div>
        </div>
    </div>
</section>

<!-- DOCUMENTS SECTION -->
<section class="l-section" id="docs">
    <div class="l-container">
        <h2 class="l-section-title">Documents Required</h2>
        <p class="l-section-sub">Please keep the following documents ready before filling out the application form.</p>
        
        <div class="l-doc-container">
            <!-- Mandatory Documents -->
            <div class="l-doc-card mandatory">
                <h3><i data-lucide="check-circle-2" style="color: var(--l-primary);"></i> Mandatory Documents</h3>
                <div class="l-doc-list">
                    <div class="l-doc-item"><span class="l-doc-num">1.</span> <span>Degree Certificate(s)</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">2.</span> <span>Government-approved Photo Identity Card</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">3.</span> <span>Experience Certificates (Subject to verification)</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">4.</span> <span>Applicant's photograph and signature</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">5.</span> <span>2 to 5 audit/study reports (authored/co-authored)</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">6.</span> <span>Payment receipt</span></div>
                </div>
            </div>

            <!-- Additional Documents -->
            <div class="l-doc-card additional">
                <h3><i data-lucide="check-circle-2" style="color: var(--l-primary);"></i> Additional Documents</h3>
                <div class="l-doc-list">
                    <div class="l-doc-item"><span class="l-doc-num">1.</span> <span>Final year marksheet(s) of relevant degrees</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">2.</span> <span>Details of certifications / training</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">3.</span> <span>Membership in professional bodies</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">4.</span> <span>Details of papers published / presented</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">5.</span> <span>Awards / Recognition</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">6.</span> <span>Any other relevant enclosure</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- IMPORTANT NOTES -->
<section class="l-section" style="background: #f8fafc;">
    <div class="l-container">
        <div class="l-info-box">
            <h3><i data-lucide="alert-triangle" style="vertical-align: middle; margin-right: 10px;"></i> Important Notes</h3>
            <ul class="l-info-list">
                <li>Applicants must go through the detailed guidelines before filling out the application.</li>
                <li>Applicants must select the relevant category at the time of application.</li>
                <li>An applicant can choose multiple categories while applying.</li>
                <li>Applicants must pay a non-refundable fee for each selected category to ensure high-quality processing.</li>
            </ul>
        </div>
    </div>
</section>

<!-- ABOUT SECTION -->
<section class="l-section" id="about">
    <div class="l-container">
        <h2 class="l-section-title">About the CEA RPL Portal</h2>
        <p class="l-section-sub" style="max-width: 800px;">
            This portal enables eligible professionals to apply for Certification of Environmental Auditors through the Recognition of Prior Learning (RPL) process under the Environment Audit Rules, 2025. It is designed to provide a structured, transparent, and user-friendly application experience.
        </p>
    </div>
</section>

<!-- FAQ SECTION -->
<section class="l-section" id="faq" style="background: var(--l-accent);">
    <div class="l-container">
        <h2 class="l-section-title">Frequently Asked Questions</h2>
        <p class="l-section-sub">Common queries regarding the application process.</p>
        
        <div class="l-faq-container">
            <div class="l-faq-item">
                <div class="l-faq-header" onclick="toggleFaq(this)">
                    <span class="l-faq-title">Who can apply for Certification of Environmental Auditors?</span>
                    <i data-lucide="chevron-down" class="l-faq-icon"></i>
                </div>
                <div class="l-faq-content">
                    Applicants must be Indian citizens, possess a Bachelor/Master/PhD in relevant disciplines from UGC/AICTE recognized institutions, meet the required post-qualification experience (8-12 years), and be below 70 years of age.
                </div>
            </div>
            <div class="l-faq-item">
                <div class="l-faq-header" onclick="toggleFaq(this)">
                    <span class="l-faq-title">Can I apply for more than one category?</span>
                    <i data-lucide="chevron-down" class="l-faq-icon"></i>
                </div>
                <div class="l-faq-content">
                    Yes, an applicant can choose multiple categories while applying. Each category selection requires a corresponding application fee.
                </div>
            </div>
            <div class="l-faq-item">
                <div class="l-faq-header" onclick="toggleFaq(this)">
                    <span class="l-faq-title">Are the application fees refundable?</span>
                    <i data-lucide="chevron-down" class="l-faq-icon"></i>
                </div>
                <div class="l-faq-content">
                    No, the application fee is non-refundable for each selected category in order to ensure the successful processing of all high-quality submissions.
                </div>
            </div>
            <div class="l-faq-item">
                <div class="l-faq-header" onclick="toggleFaq(this)">
                    <span class="l-faq-title">What documents should I keep ready before applying?</span>
                    <i data-lucide="chevron-down" class="l-faq-icon"></i>
                </div>
                <div class="l-faq-content">
                    You should keep mandatory documents like degree certificates, photo ID, experience certificates, photo/signature, and audit reports ready. For a full list, refer to the "Documents Required" section above.
                </div>
            </div>
            <div class="l-faq-item">
                <div class="l-faq-header" onclick="toggleFaq(this)">
                    <span class="l-faq-title">Is there an age limit for applying?</span>
                    <i data-lucide="chevron-down" class="l-faq-icon"></i>
                </div>
                <div class="l-faq-content">
                    Yes, the applicant must be below 70 years of age as on the closing date of the application.
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA FINAL -->
<section class="l-section">
    <div class="l-container">
        <div class="cta-card p-5" style="border-radius: 40px; background: linear-gradient(135deg, #0ea5a5 0%, #064e4e 100%);">
            <h2 class="text-white fw-bold display-5">Begin Your Application Process</h2>
            <p class="text-white opacity-75 fs-5">Apply for Certification of Environmental Auditors through the official RPL application portal.</p>
            <button onclick="openRoleModal()" class="btn btn-light btn-lg px-5 py-3 fw-bold mt-4" style="color: #0ea5a5; border-radius: 16px;">Start Your Application</button>
        </div>
    </div>
</section>

<!-- ROLE SELECTION MODAL -->
<div class="l-modal-overlay" id="roleModal">
    <div class="l-modal">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Select Your Role</h2>
            <button class="btn btn-ghost p-2 rounded-circle" onclick="closeRoleModal()"><i data-lucide="x"></i></button>
        </div>
        <p class="text-muted">How would you like to use the portal today? Please choose your role to proceed.</p>
        
        <div class="l-role-grid">
            <a asp-controller="Auth" asp-action="CandidateLogin" class="l-role-card">
                <div class="l-role-icon"><i data-lucide="user"></i></div>
                <h3>Candidate</h3>
                <p>Register or Login to start/track your auditor certification application.</p>
            </a>
            <a asp-controller="Auth" asp-action="AdminLogin" class="l-role-card">
                <div class="l-role-icon"><i data-lucide="shield-check"></i></div>
                <h3>Admin</h3>
                <p>Audit and manage applications. This requires authorized personnel credentials.</p>
            </a>
        </div>
    </div>
</div>

<script>
    function toggleFaq(header) {
        const item = header.parentElement;
        item.classList.toggle('active');
    }

    function openRoleModal() {
        document.getElementById('roleModal').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function closeRoleModal() {
        document.getElementById('roleModal').style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    // Smooth anchor scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            if (targetId === '#') return;
            const target = document.querySelector(targetId);
            if (target) {
                const headerOffset = 100;
                const elementPosition = target.getBoundingClientRect().top;
                const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

                window.scrollTo({
                    top: offsetPosition,
                    behavior: "smooth"
                });
            }
        });
    });
</script>
