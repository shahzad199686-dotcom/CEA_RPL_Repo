@{
    ViewData["Title"] = "Welcome to CEA RPL";
}

<div class="landing-hero" style="padding: 80px 20px; text-align: center; background: linear-gradient(135deg, #0ea5a5 0%, #088383 100%); color: white; border-radius: 20px; margin-top: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
    <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 20px;">Certification of Environment Auditors</h1>
    <p style="font-size: 1.25rem; opacity: 0.9; max-width: 700px; margin: 0 auto 40px; line-height: 1.6;">
        Recognition of Prior Learning (RPL) Application Portal. <br>
        Under Clause 7(i) of Environment Audit Rules, 2025.
    </p>
    
    <div style="display: flex; gap: 20px; justify-content: center;">
        <a asp-controller="Application" asp-action="Index" class="btn" style="background: white; color: #0ea5a5; padding: 16px 32px; border-radius: 12px; font-weight: 700; text-decoration: none; font-size: 1.1rem; box-shadow: 0 10px 20px rgba(0,0,0,0.1); transition: transform 0.2s;">
            Get Started
        </a>
        <a asp-controller="Auth" asp-action="Login" class="btn" style="background: rgba(255,255,255,0.15); color: white; padding: 16px 32px; border-radius: 12px; font-weight: 600; text-decoration: none; border: 1px solid rgba(255,255,255,0.3); backdrop-filter: blur(10px);">
            Sign In
        </a>
    </div>
</div>

<div class="features-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; margin-top: 60px; padding: 0 20px;">
    <div class="feature-card" style="background: white; padding: 30px; border-radius: 16px; border: 1px solid #eee; transition: transform 0.3s;">
        <div style="color: #0ea5a5; margin-bottom: 15px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 style="margin-bottom: 10px;">Streamlined Application</h3>
        <p style="color: #666; font-size: 0.95rem;">Completely digital recognition of prior learning process for environmental professionals.</p>
    </div>
    <div class="feature-card" style="background: white; padding: 30px; border-radius: 16px; border: 1px solid #eee; transition: transform 0.3s;">
        <div style="color: #0ea5a5; margin-bottom: 15px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3 style="margin-bottom: 10px;">Secure Verification</h3>
        <p style="color: #666; font-size: 0.95rem;">Two-step authentication and encrypted data storage to keep your professional records safe.</p>
    </div>
    <div class="feature-card" style="background: white; padding: 30px; border-radius: 16px; border: 1px solid #eee; transition: transform 0.3s;">
        <div style="color: #0ea5a5; margin-bottom: 15px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 style="margin-bottom: 10px;">Official Certification</h3>
        <p style="color: #666; font-size: 0.95rem;">Become a certified environment auditor officially recognized under the 2025 rules.</p>
    </div>
</div>

<style>
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .btn:hover {
        transform: translateY(-2px);
    }
</style>
