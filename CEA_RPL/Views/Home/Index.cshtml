@{
    ViewData["Title"] = "Official Certification Portal - CEA RPL";
}

<!-- ID Anchors for Navigation -->
<div id="home"></div>

<!-- HERO SECTION -->
<div class="l-hero">
    <div class="l-container">
        <div class="l-hero-content">
            <h1 class="l-hero-title">Certification of <span>Environmental Auditors</span></h1>
            <p class="l-hero-sub" style="font-size: 1.25rem;">
                Welcome to the application portal for Certification of Environmental Auditors (CEA) through Recognition of Prior Learning (RPL) under the <a href="https://static.pib.gov.in/WriteReadData/specificdocs/documents/2025/sep/doc202593627401.pdf" target="_blank" rel="noopener noreferrer" style="color: var(--l-primary); text-decoration: underline; white-space: nowrap;">Environment Audit Rules, 2025.</a>
            </p>
            
            <p class="text-muted fw-bold mb-5" style="font-size: 1rem;">
                Applicants are advised to carefully review the guidelines before proceeding with the application.
            </p>

            <div class="l-hero-actions">
                <a href="javascript:void(0)" class="l-cta-btn" onclick="openRoleModal()">
                    <span>Start Your Application</span>
                    <i data-lucide="arrow-right" style="width: 24px; height: 24px;"></i>
                </a>
                <p style="margin-top: 24px; color: var(--l-muted); font-weight: 600;">
                    Already have an account? <a asp-controller="Auth" asp-action="Login" style="color: var(--l-primary); text-decoration: none;">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

<!-- ABOUT THE FRAMEWORK SECTION -->
<section class="l-section" id="about" style="background: white;">
    <div class="l-container">
        <h2 class="l-section-title">About</h2>
        <p class="l-section-sub">This portal operates under the Environment Audit Rules, 2025 to ensure transparent, standardized, and efficient environmental auditing in India.</p>
        
        <div class="l-framework-grid">
            <!-- CEA Card -->
            <div class="l-framework-card">
                <div class="l-framework-icon"><i data-lucide="user-check"></i></div>
                <h4>Certified Environment Auditor (CEA)</h4>
                <p class="l-card-short">An individual certified by EADA to conduct environmental audits under the Environment Audit Rules, 2025.</p>
                
                <div class="l-card-expandable" id="expand-cea">
                    <div class="l-expand-inner">
                        <div class="l-expand-section">
                            <h6>Overview</h6>
                            <p>A Certified Environment Auditor (CEA) is an individual certified by the Environment Audit Designated Agency (EADA) to conduct environmental audits under the Environment Audit Rules, 2025.</p>
                            <p>It also includes performing functions as prescribed by the Central Government from time to time.</p>
                        </div>

                        <div class="l-expand-section">
                            <h6>Certification Modes</h6>
                            <ul>
                                <li>
                                    <strong>Recognition of Prior Learning (RPL)</strong>
                                    <br>• Certification based on prior experience and expertise
                                    <br>• Available for a limited period as defined by the Central Government
                                </li>
                                <li>
                                    <strong>National Certification Examination (NCE)</strong>
                                    <br>• Structured examination process
                                    <br>• Used to assess eligibility for certification
                                </li>
                            </ul>
                            <p class="mt-2" style="font-size: 0.85rem; font-style: italic; color: var(--l-muted);">
                                Eligibility criteria for both modes are defined in official government guidelines.
                            </p>
                        </div>

                        <div class="l-expand-section">
                            <h6>Validity & Renewal</h6>
                            <ul>
                                <li>Certification validity: 5 years</li>
                                <li>Can be revoked earlier if required</li>
                                <li>Renewable based on government guidelines</li>
                                <li>Renewal subject to meeting specified criteria</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <button class="l-read-more-btn" id="btn-cea" onclick="toggleExpand('cea')">Read More</button>
            </div>

            <!-- EADA Card -->
            <div class="l-framework-card">
                <div class="l-framework-icon"><i data-lucide="shield-check"></i></div>
                <h4>Environment Audit Designated Agency (EADA)</h4>
                <p class="l-card-short">Established under the Environment Audit Rules, 2025 by the MoEF&CC, it manages and regulates the environmental audit framework in India.</p>
                
                <div class="l-card-expandable" id="expand-eada">
                    <div class="l-expand-inner">
                        <div class="l-expand-section">
                            <h6>Overview</h6>
                            <p>The Environment Audit Designated Agency (EADA) is established under the Environment Audit Rules, 2025 by the Ministry of Environment, Forest and Climate Change (MoEF&CC). It is responsible for managing the environmental audit framework in India.</p>
                        </div>

                        <div class="l-expand-section">
                            <h6>Legal Framework</h6>
                            <ul>
                                <li>Environment (Protection) Act, 1986</li>
                                <li>Water (Prevention and Control of Pollution) Act, 1974</li>
                                <li>Air (Prevention and Control of Pollution) Act, 1981</li>
                                <li>Van (Sanrakshan Evam Samvardhan) Adhiniyam, 1980</li>
                                <li>Wild Life (Protection) Act, 1972</li>
                                <li>Related environmental rules and approvals (EC, CTE, CTO)</li>
                            </ul>
                        </div>

                        <div class="l-expand-section">
                            <h6>Key Responsibilities</h6>
                            <ul>
                                <li> Undertaking environment audits of projects, activities, or processes governed by applicable environmental laws and regulations;</li>
                                <li> Conducting sampling and analysis of emissions, effluents, wastes, and evaluating the effectiveness of pollution control and waste management systems installed;</li>
                                <li> Reporting any violations or non-compliance of applicable environmental regulations related to the project, process, or activity;</li>
                                <li> Computing environmental compensation for non-compliance and violations, wherever required by the competent authority;</li>
                                <li> Preparing and submitting environmental audit reports in accordance with extant regulations and guidelines;</li>
                                <li> Carrying out verification activities related to the Green Credit Registry established under Rule 10 of the Green Credit Rules, 2023, as a designated agency if authorized;</li>
                                <li> Undertaking environmental audits assigned by the Central Pollution Control Board, State Pollution Control Board, or Pollution Control Committee, including under Extended Producer Responsibility (EPR) framework;</li>
                                <li> Undertaking environmental audits under the Ecomark Rules, 2024 as assigned by the competent authority;</li>
                                <li> Conducting audits under Environment Impact Assessment (EIA) Notification, 2006 and Coastal Regulation Zone (CRZ) Notifications, 2011 & 2019;</li>
                                <li> Undertaking environmental audits assigned by project proponents under applicable environmental laws, rules, regulations, and notifications;</li>
                                <li> Verifying self-compliance reports submitted by projects to ensure adherence to environmental standards and conditions;</li>
                                <li> Performing any other functions as directed by the Central Government from time to time.</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <button class="l-read-more-btn" id="btn-eada" onclick="toggleExpand('eada')">Read More</button>
            </div>

            <!-- NPC Card -->
            <div class="l-framework-card">
                <div class="l-framework-icon"><i data-lucide="building"></i></div>
                <h4>National Productivity Council (NPC)</h4>
                <p class="l-card-short">An autonomous organization established in 1958 under DPIIT, Ministry of Commerce and Industry, Government of India.</p>
                
                <div class="l-card-expandable" id="expand-npc">
                    <div class="l-expand-inner">
                        <div class="l-expand-section">
                            <h6>Overview</h6>
                            <p>The National Productivity Council (NPC), established in 1958, is an autonomous organisation under the Department for Promotion of Industry and Internal Trade (DPIIT), Ministry of Commerce and Industry, Government of India.</p>
                            <p>It was set up as a multipartite, non-profit organisation with equal representation from employers' and workers' organisations, the Government, and technical/professional institutions.</p>
                        </div>

                        <div class="l-expand-section">
                            <h6>Mission & Leadership</h6>
                            <ul>
                                <li>Mission: Develop, disseminate, and apply knowledge and experience in productivity</li>
                                <li>Promproductivity consciousness and improvement</li>
                                <li>President: Union Minister of Commerce and Industry</li>
                                <li>Chairman of Governing Body: Secretary, DPIIT</li>
                            </ul>
                        </div>

                        <div class="l-expand-section">
                            <h6>Services & Areas of Work</h6>
                            <p class="mb-2">NPC provides consultancy and training services to Government and public and private sector organisations in various areas:</p>
                            <ul>
                                <li>Industrial Engineering</li>
                                <li>Agri-Business</li>
                                <li>Economic Services</li>
                                <li>Quality Management</li>
                                <li>Human Resource Management</li>
                                <li>Information Technology</li>
                                <li>Technology Management</li>
                                <li>Energy Management</li>
                                <li>Environmental Management</li>
                            </ul>
                        </div>

                        <div class="l-expand-section">
                            <h6>International & National Presence</h6>
                            <ul>
                                <li>Constituent of the Tokyo-based Asian Productivity Organisation (APO)</li>
                                <li>Government of India is a founding member of APO</li>
                                <li>Operates through 13 regional offices</li>
                                <li>Has one training institute</li>
                                <li>Headquarters located in New Delhi</li>
                                <li>Supported by 24+ Local Productivity Councils across the country</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <button class="l-read-more-btn" id="btn-npc" onclick="toggleExpand('npc')">Read More</button>
            </div>
        </div>
    </div>
</section>

<!-- ELIGIBILITY SECTION -->
<section class="l-section" id="eligibility" style="background: var(--l-accent);">
    <div class="l-container">
        <h2 class="l-section-title">Eligibility Criteria</h2>
        <p class="l-section-sub">Please ensure you meet the following requirements before applying.</p>
        
        <div class="l-eligibility-grid">
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="user-check"></i></div>
                <div class="l-elig-content">
                    <h4>Citizenship</h4>
                    <p>Applicant must be an Indian citizen.</p>
                </div>
            </div>
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="graduation-cap"></i></div>
                <div class="l-elig-content">
                    <h4>Educational Qualification</h4>
                    <p>Must possess a Bachelor’s / Master’s / Ph.D. degree from a recognized institution (UGC/AICTE) in relevant disciplines. Refer detailed guidelines for list of eligible disciplines.</p>
                </div>
            </div>
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="briefcase"></i></div>
                <div class="l-elig-content">
                    <h4>Professional Experience</h4>
                    <p>Post-qualification experience required: <br>• Bachelor’s: 12 years <br>• Master’s: 10 years <br>• Ph.D.: 8 years</p>
                </div>
            </div>
            <div class="l-eligibility-card">
                <div class="l-elig-icon"><i data-lucide="calendar"></i></div>
                <div class="l-elig-content">
                    <h4>Age Limit</h4>
                    <p>Applicant must be below 70 years as on the closing date of application.</p>
                </div>
            </div>
        </div>
    </div>
</section>

