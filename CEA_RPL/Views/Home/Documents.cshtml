@{
    ViewData["Title"] = "Documents Required - CEA RPL";
}

<!-- DOCUMENTS SECTION -->
<section class="l-section" id="docs" style="background: var(--l-accent);">
    <div class="l-container">
        <h2 class="l-section-title">Document Required</h2>
        <p class="l-section-sub">Please keep the following documents ready before filling out the application form.</p>
        
        <div class="l-doc-container">
            <!-- Mandatory Documents -->
            <div class="l-doc-card mandatory">
                <h3><i data-lucide="check-circle-2" style="color: var(--l-primary);"></i> Mandatory Documents</h3>
                <div class="l-doc-list">
                    <div class="l-doc-item"><span class="l-doc-num">1.</span> <span>Degree Certificate(s)</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">2.</span> <span>Government-approved Photo Identity Card</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">3.</span> <span>Experience Certificates (Subject to verification)</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">4.</span> <span>Applicant's photograph and signature</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">5.</span> <span>2 to 5 audit/study reports (authored/co-authored)</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">6.</span> <span>Payment receipt</span></div>
                </div>
            </div>

            <!-- Additional Documents -->
            <div class="l-doc-card additional">
                <h3><i data-lucide="check-circle-2" style="color: var(--l-primary);"></i> Additional Documents</h3>
                <div class="l-doc-list">
                    <div class="l-doc-item"><span class="l-doc-num">1.</span> <span>Final year marksheet(s) of relevant degrees</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">2.</span> <span>Details of certifications / training</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">3.</span> <span>Membership in professional bodies</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">4.</span> <span>Details of papers published / presented</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">5.</span> <span>Awards / Recognition</span></div>
                    <div class="l-doc-item"><span class="l-doc-num">6.</span> <span>Any other relevant enclosure</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- IMPORTANT NOTES -->
<section class="l-section" style="background: #f8fafc;">
    <div class="l-container">
        <div class="l-info-box">
            <h3><i data-lucide="alert-triangle" style="vertical-align: middle; margin-right: 10px;"></i> Important Notes</h3>
            <ul class="l-info-list">
                <li>Applicants must go through the detailed guidelines before filling out the application.</li>
                <li>Applicants must select the relevant category at the time of application.</li>
                <li>An applicant can choose multiple categories while applying.</li>
                <li>Applicants must pay a non-refundable fee for each selected category to ensure high-quality processing.</li>
            </ul>
        </div>
    </div>
</section>

