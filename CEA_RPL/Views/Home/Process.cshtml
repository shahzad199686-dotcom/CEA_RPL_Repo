@{
    ViewData["Title"] = "Process - CEA RPL";
}

<!-- HOW IT WORKS SECTION -->
<section class="l-section" id="process" style="background: white;">
    <div class="l-container">
        <h2 class="l-section-title">How the Application Process Works</h2>
        <p class="l-section-sub">A streamlined process designed for industry professionals.</p>
        
        <div class="l-step-grid">
            <div class="l-step-card">
                <div class="l-step-num">1</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="user-plus" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Create Account</h4>
                <p class="text-muted small">Sign up or sign in to your secure portal.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">2</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="file-edit" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Fill Form</h4>
                <p class="text-muted small">Complete the comprehensive application details.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">3</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="upload-cloud" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Upload Docs</h4>
                <p class="text-muted small">Attach all required certificates and reports.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">4</div>
                <div class="l-step-num">4</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="eye" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Review</h4>
                <p class="text-muted small">Verify all details before final submission.</p>
            </div>
            <div class="l-step-card">
                <div class="l-step-num">5</div>
                <div class="l-step-icon" style="color: #0ea5a5; margin-bottom: 20px;">
                    <i data-lucide="check-circle" style="width: 32px; height: 32px;"></i>
                </div>
                <h4 class="fw-bold">Submit & Track</h4>
                <p class="text-muted small">Finalize application and track its progress.</p>
            </div>
        </div>
    </div>
</section>

