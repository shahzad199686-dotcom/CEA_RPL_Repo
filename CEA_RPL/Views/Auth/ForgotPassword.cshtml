@{
    ViewData["Title"] = "Forgot Password - CEA RPL";
}

<div class="auth-page-container" id="resetStep1">
    <div style="text-align: center; margin-bottom: 35px;">
        <h2 style="font-size: 2rem; color: var(--l-ink); margin-bottom: 10px; font-weight: 800;">Reset Password</h2>
        <p style="color: var(--l-muted);">Enter your email to receive a reset code</p>
    </div>

    <form id="resetRequestForm">
        <div style="margin-bottom: 25px;">
            <label for="resetEmail" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.9rem; color: var(--l-ink);">Email Address</label>
            <input id="resetEmail" type="email" placeholder="you@example.com" required style="width: 100%; padding: 14px; border-radius: 12px; border: 2px solid #f1f5f9; outline: none; transition: all 0.2s;" />
        </div>

        <button type="submit" style="width: 100%; background: var(--l-primary); color: white; border: none; padding: 16px; border-radius: 12px; font-size: 1.1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 10px 20px rgba(14,165,165,0.2);">
            Send Reset Code
        </button>
    </form>

    <div style="text-align: center; margin-top: 35px; padding-top: 25px; border-top: 1px solid #eee;">
        <a asp-action="Login" style="color: var(--l-primary); font-weight: 700; text-decoration: none;">Back to Login</a>
    </div>
</div>

<div class="auth-page-container" id="resetStep2" style="display: none;">
    <div style="text-align: center; margin-bottom: 35px;">
        <h2 style="font-size: 2rem; color: var(--l-ink); margin-bottom: 10px; font-weight: 800;">Verify & Reset</h2>
        <p style="color: var(--l-muted);">Enter the code and your new password</p>
    </div>

    <form id="resetPasswordForm">
        <div style="margin-bottom: 20px;">
            <label for="resetOtp" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.9rem; color: var(--l-ink);">6-Digit Code</label>
            <input id="resetOtp" type="text" maxlength="6" placeholder="000000" required style="width: 100%; padding: 14px; border-radius: 12px; border: 2px solid #f1f5f9; outline: none; transition: all 0.2s; text-align: center; letter-spacing: 4px; font-weight: 800; font-size: 1.2rem;" />
        </div>

        <div style="margin-bottom: 25px;">
            <label for="newPassword" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.9rem; color: var(--l-ink);">New Password</label>
            <input id="newPassword" type="password" placeholder="••••••••" required style="width: 100%; padding: 14px; border-radius: 12px; border: 2px solid #f1f5f9; outline: none; transition: all 0.2s;" />
            <p style="font-size: 0.75rem; color: var(--l-muted); margin-top: 6px;">Use at least 8 characters with uppercase, lowercase, number, and special character.</p>
        </div>

        <button type="submit" style="width: 100%; background: var(--l-primary); color: white; border: none; padding: 16px; border-radius: 12px; font-size: 1.1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 10px 20px rgba(14,165,165,0.2);">
            Reset Password
        </button>
        
        <div style="text-align: center; margin-top: 20px;">
            <button type="button" id="resendBtn" onclick="resendOtp()" style="background: none; border: none; color: var(--l-primary); font-weight: 600; cursor: pointer; font-size: 0.9rem;">
                Resend Code
            </button>
        </div>
    </form>
</div>

<div id="statusBox" style="position: fixed; bottom: 40px; right: 40px; padding: 20px 30px; border-radius: 16px; background: white; box-shadow: 0 15px 40px rgba(0,0,0,0.15); display: none; z-index: 5000; font-weight: 600; border-left: 5px solid var(--l-primary); animation: slideIn 0.3s forwards;">
</div>

<style>
    @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    input:focus { border-color: var(--l-primary) !important; box-shadow: 0 0 10px rgba(14,165,165,0.05); }
</style>

<script>
    const step1 = document.getElementById('resetStep1');
    const step2 = document.getElementById('resetStep2');
    const statusBox = document.getElementById('statusBox');

    document.getElementById('resetRequestForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('resetEmail').value;
        const btn = e.target.querySelector('button');
        btn.disabled = true;
        btn.innerText = "Sending...";

        const formData = new FormData();
        formData.append('email', email);

        try {
            const resp = await fetch('/api/auth/reset-request', { method: 'POST', body: formData });
            const data = await resp.json();
            showStatus(data.message, resp.ok ? "success" : "error");
            if (resp.ok) {
                step1.style.display = 'none';
                step2.style.display = 'block';
                startResendTimer();
            }
        } catch (err) {
            showStatus("Connection error.", "error");
        } finally {
            btn.disabled = false;
            btn.innerText = "Send Reset Code";
        }
    });

    let resendTimer = 0;
    function startResendTimer() {
        resendTimer = 60;
        const resendBtn = document.getElementById('resendBtn');
        resendBtn.disabled = true;
        const interval = setInterval(() => {
            resendTimer--;
            resendBtn.innerText = `Resend Code (${resendTimer}s)`;
            if (resendTimer <= 0) {
                clearInterval(interval);
                resendBtn.disabled = false;
                resendBtn.innerText = "Resend Code";
            }
        }, 1000);
    }

    async function resendOtp() {
        const email = document.getElementById('resetEmail').value;
        const formData = new FormData();
        formData.append('email', email);

        try {
            const resp = await fetch('/api/auth/reset-request', { method: 'POST', body: formData });
            const data = await resp.json();
            showStatus(data.message, resp.ok ? "success" : "error");
            if (resp.ok) {
                startResendTimer();
            }
        } catch (err) {
            showStatus("Connection error.", "error");
        }
    }

    document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('resetEmail').value;
        const otp = document.getElementById('resetOtp').value;
        const password = document.getElementById('newPassword').value;
        const btn = e.target.querySelector('button');

        const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z]).{8,}$/;
        if (!passwordRegex.test(password)) {
            return showStatus("Password must be at least 8 characters and include uppercase, lowercase, number, and special character.", "error");
        }

        btn.disabled = true;
        btn.innerText = "Resetting...";

        const formData = new FormData();
        formData.append('email', email);
        formData.append('otp', otp);
        formData.append('newPassword', password);

        try {
            const resp = await fetch('/api/auth/reset-password', { method: 'POST', body: formData });
            const data = await resp.json();
            showStatus(data.message, resp.ok ? "success" : "error");
            if (resp.ok) {
                setTimeout(() => window.location.href = '/Auth/Login', 2000);
            }
        } catch (err) {
            showStatus("Connection error.", "error");
        } finally {
            btn.disabled = false;
            btn.innerText = "Reset Password";
        }
    });

    function showStatus(msg, type = "success") {
        statusBox.innerText = msg;
        statusBox.style.borderLeftColor = type === "success" ? "var(--l-primary)" : "#ef4444";
        statusBox.style.display = 'block';
        setTimeout(() => { statusBox.style.display = 'none'; }, 5000);
    }
</script>
