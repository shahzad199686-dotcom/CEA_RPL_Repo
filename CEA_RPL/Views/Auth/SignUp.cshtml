@{
    Layout = null; // No global header/footer for auth pages
    ViewData["Title"] = "Create Account - CEA RPL";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --primary-green: #0E5A3C;
            --primary-hover: #0B4A32;
            --text-main: #1F2937;
            --text-muted: #6B7280;
            --border-color: #E5E7EB;
            --req-color: #DC2626;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(to bottom right, #f0fdf4, #ecfdf5);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-main);
            padding: 20px;
        }

        .auth-card {
            background: white;
            width: 100%;
            max-width: 500px;
            padding: 32px 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--border-color);
            position: relative;
            animation: cardFadeUp 0.5s ease-out;
        }

        @@keyframes cardFadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .auth-logo {
            display: block;
            width: 56px;
            height: auto;
            margin: 0 auto 16px;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .auth-title {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 6px;
            letter-spacing: -0.025em;
        }

        .auth-subtitle {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
            font-size: 0.85rem;
            color: #4B5563;
        }

        .req {
            color: var(--req-color);
            font-weight: 500;
            margin-left: 2px;
        }

        .form-input {
            width: 100%;
            height: 48px;
            padding: 0 16px;
            border-radius: 10px;
            border: 2px solid var(--border-color);
            outline: none;
            transition: all 0.2s;
            font-size: 0.95rem;
        }

        .form-input:focus {
            border-color: var(--primary-green);
            box-shadow: 0 0 0 4px rgba(14, 90, 60, 0.1);
        }

        .btn-auth {
            width: 100%;
            background: var(--primary-green);
            color: white;
            border: none;
            height: 48px;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-auth:hover:not(:disabled) {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .btn-auth:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .auth-link {
            color: var(--primary-green);
            text-decoration: none;
            font-weight: 700;
        }

        .auth-link:hover {
            text-decoration: underline;
        }

        .back-home {
            position: absolute;
            top: -35px;
            left: 0;
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--primary-green);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            transition: transform 0.2s;
        }

        .back-home:hover {
            transform: translateX(-4px);
        }

        #authStatus {
            margin-top: 12px;
            padding: 10px;
            border-radius: 8px;
            text-align: center;
            font-size: 0.85rem;
            font-weight: 500;
            display: none;
        }

        .otp-input {
            letter-spacing: 8px;
            text-align: center;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--primary-green);
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        @@media (max-width: 640px) {
            .grid-2 {
                grid-template-columns: 1fr;
                gap: 0;
            }
        }

        @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

<div class="auth-card">
    <a href="/" class="back-home">
        <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i>
        Back to Home
    </a>

    <img src="/images/eada_logo.png" alt="EADA" class="auth-logo">

    <div class="auth-header">
        <h2 class="auth-title">Get Started</h2>
        <p class="auth-subtitle">Begin your certification process</p>
    </div>

    <form id="registerForm">
        <!-- STEP 1: EMAIL VERIFICATION -->
        <div id="step1">
            <div class="form-group">
                <label for="email" class="form-label">Email Address <span class="req">*</span></label>
                <div style="display: flex; gap: 8px;">
                    <input id="email" name="email" type="email" class="form-input" placeholder="you@example.com" required style="flex: 1;" />
                    <button type="button" id="btnSendOtp" class="btn-auth" style="width: 110px; font-size: 0.85rem;">
                        Send OTP
                    </button>
                </div>
                <div id="cooldownTimer" style="font-size: 0.75rem; color: var(--text-muted); margin-top: 5px; display: none;">Resend available in <span id="seconds">60</span>s</div>
            </div>
            
            <div class="g-recaptcha" data-sitekey="6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI" style="margin-bottom: 16px; display: flex; justify-content: center; transform: scale(0.85);"></div>

            <!-- OTP INPUT -->
            <div id="otpInputArea" style="display: none; margin-bottom: 16px; animation: fadeIn 0.3s ease-out;">
                <label for="emailOtp" class="form-label" style="text-align: center;">Enter 6-digit Code</label>
                <div style="display: flex; flex-direction: column; align-items: center; gap: 10px;">
                    <input id="emailOtp" type="text" maxlength="6" inputmode="numeric" placeholder="000000" class="form-input otp-input" style="width: 180px;" />
                    <button type="button" id="btnVerifyEmail" class="btn-auth" style="width: 100%; max-width: 180px; height: 42px; font-size: 0.9rem;">
                        Verify Email
                    </button>
                </div>
            </div>
            
            <div id="emailVerifiedBadge" style="display: none; text-align: center; padding: 8px; background: #F0F7F4; color: var(--primary-green); border-radius: 8px; font-weight: 700; margin-bottom: 16px; border: 1px solid #E5E7EB; font-size: 0.85rem;">
                ✓ Email Verified Successfully
            </div>
        </div>

        <!-- STEP 2: PROFILE DETAILS -->
        <div id="profileDetails" style="opacity: 0.5; pointer-events: none; transition: opacity 0.3s;">
            <div class="grid-2">
                <div class="form-group">
                    <label for="firstName" class="form-label">First Name <span class="req">*</span></label>
                    <input id="firstName" name="firstName" type="text" class="form-input" placeholder="First" required />
                </div>
                <div class="form-group">
                    <label for="lastName" class="form-label">Last Name <span class="req">*</span></label>
                    <input id="lastName" name="lastName" type="text" class="form-input" placeholder="Last" required />
                </div>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label for="mobileNumber" class="form-label">Mobile Number <span class="req">*</span></label>
                    <input id="mobileNumber" name="mobile" type="text" maxlength="10" class="form-input" placeholder="10-digit mobile" required oninput="this.value=this.value.replace(/[^0-9]/g,'');" />
                </div>

                <div class="form-group">
                    <label for="confirmMobileNumber" class="form-label">Confirm Mobile Number <span class="req">*</span></label>
                    <input id="confirmMobileNumber" type="text" maxlength="10" class="form-input" placeholder="Re-enter mobile" required oninput="this.value=this.value.replace(/[^0-9]/g,'');" />
                </div>
            </div>
            <div id="mobileError" style="color: var(--req-color); font-size: 0.75rem; margin-top: -8px; margin-bottom: 16px; font-weight: 600; display: none;">Mobile numbers do not match</div>

            <button type="submit" id="btnContinue" disabled class="btn-auth">
                Complete Registration
                <i data-lucide="check-circle" style="width: 20px; height: 20px;"></i>
            </button>
        </div>
    </form>

    <div id="authStatus"></div>

    <div class="auth-footer">
        Already a member? <a asp-action="Login" class="auth-link">Sign In</a>
    </div>
</div>


<script>
    lucide.createIcons();

    const registerForm = document.getElementById('registerForm');
    const authStatus = document.getElementById('authStatus');
    const btnSendOtp = document.getElementById('btnSendOtp');
    const btnVerifyEmail = document.getElementById('btnVerifyEmail');
    const otpInputArea = document.getElementById('otpInputArea');
    const profileDetails = document.getElementById('profileDetails');
    const btnContinue = document.getElementById('btnContinue');
    const emailInput = document.getElementById('email');

    let isEmailVerified = false;
    let cooldown = 0;

    // STEP 1: SEND OTP
    btnSendOtp.addEventListener('click', async () => {
        const email = emailInput.value.trim();
        if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) return alert('Please enter a valid email address.');

        const captchaToken = grecaptcha.getResponse();
        if (!captchaToken) {
            alert('Please verify that you are not a robot.');
            return;
        }

        btnSendOtp.disabled = true;
        btnSendOtp.innerText = 'Sending...';
        
        const formData = new FormData();
        formData.append('email', email);
        formData.append('captchaToken', captchaToken);

        try {
            const resp = await fetch('/api/auth/sendotp', { method: 'POST', body: formData });
            const data = await resp.json();
            
            if (resp.ok) {
                showStatus(data.message, '#F0F7F4', '#0E5A3C');
                otpInputArea.style.display = 'block';
                startCooldown();
            } else {
                showStatus(data.message, '#fff5f5', '#e53e3e');
                btnSendOtp.disabled = false;
                btnSendOtp.innerText = 'Send OTP';
                grecaptcha.reset();
            }
        } catch (err) {
            showStatus('Connection failed.', '#fff5f5', '#e53e3e');
            btnSendOtp.disabled = false;
            btnSendOtp.innerText = 'Send OTP';
            grecaptcha.reset();
        }
    });

    // STEP 2: VERIFY OTP
    btnVerifyEmail.addEventListener('click', async () => {
        const otp = document.getElementById('emailOtp').value;
        const email = emailInput.value;

        if (!otp || otp.length < 6) return alert('Enter 6-digit code');

        const formData = new FormData();
        formData.append('email', email);
        formData.append('emailOtp', otp);

        btnVerifyEmail.disabled = true;
        btnVerifyEmail.innerText = 'Verifying...';

        try {
            const resp = await fetch('/api/auth/verifyotp', { method: 'POST', body: formData });
            if (resp.ok) {
                isEmailVerified = true;
                otpInputArea.style.display = 'none';
                document.getElementById('emailVerifiedBadge').style.display = 'block';
                emailInput.readOnly = true;
                btnSendOtp.style.display = 'none';
                
                // Unlock rest of form
                profileDetails.style.opacity = '1';
                profileDetails.style.pointerEvents = 'auto';
                checkFormValidity();
                showStatus('Email verified!', '#F0F7F4', '#0E5A3C');
            } else {
                const data = await resp.json();
                showStatus(data.message, '#fff5f5', '#e53e3e');
                btnVerifyEmail.disabled = false;
                btnVerifyEmail.innerText = 'Verify Email';
            }
        } catch (err) {
            showStatus('Verification failed.', '#fff5f5', '#e53e3e');
            btnVerifyEmail.disabled = false;
        }
    });

    // COOLDOWN LOGIC
    function startCooldown() {
        cooldown = 60;
        document.getElementById('cooldownTimer').style.display = 'block';
        btnSendOtp.disabled = true;
        btnSendOtp.style.opacity = '0.5';
        
        const timer = setInterval(() => {
            cooldown--;
            document.getElementById('seconds').innerText = cooldown;
            if (cooldown <= 0) {
                clearInterval(timer);
                document.getElementById('cooldownTimer').style.display = 'none';
                btnSendOtp.disabled = false;
                btnSendOtp.style.opacity = '1';
                btnSendOtp.innerText = 'Send OTP';
                grecaptcha.reset();
            }
        }, 1000);
    }

    function checkFormValidity() {
        if (!isEmailVerified) return;
        const fname = document.getElementById('firstName').value.trim();
        const lname = document.getElementById('lastName').value.trim();
        
        const mobileInput = document.getElementById('mobileNumber');
        const confirmInput = document.getElementById('confirmMobileNumber');
        const mobileRaw = mobileInput?.dataset.raw || '';
        const confirmRaw = confirmInput?.dataset.raw || '';

        const isMobileValid = /^[6-9][0-9]{9}$/.test(mobileRaw);
        const isMatch = mobileRaw === confirmRaw && isMobileValid;
        
        const allValid = fname.length >= 2 && lname.length >= 2 && isMatch;
        btnContinue.disabled = !allValid;
        btnContinue.style.opacity = allValid ? "1" : "0.6";
        btnContinue.style.cursor = allValid ? "pointer" : "not-allowed";
    }

    function validateMobileMatch() {
        const mobileInput = document.getElementById("mobileNumber");
        const confirmInput = document.getElementById("confirmMobileNumber");
        const errorDiv = document.getElementById('mobileError');

        const mobileRaw = mobileInput?.dataset.raw || '';
        const confirmRaw = confirmInput?.dataset.raw || '';

        if (!mobileRaw || !confirmRaw) {
            errorDiv.style.display = 'none';
            confirmInput.style.borderColor = '#E5E7EB';
            return;
        }

        const isMatch = mobileRaw === confirmRaw;
        const is10Digits = /^[0-9]{10}$/.test(mobileRaw);

        if (isMatch) {
            errorDiv.style.display = 'none';
            confirmInput.style.borderColor = '#E5E7EB';
        } else {
            errorDiv.style.display = 'block';
            errorDiv.innerText = "Mobile numbers do not match.";
            confirmInput.style.borderColor = '#e53e3e';
        }
    }

    function maskMobile(value) {
        if (!value || value.length < 4) return value;
        return "XXXXXX" + value.slice(-4);
    }

    ['firstName', 'lastName', 'mobileNumber', 'confirmMobileNumber'].forEach(id => {
        const el = document.getElementById(id);
        
        if (id === 'mobileNumber' || id === 'confirmMobileNumber') {
            el.addEventListener('focus', function() {
                const val = this.dataset.raw || '';
                if (val) this.value = val;
            });
            el.addEventListener('blur', function() {
                if (this.value && !this.value.includes('XXXXXX')) {
                    this.dataset.raw = this.value.replace(/\D/g, '');
                }
                validateMobileMatch();
                if (this.dataset.raw) {
                    this.value = maskMobile(this.dataset.raw);
                }
            });
            el.addEventListener('input', function() {
                if (this.value && !this.value.includes('XXXXXX')) {
                    this.dataset.raw = this.value.replace(/\D/g, '');
                }
                validateMobileMatch();
                checkFormValidity();
            });
        } else {
            el.addEventListener('input', checkFormValidity);
        }
    });

    registerForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        showStatus('Finalizing registration...', '#edf2f7', '#4a5568');
        
        const formData = new FormData(registerForm);
        
        const mobileInput = document.getElementById('mobileNumber');
        const mobileRaw = mobileInput?.dataset.raw || '';
        
        if (mobileRaw) {
            formData.set('mobile', mobileRaw);
        }
        
        try {
            const resp = await fetch('/api/auth/signup', { method: 'POST', body: formData });
            if (resp.ok) {
                showStatus('Account created successfully!', '#F0F7F4', '#0E5A3C');
                setTimeout(() => window.location.href = '/Application/Index', 1500);
            } else {
                const data = await resp.json();
                showStatus(data.message, '#fff5f5', '#e53e3e');
            }
        } catch (err) {
            showStatus('Submission failed.', '#fff5f5', '#e53e3e');
        }
    });

    function showStatus(msg, bg, color) {
        authStatus.innerText = msg;
        authStatus.style.background = bg;
        authStatus.style.color = color;
        authStatus.style.display = 'block';
    }
</script>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
</body>
</html>
